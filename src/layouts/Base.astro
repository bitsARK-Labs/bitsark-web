---
import '../styles/global.css';
import Logo              from '@components/Logo.astro';
import DolarMapLogo      from '@components/DolarMapLogo.astro';
import MobileMenu        from '@components/MobileMenu.astro';
import EmailObfuscated   from '@components/EmailObfuscated.astro';
import LangBanner        from '@components/LangBanner.astro';
import { ClientRouter } from 'astro:transitions';
import { useTranslations } from '../i18n';


export interface Props {
  title:       string;
  description: string;
  ogImage?:    string;
  canonical?:  string;
  lang?:       string;
  schema?:     object;
  ogType?:     string;
  /**
   * hreflang alternates para sites bilíngues.
   * Forneça APENAS quando a página counterpart já existir em produção.
   * Apontar hreflang para páginas inexistentes gera penalidade no Google.
   *
   * Exemplo:
   * alternates={[
   *   { hreflang: 'en',        href: 'https://bitsark.com/exchanges/' },
   *   { hreflang: 'pt-BR',     href: 'https://bitsark.com/pt/exchanges/' },
   *   { hreflang: 'x-default', href: 'https://bitsark.com/exchanges/' },
   * ]}
   */
  alternates?: Array<{ hreflang: string; href: string }>;
  noindex?:    boolean;
}


const {
  title,
  description,
  ogImage    = 'https://bitsark.com/og-default.png',
  canonical,
  lang       = 'en',
  schema,
  ogType     = 'website',
  alternates = [],
  noindex    = false,
} = Astro.props;


const path         = Astro.url.pathname;
const canonicalURL = canonical ?? `https://bitsark.com${path}`;

/**
 * og:image deve ser SEMPRE URL absoluta. Facebook/LinkedIn/Twitter validators
 * rejeitam paths relativos. Se uma página passar "/foo.png", convertemos
 * para "https://bitsark.com/foo.png" automaticamente.
 */
const absoluteOgImage = ogImage.startsWith('http')
  ? ogImage
  : `https://bitsark.com${ogImage.startsWith('/') ? '' : '/'}${ogImage}`;

// ── Normaliza o idioma para UI e SEO (padroniza em pt-BR) ──
const normalizedLang = lang.startsWith('pt') ? 'pt-BR' : 'en';

// ── Detecção de produto (suporta /pt/* e raiz) ──────────────
const isDolarMap    = path.startsWith('/dolarmap')            || path.startsWith('/pt/dolarmap');
const isExchanges   = path.startsWith('/exchanges')           || path.startsWith('/pt/exchanges');
const isStablecoins = path.startsWith('/stablecoins-brasil')  || path.startsWith('/pt/stablecoins-brasil');
const isApiPage     = path.startsWith('/exchanges/api')       || path.startsWith('/pt/exchanges/api');

// ── Strings de UI no idioma correto ───────────────────────
const t = useTranslations(normalizedLang);


// ── Helper para localizar links internos ──────────────────
// Garante DUAS coisas:
//   1. Tradução PT (/foo → /pt/foo/) quando o idioma é pt-BR.
//   2. Barra final em TODO link interno (trailingSlash: 'always') - evita o
//      redirect 308 do host e o erro "trailing slash mismatch" no SiteChecker.
const l = (link: string): string => {
  if (link.startsWith('http') || link.startsWith('#')) return link;

  const translated = [
    '/', '/about', '/exchanges', '/exchanges/decripto',
    '/terms', '/dolarmap', '/stablecoins-brasil',
    '/dolarmap/privacy', '/dolarmap/terms', '/dolarmap/support',
    '/stablecoins-brasil/receber-exterior-pj', '/exchanges/api',
  ];

  const hashIndex = link.indexOf('#');
  const cleanPath = (hashIndex >= 0 ? link.slice(0, hashIndex) : link)
    .replace(/\/$/, '') || '/';
  const fragment = hashIndex >= 0 ? link.slice(hashIndex) : '';

  if (
    normalizedLang === 'pt-BR' &&
    translated.includes(cleanPath)
  ) {
    const ptPath = cleanPath === '/' ? '/pt/' : `/pt${cleanPath}/`;
    return `${ptPath}${fragment}`;
  }

  // Normaliza barra final para links internos (preserva fragmento e raiz).
  const withSlash = cleanPath === '/' ? '/' : `${cleanPath}/`;
  return `${withSlash}${fragment}`;
};


// ── Helper para garantir que links de alternates sejam sempre relativos ──
const toRelative = (url?: string): string | undefined => {
  if (!url) return undefined;
  try {
    const pathname = new URL(url).pathname;
    return pathname.endsWith('/') ? pathname : `${pathname}/`;
  } catch {
    return url;
  }
};


// ── Cálculo de hrefs para o seletor de idioma ─────────────
// Prioriza alternates fornecidos; caso contrário, vai para a home do idioma.
const langHrefs: Record<string, string> = {
  'en':    toRelative(alternates.find(a => a.hreflang === 'en' || a.hreflang === 'x-default')?.href) ?? '/',
  'pt-BR': toRelative(alternates.find(a => a.hreflang.startsWith('pt'))?.href) ?? '/pt/',
};


// ── Idiomas disponíveis ───────────────────────────────────
const languages = [
  { code: 'pt-BR', label: 'PT', flag: '🇧🇷' },
  { code: 'en',    label: 'EN', flag: '🇺🇸' },
];


// ── Nav links (desktop) ───────────────────────────────────
const navLinks = isDolarMap ? [
  { label: t('nav.dolarmap.buy'),    href: l('/dolarmap#buy')       },
  { label: t('nav.dolarmap.sell'),   href: l('/dolarmap#sell')      },
  { label: t('nav.dolarmap.alerts'), href: l('/dolarmap#alertas')   },
] : isExchanges ? [
  { label: t('nav.exchanges.list'),        href: l('/exchanges')             },
  { label: t('nav.exchanges.decripto'),    href: l('/exchanges/decripto')    },
  { label: t('nav.exchanges.api'),         href: l('/exchanges/api')         },
  { label: t('nav.exchanges.stablecoins'), href: l('/stablecoins-brasil')    },
] : isStablecoins ? [
  { label: t('nav.stablecoins.size'),       href: l('/stablecoins-brasil#data')      },
  { label: t('nav.stablecoins.receiverPj'), href: l('/stablecoins-brasil/receber-exterior-pj')    },
  { label: t('nav.stablecoins.exchanges'),  href: l('/exchanges')                                 },
] : [
  { label: t('nav.home.dolarmap'),    href: l('/dolarmap')           },
  { label: t('nav.home.exchanges'),   href: l('/exchanges')          },
  { label: t('nav.home.stablecoins'), href: l('/stablecoins-brasil') },
];


// ── CTA (desktop) ────────────────────────────────────────
const cta = isDolarMap ? {
  label:    t('nav.cta.playstore'),
  href:     'https://play.google.com/store/apps/details?id=dolarmap.app',
  external: true,
} : isExchanges ? {
  label:    t('nav.cta.api'),
  href:     l('/exchanges/api'),
  external: false,
} : isStablecoins ? {
  label:    t('nav.cta.dolarmap'),
  href:     'https://play.google.com/store/apps/details?id=dolarmap.app',
  external: true,
} : null;


// ── Nav links (mobile) ────────────────────────────────────
const mobileLinks = isDolarMap ? [
  { label: t('nav.dolarmap.buy'),       href: l('/dolarmap#buy')        },
  { label: t('nav.dolarmap.sell'),      href: l('/dolarmap#sell')       },
  { label: t('nav.dolarmap.arbitrage'), href: l('/dolarmap#arbitragem') },
  { label: t('nav.dolarmap.notify'),    href: l('/dolarmap#alertas')    },
  { label: t('nav.cta.playstore'),      href: 'https://play.google.com/store/apps/details?id=dolarmap.app', external: true },
] : isExchanges ? [
  { label: t('nav.exchanges.list'),     href: l('/exchanges')           },
  { label: t('nav.exchanges.decripto'), href: l('/exchanges/decripto')  },
  { label: t('nav.exchanges.api'),      href: l('/exchanges/api')       },
] : isStablecoins ? [
  { label: t('nav.stablecoins.size'),       href: l('/stablecoins-brasil#stablecoin-inflow')      },
  { label: t('nav.stablecoins.receiverPj'), href: l('/stablecoins-brasil/receber-exterior-pj')    },
  { label: t('nav.stablecoins.dollar'),     href: l('/dolarmap')                                  },
  { label: t('nav.stablecoins.exchanges'),  href: l('/exchanges')                                 },
  { label: t('nav.cta.dolarmap'),           href: 'https://play.google.com/store/apps/details?id=dolarmap.app', external: true },
] : [
  { label: t('nav.home.dolarmap'),    href: l('/dolarmap')           },
  { label: t('nav.home.exchanges'),   href: l('/exchanges')          },
  { label: t('nav.home.stablecoins'), href: l('/stablecoins-brasil') },
];
---


<!doctype html>
<html lang={normalizedLang}>
  <head>
    <!-- 1. Charset e viewport SEMPRE primeiros -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- 2. Title logo após charset/viewport -->
    <title>{title}</title>

    <!-- 3. Color scheme: scrollbars/inputs em dark mode corretos nativamente -->
    <meta name="color-scheme" content="dark" />

    <!-- SEO Core -->
    <meta name="description"  content={description} />
    <meta name="robots"       content={noindex ? 'noindex, nofollow' : 'index, follow'} />
    <meta name="googlebot"    content={noindex ? 'noindex, nofollow' : 'index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1'} />
    <link rel="canonical"     href={canonicalURL} />
    <meta name="author"       content="Ricardo Delfino" />
    <meta name="publisher"    content="bitsARK Labs" />

    <!-- 
      Fontes self-hosted (MIT - Geist by Vercel).
      Preload antecipado com fetchpriority="high" para eliminar FOUT/CLS.
    -->
    <link rel="preload" as="font" type="font/woff2" href="/fonts/GeistVF.woff2"     crossorigin fetchpriority="high" />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/GeistMonoVF.woff2" crossorigin fetchpriority="high" />

    <!--
      hreflang: renderizado SOMENTE quando a prop `alternates` é fornecida
      E a página é indexável.
      Regras (Google):
        1. Nunca apontar hreflang para uma página inexistente.
        2. NUNCA emitir hreflang em página `noindex` - hreflang e noindex são
           sinais contraditórios (hreflang = "indexe estas variantes"; noindex =
           "não indexe"). O Search Console reporta os dois lados do cluster como
           erro ("noindex URL has incoming hreflang" / "outgoing hreflang to
           noindex URL"). O seletor de idioma da UI continua funcionando via
           `langHrefs` - apenas as tags <link rel="alternate"> são suprimidas.
      Forneça `alternates` apenas quando ambas as variantes estiverem em produção.
    -->
    {!noindex && alternates.map(alt => (
      <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
    ))}

    <!-- Open Graph -->
    <meta property="og:type"            content={ogType} />
    <meta property="og:url"             content={canonicalURL} />
    <meta property="og:locale"          content={normalizedLang === 'pt-BR' ? 'pt_BR' : 'en_US'} />
    <meta property="og:site_name"       content="bitsARK Labs" />
    <meta property="og:title"           content={title} />
    <meta property="og:description"     content={description} />
    <meta property="og:image"           content={absoluteOgImage} />
    <meta property="og:image:secure_url" content={absoluteOgImage} />
    <meta property="og:image:type"      content="image/png" />
    <meta property="og:image:width"     content="1200" />
    <meta property="og:image:height"    content="630" />
    <meta property="og:image:alt"       content={title} />
    {alternates
      .filter(a => a.hreflang !== 'x-default' && a.hreflang !== normalizedLang)
      .map(alt => (
        <meta property="og:locale:alternate"
              content={alt.hreflang === 'pt-BR' ? 'pt_BR' : 'en_US'} />
      ))
    }

    <!-- Twitter / X Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:site"        content="@bitsARKLabs" />
    <meta name="twitter:creator"     content="@bitsARKLabs" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={absoluteOgImage} />
    <meta name="twitter:image:alt"   content={title} />

    <!--
      View Transitions API (Astro 5 ClientRouter).
      `fallback="none"` desativa o animation fallback em browsers sem suporte
      (Safari < 18.2, Firefox < 134) - navegação tradicional é preservada
      e nenhum JS é executado. Em browsers compatíveis, ganha-se transição
      suave entre páginas + prefetch automático no hover.
    -->
    <ClientRouter fallback="none" />

    <!-- Favicons -->
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=1.0" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png?v=1.0" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png?v=1.0" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png?v=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=1.0" />
    <link rel="manifest" href="/site.webmanifest?v=1.0" />
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color="#4f98a3" />
    <meta name="apple-mobile-web-app-title" content="bitsARK" />
    <meta name="msapplication-TileColor"    content="#0f1012" />
    <meta name="theme-color"                content="#0a0b0d" />
    <link rel="shortcut icon" href="/favicon.ico?v=1.0" />

    <!-- Schema.org JSON-LD dinâmico (por página) -->
    {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}

    <!--
      Schema Organization fixo (fonte ÚNICA de verdade, presente em todas as páginas).

      SCHEMA POLICY:
      - A Organization é declarada UMA única vez (logo abaixo).
      - Outras páginas DEVEM referenciar via { "@id": "https://bitsark.com/#organization" }.
      - NUNCA redeclarar "@type": "Organization" em outra página - duplicar o @id
        provoca conflito de campos (ex: "url" duplicado) e o Rich Results Test
        DESCARTA o @graph inteiro (incluindo BreadcrumbList, FAQPage, etc.).

        Errado:  publisher: { "@type": "Organization", "name": "bitsARK Labs", "url": "..." }
        Certo:   publisher: { "@id": "https://bitsark.com/#organization" }

      Guard script: scripts/check-schema-duplicates.mjs roda no postbuild
      e falha o build se qualquer HTML em dist/ tiver mais de uma Organization.
    -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "@id": "https://bitsark.com/#organization",
      "name": "bitsARK Labs",
      "legalName": "Tecnologia Atual Serviços LTDA",
      "taxID": "51.334.748/0001-61",
      "url": "https://bitsark.com",
      "logo": {
        "@type": "ImageObject",
        "url": "https://bitsark.com/images/logo.png",
        "width": 1200,
        "height": 1200
      },
      "image": "https://bitsark.com/images/logo.png",
      "founder": {
        "@type": "Person",
        "@id": "https://bitsark.com/about/#ricardo",
        "name": "Ricardo Delfino",
        "url": "https://bitsark.com/about/"
      },
      "foundingDate": "2025",
      "contactPoint": {
        "@type": "ContactPoint",
        "email": "support@bitsark.com",
        "contactType": "customer support",
        "availableLanguage": ["English", "Portuguese"]
      },
      "sameAs": [
        "https://github.com/bitsARK-Labs",
        "https://www.linkedin.com/in/ricardods/",
        "https://twitter.com/bitsarklabs",
        "https://play.google.com/store/apps/dev?id=7793792104800726717"
      ]
    })} /> 
    <!-- 
      A propriedade "url" em Schema.org para Organization deve ser a URL base do site, 
      sem a barra final, conforme as diretrizes mais recentes.
    -->

    <style is:global>
      .skip-link {
        border-radius: 0 0 var(--radius-md) var(--radius-md);
      }

      /* ── DolarMap Nav Identity ──────────────────────────── */
      .dm-identity-nav {
        display: flex;
        align-items: center;
        gap: 0.55rem;
        min-width: 0;
      }
      .dm-identity-nav__link {
        display: inline-flex;
        align-items: center;
        text-decoration: none;
      }
      .dm-identity-nav__product {
        position: relative;
        display: flex;
        align-items: center;
      }
      .dm-logo-svg {
        height: 18px;
        width: auto;
        color: var(--color-text);
      }

      /* "by" separator - editorial dashes (never a pipe) */
      .dm-identity-nav__by {
        position: relative;
        font-family: var(--font-body);
        font-size: 0.55rem;
        color: var(--color-text-faint);
        letter-spacing: 0.02em;
        font-weight: 600;
        opacity: 0.55;
        padding: 0 0.65rem;
      }
      .dm-identity-nav__by::before,
      .dm-identity-nav__by::after {
        content: '';
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        width: 6px;
        height: 1px;
        background: currentColor;
        opacity: 0.6;
      }
      .dm-identity-nav__by::before { left: 0; }
      .dm-identity-nav__by::after  { right: 0; }

      .dm-identity-nav__endorser {
        display: flex;
        align-items: center;
        margin-top: 10px;
        --logo-bits-color: var(--color-text-faint);
        --logo-ark-color: var(--color-text-faint);
        --logo-labs-color: var(--color-text-faint);
        --logo-bracket-color: var(--color-text-faint);
        transition: --logo-bits-color 0.3s ease;
      }
      .dm-identity-nav__link:hover .dm-identity-nav__endorser {
        --logo-bits-color: var(--color-text-muted);
        --logo-ark-color: var(--color-text-muted);
        --logo-labs-color: var(--color-text-muted);
        --logo-bracket-color: var(--color-text-muted);
      }
      .dm-identity-nav__endorser :global(.logo-svg) {
        height: 11px;
        width: auto;
      }
      .dm-identity-nav__endorser-full,
      .dm-identity-nav__endorser-compact {
        display: inline-flex;
      }
      .dm-identity-nav__endorser-compact { display: none; }

      /* Mobile <= 540px - swap to compact bitsARK (sem Labs, bracket curto) */
      @media (max-width: 540px) {
        .dm-identity-nav__endorser-full { display: none; }
        .dm-identity-nav__endorser-compact { display: inline-flex; }
      }

      /* ── Sub-brand (Exchanges / Stablecoins) ──────────── */
      .nav__product-block {
        display: flex;
        flex-direction: column;
        line-height: 1.1;
        gap: 0;
      }
      .nav__product-block__name {
        font-family: var(--font-mono);
        font-size: 1.05rem;
        font-weight: 700;
        letter-spacing: -0.02em;
        white-space: nowrap;
      }
      .nav__product-block__sub {
        font-family: var(--font-mono);
        font-size: 0.85rem;
        font-weight: 500;
        letter-spacing: 0.04em;
      }

      /* ── Modificadores de cor - eliminam inline style= ── */
      .nav__product-block__name--primary { color: var(--color-primary); }
      .nav__product-block__name--success { color: var(--color-success); }
      .nav__product-block__sub--faint    { color: var(--color-text-faint); }

      /* ── Mobile CTA item ────────────────────────────────── */
      .mobile-menu__link--cta {
        margin-top: 0.75rem;
        color: var(--color-primary);
        border-top: 1px solid var(--color-border);
        padding-top: 0.75rem;
      }

      /* ── Lang Picker ─────────────────────────────────────
         Estilos base vivem no global.css.
         Aqui apenas o override específico do layout.
      ─────────────────────────────────────────────────────── */
      .nav__lang-picker {
        align-items: center;
        gap: 0.25rem;
        color: var(--color-text-faint);
      }
      .nav__lang-picker--mobile {
        margin-bottom: 1.5rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--color-border);
      }
      .nav__lang-picker svg {
        width: 14px;
        height: 14px;
        flex-shrink: 0;
        margin-right: 0.1rem;
        opacity: 0.5;
      }
      .nav__lang-link {
        font-family: var(--font-body);
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.02em;
        text-transform: uppercase;
        color: var(--color-text-muted);
        text-decoration: none;
        padding: 0.2em 0.4em;
        border-radius: var(--radius-sm);
        transition: color var(--transition), background var(--transition);
      }
      .nav__lang-link:hover {
        color: var(--color-text);
        background: var(--color-primary-highlight);
      }
      .nav__lang-link.active {
        color: var(--color-primary);
        background: var(--color-primary-highlight);
      }

      /* ── Footer legal bar: layout horizontal com lang picker ── */
      .footer__legal {
        flex-direction: row;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1.5rem;
        flex-wrap: wrap;
      }
      .footer__legal-text {
        flex: 1 1 auto;
        min-width: 0;
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
      }
      .nav__lang-picker--footer {
        flex-shrink: 0;
        margin-right: 0;
      }

      /* Mobile: empilha o picker abaixo do texto legal */
      @media (max-width: 520px) {
        .footer__legal {
          flex-direction: column;
          align-items: flex-start;
          gap: 1rem;
        }
      }
    </style>

    <!--
      Slot nomeado "head": permite que páginas injetem tags adicionais no <head>,
      tipicamente <script type="application/ld+json" slot="head"> para JSON-LD
      específico da página (ex.: FAQPage, Legislation), além do prop `schema`.
    -->
    <slot name="head" />
  </head>

  <body>
    <a href="#main-content" class="skip-link">
      {t('nav.skipLink')}
    </a>

    {normalizedLang === 'en' && (
      <LangBanner ptHref={langHrefs['pt-BR']} />
    )}

    <!-- ── NAV ───────────────────────────────────────────── -->
    <nav class="nav" aria-label={t('nav.ariaLabel')}>
      <div class="container">
        <div class="nav__inner">

          <!-- ── LOGO ─────────────────────────────────────── -->
          {isDolarMap ? (

            /* ── DolarMap: SVG próprio + by + bitsARK faint ── */
            <div class="nav__logo dm-identity-nav">
              <a href={l('/dolarmap')} class="dm-identity-nav__link" aria-label="DolarMap - home">
                <div class="dm-identity-nav__product">
                  <DolarMapLogo gradientId="dm-logo-gradient-nav" aria-hidden="true" focusable="false" />
                </div>
              </a>
              <span class="dm-identity-nav__by">by</span>
              <a href={l('/')} class="dm-identity-nav__link" aria-label={t('nav.ariaHome')}>
                <div class="dm-identity-nav__endorser">
                  <span class="dm-identity-nav__endorser-full"><Logo /></span>
                  <span class="dm-identity-nav__endorser-compact"><Logo compact /></span>
                </div>
              </a>
            </div>

          ) : isExchanges ? (

            /* ── Exchanges: 2 linhas + by + bitsARK faint ── */
            <div class="nav__logo dm-identity-nav">
              <a href={l('/exchanges')} aria-label="Exchanges in Brazil - home">
                <div class="nav__product-block">
                  <span class="nav__product-block__name nav__product-block__name--primary">Exchanges</span>
                  <span class="nav__product-block__sub nav__product-block__sub--faint">in Brazil</span>
                </div>
              </a>
              <span class="dm-identity-nav__by">by</span>
