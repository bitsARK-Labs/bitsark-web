                        // Match exato (sempre prioridade)
                        if (normalizedPath === normalizedHref) return true;

                        // Excluir hubs principais do "startsWith" para evitar duplo highlight em subpáginas
                        const hubs = ['/dolarmap', '/exchanges', '/stablecoins-brasil', '/pt/dolarmap', '/pt/exchanges', '/pt/stablecoins-brasil'];
                        return !hubs.includes(normalizedHref) && normalizedPath.startsWith(normalizedHref + '/');
