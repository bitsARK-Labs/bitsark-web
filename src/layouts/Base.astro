    <!-- ── SCRIPT ─────────────────────────────────────────── -->
    <script>
      // Batch all DOM reads before writes, then commit in a single rAF to avoid
      // forced reflow. The ClientRouter (View Transitions) reads geometry right
      // after DOMContentLoaded; interleaving classList mutations with those reads
      // causes a 699 ms reflow on initial load.
      const currentPath = window.location.pathname.replace(/\/$/, '') || '/';
      const hubPaths = ['/dolarmap', '/exchanges', '/stablecoins-brasil', '/pt/dolarmap', '/pt/exchanges', '/pt/stablecoins-brasil'];

      // Phase 1: read-only - compute which links need which class (no DOM writes)
      const linkUpdates = [];
      document.querySelectorAll('.nav__link').forEach((link) => {
        const href = link.getAttribute('href')?.replace(/\/$/, '') || '';
        if (!href || href.includes('#')) return;
        const isActive =
          currentPath === href ||
          (href !== '' && currentPath.startsWith(href + '/') && !hubPaths.includes(href));
        linkUpdates.push({ el: link, add: isActive });
      });

      const navEl = document.querySelector('.nav') as HTMLElement | null;
      const shouldBeScrolled = window.scrollY > 8;

      // Phase 2: write-only - commit all classList changes in one rAF
      requestAnimationFrame(() => {
        for (const { el, add } of linkUpdates) {
          el.classList.remove('active');
          if (add) el.classList.add('active');
        }

        if (navEl) {
          navEl.classList.toggle('is-scrolled', shouldBeScrolled);
        }
      });

      // Nav scroll state - condense from translucent to opaque after the first 8px
      if (navEl) {
        const onScroll = () => {
          requestAnimationFrame(() => {
            navEl.classList.toggle('is-scrolled', window.scrollY > 8);
          });
        };
        window.addEventListener('scroll', onScroll, { passive: true });
      }
    </script>

    <!-- ── Persistência de Idioma (Gold Standard UX) ── -->
    <script is:inline>
      function bsUpdatePreferredLang() {
        const currentLang = document.documentElement.lang; // 'en' ou 'pt-BR'
        try { localStorage.setItem('preferred-lang', currentLang); } catch (e) {}

        // Captura escolha EXPLÍCITA do usuário em qualquer lang picker (desktop + mobile).
        // Diferencia "última página vista" (preferred-lang) de "decisão consciente"
        // (lang-choice-made) - esta última é usada pelo banner de sugestão de PT
        // para não importunar quem já decidiu.
        // Guard evita registrar o listener mais de uma vez entre navegações suaves.
        if (!document.__bsLangChoiceBound) {
          document.__bsLangChoiceBound = true;
          document.addEventListener('click', function(ev) {
            const target = ev.target instanceof Element
              ? ev.target.closest('[data-lang-choice]')
              : null;
            if (!target) return;
            try {
              localStorage.setItem('lang-choice-made', '1');
            } catch (e) {}
          }, { capture: true });
        }
      }

      bsUpdatePreferredLang();
      document.addEventListener('astro:page-load', bsUpdatePreferredLang);
    </script>

