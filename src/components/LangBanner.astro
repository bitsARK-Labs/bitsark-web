---
/**
 * LangBanner.astro
 * ──────────────────────────────────────────────────────────────────────────
 * Banner discreto exibido no topo das páginas em inglês, sugerindo a versão
 * em português para usuários cujo navegador indica preferência por pt*.
 *
 * Regras de exibição (todas devem ser verdadeiras — checadas no client):
 *   1. Página atual é EN (gate server-side no Base.astro).
 *   2. `navigator.languages` ou `navigator.language` começa com "pt".
 *   3. Usuário nunca dispensou o banner (`lang-banner-dismissed` ausente).
 *   4. Usuário nunca fez escolha explícita de idioma antes
 *      (`lang-choice-made` ausente — gravado pelo script de Base.astro
 *      quando o usuário clica em qualquer `[data-lang-choice]`).
 *
 * Renderiza sempre `hidden` no HTML estático → zero CLS, zero FOUC,
 * gracioso sem JavaScript.
 */

export interface Props {
  /** URL do equivalente em português da página atual. */
  ptHref: string;
}

const { ptHref } = Astro.props;

// Textos sempre em PT — o banner se dirige a um falante de português
// que caiu na versão EN do site. Não há razão para internacionalizar
// essas strings.
const tagLabel  = 'PT-BR';
const message   = 'Este site também está disponível em português.';
const ctaSwitch = 'Ver em português';
const ctaKeep   = 'Manter em inglês';
const ariaRegion = 'Sugestão de idioma';
const ariaClose  = 'Fechar sugestão de idioma';
---

<div
  id="lang-banner"
  class="lang-banner"
  role="region"
  aria-label={ariaRegion}
  hidden
>
  <div class="lang-banner__rail" aria-hidden="true"></div>

  <div class="lang-banner__inner">
    <span class="lang-banner__tag" aria-hidden="true">
      <svg class="lang-banner__glyph" viewBox="0 0 24 24" width="14" height="14"
           fill="none" stroke="currentColor" stroke-width="1.6"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M3 5h7M6.5 5v2.5M4 11c1.4-1.8 2.6-3 2.5-5M9 11c-1.4-1.8-2.6-3-2.5-5"/>
        <path d="M13.5 19l3.5-9 3.5 9M14.7 16.5h4.6"/>
      </svg>
      <span class="lang-banner__tag-text">{tagLabel}</span>
    </span>

    <p class="lang-banner__msg">{message}</p>

    <div class="lang-banner__actions">
      <a
        class="lang-banner__cta"
        href={ptHref}
        data-lang-action="switch"
        data-lang-choice="pt-BR"
      >
        <span>{ctaSwitch}</span>
        <svg viewBox="0 0 24 24" width="12" height="12"
             fill="none" stroke="currentColor" stroke-width="1.8"
             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M13 6l6 6-6 6"/>
        </svg>
      </a>
      <button
        type="button"
        class="lang-banner__keep"
        data-lang-action="keep"
      >{ctaKeep}</button>
    </div>

    <button
      type="button"
      class="lang-banner__close"
      data-lang-action="close"
      aria-label={ariaClose}
    >
      <svg viewBox="0 0 24 24" width="14" height="14"
           fill="none" stroke="currentColor" stroke-width="1.6"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M6 6l12 12M18 6L6 18"/>
      </svg>
    </button>
  </div>
</div>

<style>
  /* ── Container ─────────────────────────────────────────────
     Editorial system notice: hairline gradient on top, dense
     surface, mono tag chip, refined icon set. Reads as a piece
     of product chrome, not a marketing toast.
  ─────────────────────────────────────────────────────────── */
  .lang-banner {
    position: relative;
    display: block;
    background:
      linear-gradient(
        180deg,
        rgba(var(--color-primary-rgb), 0.055) 0%,
        rgba(var(--color-primary-rgb), 0.018) 100%
      ),
      var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    line-height: 1.4;

    opacity: 0;
    transform: translateY(-3px);
    transition:
      opacity 320ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 320ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .lang-banner.is-visible {
    opacity: 1;
    transform: none;
  }
  .lang-banner[hidden] {
    display: none !important;
  }

  /* Top gradient hairline — the "premium" cue.
     Three-stop gradient with soft fade on the edges gives the
     impression of accent light bleeding into the chrome. */
  .lang-banner__rail {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(var(--color-primary-rgb), 0.0) 8%,
      rgba(var(--color-primary-rgb), 0.55) 38%,
      rgba(232, 175, 52, 0.45) 62%,
      rgba(var(--color-primary-rgb), 0.0) 92%,
      transparent 100%
    );
    pointer-events: none;
  }

  /* ── Inner row ───────────────────────────────────────────── */
  .lang-banner__inner {
    width: 100%;
    max-width: var(--content-wide, 1200px);
    margin: 0 auto;
    padding: 0.6rem clamp(1rem, 4vw, 1.5rem);
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }

  /* ── PT-BR tag chip ──────────────────────────────────────── */
  .lang-banner__tag {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.22rem 0.5rem 0.22rem 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-primary);
    background: rgba(var(--color-primary-rgb), 0.08);
    border: 1px solid rgba(var(--color-primary-rgb), 0.22);
    border-radius: var(--radius-sm);
    line-height: 1;
    white-space: nowrap;
    flex-shrink: 0;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.03),
      0 1px 0 rgba(0, 0, 0, 0.2);
  }
  .lang-banner__glyph {
    color: var(--color-primary);
    opacity: 0.85;
  }
  .lang-banner__tag-text {
    /* Optical balance: slight rise for mono caps */
    transform: translateY(0.5px);
  }

  /* ── Message ─────────────────────────────────────────────── */
  .lang-banner__msg {
    margin: 0;
    flex: 1 1 auto;
    min-width: 0;
    color: var(--color-text);
    font-weight: 400;
    letter-spacing: -0.005em;
  }

  /* ── Actions cluster ─────────────────────────────────────── */
  .lang-banner__actions {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  /* Primary CTA — solid teal, precise arrow, the only saturated
     element in the row. Earns its place by being the only ask. */
  .lang-banner__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: -0.005em;
    text-decoration: none;
    color: var(--color-text-inverse);
    background: var(--color-primary);
    padding: 0.42em 0.85em;
    border: 1px solid var(--color-primary);
    border-radius: var(--radius-sm);
    transition:
      background var(--transition),
      border-color var(--transition),
      box-shadow var(--transition),
      transform var(--transition);
    white-space: nowrap;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.18),
      0 1px 0 rgba(0, 0, 0, 0.3);
  }
  .lang-banner__cta svg {
    transition: transform var(--transition);
  }
  .lang-banner__cta:hover,
  .lang-banner__cta:focus-visible {
    background: var(--color-primary-hover);
    border-color: var(--color-primary-hover);
    outline: none;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.22),
      0 0 0 1px rgba(var(--color-primary-rgb), 0.35),
      0 6px 18px rgba(var(--color-primary-rgb), 0.22);
  }
  .lang-banner__cta:hover svg,
  .lang-banner__cta:focus-visible svg {
    transform: translateX(2px);
  }
  .lang-banner__cta:active {
    transform: translateY(0.5px);
  }

  /* Ghost "keep" — recedes intentionally. Underline-on-hover
     uses border-bottom so it doesn't shift the baseline. */
  .lang-banner__keep {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-text-muted);
    background: transparent;
    border: 0;
    border-bottom: 1px solid transparent;
    padding: 0.42em 0.25em;
    cursor: pointer;
    transition: color var(--transition), border-color var(--transition);
    white-space: nowrap;
    line-height: 1;
  }
  .lang-banner__keep:hover,
  .lang-banner__keep:focus-visible {
    color: var(--color-text);
    border-bottom-color: var(--color-text-muted);
    outline: none;
  }

  /* Close — neutral square button, tactile hover. */
  .lang-banner__close {
    margin-left: 0.25rem;
    background: transparent;
    border: 1px solid transparent;
    color: var(--color-text-faint);
    width: 28px;
    height: 28px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-sm);
    cursor: pointer;
    flex-shrink: 0;
    transition:
      color var(--transition),
      background var(--transition),
      border-color var(--transition);
  }
  .lang-banner__close:hover,
  .lang-banner__close:focus-visible {
    color: var(--color-text);
    background: rgba(255, 255, 255, 0.03);
    border-color: var(--color-border);
    outline: none;
  }

  /* ── Motion accessibility ────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .lang-banner,
    .lang-banner__cta,
    .lang-banner__cta svg,
    .lang-banner__keep,
    .lang-banner__close {
      transition: none;
      transform: none;
    }
  }

  /* ── Responsive ──────────────────────────────────────────── */
  @media (max-width: 720px) {
    .lang-banner__inner {
      gap: 0.6rem;
      padding: 0.6rem 1rem;
      flex-wrap: wrap;
    }
    .lang-banner__msg {
      flex: 1 1 100%;
      order: 3;
      font-size: var(--text-xs);
    }
    .lang-banner__tag { order: 1; }
    .lang-banner__close { order: 2; margin-left: auto; }
    .lang-banner__actions {
      order: 4;
      width: 100%;
      justify-content: flex-start;
      gap: 0.6rem;
    }
  }

  @media (max-width: 380px) {
    .lang-banner__cta {
      flex: 1 1 auto;
      justify-content: center;
    }
  }
</style>

<script is:inline>
  (function () {
    function readLS(key) {
      try { return localStorage.getItem(key); } catch (e) { return null; }
    }
    function writeLS(key, value) {
      try { localStorage.setItem(key, value); } catch (e) {}
    }

    function initLangBanner() {
      const el = document.getElementById('lang-banner');
      if (!el || el.dataset.langInit === '1') return;
      el.dataset.langInit = '1';

      // (a) Usuário já dispensou explicitamente o banner antes?
      if (readLS('lang-banner-dismissed') === '1') return;

      // (b) Usuário já fez escolha explícita de idioma em alguma visita?
      //     Se sim, sua escolha prevalece — não importunamos novamente.
      if (readLS('lang-choice-made') === '1') return;

      // (c) Navegador prefere português?
      const langs = []
        .concat(navigator.languages || [])
        .concat([navigator.language || '']);
      const wantsPt = langs.some(function (l) {
        return (l || '').toLowerCase().indexOf('pt') === 0;
      });
      if (!wantsPt) return;

      // (d) Revela com transição
      el.hidden = false;
      requestAnimationFrame(function () {
        el.classList.add('is-visible');
      });

      // (e) Handlers — qualquer interação grava dismissal
      function dismiss() {
        writeLS('lang-banner-dismissed', '1');
        el.classList.remove('is-visible');
        let removed = false;
        const finish = function () {
          if (removed) return;
          removed = true;
          el.remove();
        };
        el.addEventListener('transitionend', finish, { once: true });
        setTimeout(finish, 400);
      }

      const actions = el.querySelectorAll('[data-lang-action]');
      for (let i = 0; i < actions.length; i++) {
        actions[i].addEventListener('click', dismiss);
      }
      el.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') dismiss();
      });
    }

    initLangBanner();
    document.addEventListener('astro:page-load', initLangBanner);
  })();
</script>
