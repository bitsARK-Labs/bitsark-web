  /* ── Desktop: nunca exibir o menu ───────────────────────── */
  @media (min-width: 769px) {
    .bm { display: none !important; }
  }

  /* ── Reduced motion ─────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .bm,
    .bm__panel,
    .bm__section,
    .bm__footer,
    .bm__anchor-arrow,
    .bm__sol-chev,
    .bm__cta-chev,
    .bm__cta {
      transition: none !important;
      animation: none !important;
      transform: none !important;
    }
  }
</style>

<script>
  function initBitsarkMobileMenu(): void {
    const menu     = document.getElementById('bitsark-mobile-menu') as HTMLElement | null;
    const trigger  = document.getElementById('hamburger')           as HTMLButtonElement | null;
    const closeBtn = document.getElementById('bm-close')            as HTMLButtonElement | null;
    if (!menu || !trigger || !closeBtn) return;

    // Idempotência: View Transitions reexecuta o script a cada page-load
    const M = menu as HTMLElement & { __bmInit?: boolean };
    if (M.__bmInit) return;
    M.__bmInit = true;

    const main = document.getElementById('main-content');
    const FOCUSABLE = 'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])';
    let scrollLockY = 0;
    let lastFocused: HTMLElement | null = null;

    function getFocusable(): HTMLElement[] {
      return Array.from(menu!.querySelectorAll(FOCUSABLE)) as HTMLElement[];
    }

    function lockScroll(): void {
      scrollLockY = window.scrollY;
      const scrollbar = window.innerWidth - document.documentElement.clientWidth;
      document.body.style.position = 'fixed';
      document.body.style.top = `-${scrollLockY}px`;
      document.body.style.left = '0';
      document.body.style.right = '0';
      document.body.style.width = '100%';
      if (scrollbar > 0) document.body.style.paddingRight = `${scrollbar}px`;
    }

    function unlockScroll(): void {
      document.body.style.position = '';
      document.body.style.top = '';
      document.body.style.left = '';
      document.body.style.right = '';
      document.body.style.width = '';
      document.body.style.paddingRight = '';
      window.scrollTo(0, scrollLockY);
    }

    function openMenu(): void {
      lastFocused = document.activeElement as HTMLElement;
      menu!.removeAttribute('aria-hidden');
      menu!.removeAttribute('inert');
      menu!.classList.add('is-open');
      trigger!.setAttribute('aria-expanded', 'true');
      trigger!.setAttribute('aria-label', trigger!.dataset.labelClose ?? 'Close menu');
      if (main) {
        main.setAttribute('aria-hidden', 'true');
        main.setAttribute('inert', '');
      }
      lockScroll();
      requestAnimationFrame(() => {
        const first = getFocusable()[0];
        first?.focus();
      });
    }

    function closeMenu(opts: { restoreFocus?: boolean } = { restoreFocus: true }): void {
      menu!.classList.remove('is-open');
      trigger!.setAttribute('aria-expanded', 'false');
      trigger!.setAttribute('aria-label', trigger!.dataset.labelOpen ?? 'Open menu');

      const finalize = () => {
        menu!.setAttribute('aria-hidden', 'true');
        menu!.setAttribute('inert', '');
        if (main) {
          main.removeAttribute('aria-hidden');
          main.removeAttribute('inert');
        }
        unlockScroll();
        if (opts.restoreFocus && lastFocused && document.contains(lastFocused)) {
          lastFocused.focus();
        }
      };

      let done = false;
      const onEnd = (e: TransitionEvent) => {
        if (e.target !== menu) return;
        if (done) return;
        done = true;
        menu!.removeEventListener('transitionend', onEnd);
        finalize();
      };
      menu!.addEventListener('transitionend', onEnd);
      // Failsafe: força finalizar após 260ms
      window.setTimeout(() => {
        if (done) return;
        done = true;
        menu!.removeEventListener('transitionend', onEnd);
        finalize();
      }, 260);
    }

    function toggle(): void {
      if (menu!.classList.contains('is-open')) closeMenu();
      else openMenu();
    }

    // ── Triggers ─────────────────────────────────────────
    trigger.addEventListener('click', toggle);
    closeBtn.addEventListener('click', () => closeMenu());

    // ── Focus trap + ESC ─────────────────────────────────
    menu.addEventListener('keydown', (e: KeyboardEvent) => {
      if (!menu.classList.contains('is-open')) return;

      if (e.key === 'Escape') {
        e.preventDefault();
        closeMenu();
        return;
      }

      if (e.key === 'Tab') {
        const list = getFocusable();
        if (list.length === 0) return;
        const first = list[0];
        const last  = list[list.length - 1];
        const active = document.activeElement as HTMLElement;
        if (e.shiftKey && active === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && active === last) {
          e.preventDefault();
          first.focus();
        }
      }
    });

    // ── Anchor links da mesma página: fecha + smooth-scroll
    menu.querySelectorAll('a[data-anchor]').forEach((a) => {
      a.addEventListener('click', (e: Event) => {
        const anchor = a as HTMLAnchorElement;
        const href = anchor.getAttribute('href') ?? '';
        const hashIdx = href.indexOf('#');
        if (hashIdx < 0) return;

        const targetPath = href.slice(0, hashIdx).replace(/\/$/, '');
        const currentPath = window.location.pathname.replace(/\/$/, '');
        const onSamePage = targetPath === '' || targetPath === currentPath;

        if (onSamePage) {
          e.preventDefault();
          const hash = href.slice(hashIdx + 1);
          closeMenu({ restoreFocus: false });
          window.setTimeout(() => {
            const target = document.getElementById(hash);
            if (target) {
              target.scrollIntoView({ behavior: 'smooth', block: 'start' });
              history.replaceState(null, '', `#${hash}`);
            }
          }, 220);
        } else {
          closeMenu({ restoreFocus: false });
        }
      });
    });

    // ── Qualquer outro link interno fecha antes do swap ──
    menu.querySelectorAll('a[href]').forEach((a) => {
      const anchor = a as HTMLAnchorElement;
      if (anchor.dataset.anchor !== undefined) return; // já tratado acima
      const href = anchor.getAttribute('href') ?? '';
      if (href.startsWith('http') || href.startsWith('mailto:')) return;
      anchor.addEventListener('click', () => {
        if (menu.classList.contains('is-open')) {
          closeMenu({ restoreFocus: false });
        }
      });
    });
  }

  // Primeira execução
  initBitsarkMobileMenu();

  // Re-inicializa após cada navegação SPA do Astro
  document.addEventListener('astro:page-load', initBitsarkMobileMenu);

  // Cleanup antes do swap: garante que o próximo DOM começa limpo
  document.addEventListener('astro:before-swap', () => {
    const menu = document.getElementById('bitsark-mobile-menu');
    if (menu?.classList.contains('is-open')) {
      menu.classList.remove('is-open');
      menu.setAttribute('aria-hidden', 'true');
      menu.setAttribute('inert', '');
      document.body.style.position = '';
      document.body.style.top = '';
      document.body.style.left = '';
      document.body.style.right = '';
      document.body.style.width = '';
      document.body.style.paddingRight = '';
      const main = document.getElementById('main-content');
      if (main) {
        main.removeAttribute('aria-hidden');
        main.removeAttribute('inert');
      }
    }
  });
</script>
