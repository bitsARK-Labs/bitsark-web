  /* ── Company list ──────────────────────────────────────── */
  .bm__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .bm__link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    min-height: 44px;
    padding: 0.4rem 0.5rem;
    color: var(--color-text);
    font-size: var(--text-base);
    font-weight: 500;
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: color 200ms cubic-bezier(0.16, 1, 0.3, 1),
                background 200ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .bm__link:hover { color: var(--color-primary); }
  .bm__link:active { background: rgba(79, 152, 163, 0.06); }
  .bm__link:focus-visible {
