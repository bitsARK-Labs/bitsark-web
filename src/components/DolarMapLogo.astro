---
export interface Props {
  gradientId: string;
  class?: string;
  'aria-label'?: string;
  'aria-hidden'?: boolean | 'true' | 'false';
  role?: string;
  focusable?: boolean | 'false';
}

const {
  gradientId,
  class: className,
  'aria-label': ariaLabel,
  'aria-hidden': ariaHidden,
  role,
  focusable,
} = Astro.props;
