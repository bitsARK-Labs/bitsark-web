<!-- ═══════════════════════════════════════════════════════════
     SIMULADOR Â· VANILLA JS
══════════════════════════════════════════════════════════════ -->
<script is:inline>
  (function () {
    const root = document.getElementById("rep-sim");
    if (!root) return;

    const input    = document.getElementById("rep-sim-input");
    const toggle   = document.getElementById("rep-sim-iof-toggle");
    const presets  = root.querySelectorAll("[data-preset]");
    const iofRow   = root.querySelector("[data-iof-row]");
    const ptaxInput = document.getElementById("rep-sim-ptax-input");
    const ptaxField = document.getElementById("rep-sim-ptax-field");

    const PTAX_FALLBACK = 5.10;
    const lang = root.dataset.locale || document.documentElement.lang || "en";

    /* helpers */
    const num   = (v, fb) => { const n = parseFloat(v); return Number.isFinite(n) ? n : fb; };
    const clamp = (n, lo, hi) => Math.min(hi, Math.max(lo, n));
    const clone = (o) => JSON.parse(JSON.stringify(o));

    /* state (presets in % units; JS converts at calc time) */
    const defaults = {
      fxMode: root.dataset.fxMode === "fintech" ? "fintech" : "wire",
      fx: {
        wire:    { charge: num(root.dataset.wireCharge,    2.5), fixed: num(root.dataset.wireFixed,    35) },
        fintech: { charge: num(root.dataset.fintechCharge, 1.0), fixed: num(root.dataset.fintechFixed,  0) },
      },
      stable: { spread: num(root.dataset.stableSpread, 0.1), fee: num(root.dataset.stableFee, 1.0) },
      iofCambio:         num(root.dataset.iofCambio,         0.38),
      iofStableProposed: num(root.dataset.iofStableProposed, 3.5),
    };
    const state = clone(defaults);
    state.ptax = num(root.dataset.ptax, PTAX_FALLBACK);
    state.iofStableOn = false;

    let userEditedPtax = false;

    /* element caches */
    const outs = {};
    root.querySelectorAll("[data-out]").forEach(el => { outs[el.dataset.out] = el; });
    const inputs = {};
    root.querySelectorAll("[data-field]").forEach(el => { inputs[el.dataset.field] = el; });

    const modeBtns      = root.querySelectorAll("[data-mode]");
    const fxTitle       = root.querySelector("[data-fx-title]");
    const fxChargeLabel = root.querySelector("[data-fx-charge-label]");
    const fxFixedLabel  = root.querySelector("[data-fx-fixed-label]");

    /* formatters */
    const fmtBRL = (n) => new Intl.NumberFormat(lang, {
      style: "currency", currency: "BRL", maximumFractionDigits: 2
    }).format(n);
    const fmtBRLneg = (n) => "−" + fmtBRL(Math.abs(n));
    const fmtPct = (n) => {
      const val = Math.abs(n).toLocaleString(lang, { minimumFractionDigits: 1, maximumFractionDigits: 1 });
      return (n >= 0 ? "+" : "−") + val + "%";
    };

    /* a11y: focus input when clicking anywhere on the wrapper */
    if (ptaxField && ptaxInput) {
      ptaxField.addEventListener("click", () => ptaxInput.focus());
    }

    /* live PTAX fetch */
    async function fetchLivePtax() {
      if (userEditedPtax) return;
      try {
        const today = new Date();
        const start = new Date(today);
        start.setDate(start.getDate() - 7);
        const f = (d) =>
          `${(d.getMonth() + 1).toString().padStart(2, "0")}-${d.getDate().toString().padStart(2, "0")}-${d.getFullYear()}`;
        const url =
          `https://olinda.bcb.gov.br/olinda/servico/PTAX/versao/v1/odata/CotacaoDolarPeriodo(dataInicial=@dataInicial,dataFinalCotacao=@dataFinalCotacao)` +
          `?@dataInicial='${f(start)}'&@dataFinalCotacao='${f(today)}'&$top=1&$orderby=dataHoraCotacao%20desc&$format=json&$select=cotacaoVenda,dataHoraCotacao`;
        const res = await fetch(url);
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const data = await res.json();
        if (!data.value || !data.value[0]) throw new Error("no data");
        if (userEditedPtax) return;
        state.ptax = data.value[0].cotacaoVenda;
        ptaxInput.value = String(state.ptax.toFixed(2)).replace(",", ".");
        calc();
      } catch (e) {
        console.warn("Live PTAX unavailable, using fallback.", e);
        if (!userEditedPtax) {
          state.ptax = PTAX_FALLBACK;
          ptaxInput.value = String(PTAX_FALLBACK.toFixed(2)).replace(",", ".");
          calc();
        }
      }
    }

    ptaxInput.addEventListener("input", () => {
      const v = parseFloat(ptaxInput.value);
      if (isNaN(v) || v <= 0) return;
      userEditedPtax = true;
      state.ptax = v;
      calc();
    });

    /* mode switch (radiogroup) */
    function setMode(mode, focusActive) {
      if (mode !== "wire" && mode !== "fintech") return;
      state.fxMode = mode;
      modeBtns.forEach(btn => {
        const active = btn.dataset.mode === mode;
        btn.classList.toggle("is-active", active);
        btn.setAttribute("aria-checked", active ? "true" : "false");
        btn.setAttribute("tabindex", active ? "0" : "-1");
        if (active) {
          if (fxTitle)       fxTitle.textContent       = btn.dataset.title;
          if (fxChargeLabel) fxChargeLabel.textContent = btn.dataset.chargeLabel;
          if (fxFixedLabel)  fxFixedLabel.textContent  = btn.dataset.fixedLabel;
          if (inputs["fx-charge"]) inputs["fx-charge"].setAttribute("aria-label", btn.dataset.chargeLabel);
          if (inputs["fx-fixed"])  inputs["fx-fixed"].setAttribute("aria-label", btn.dataset.fixedLabel);
          if (focusActive) btn.focus();
        }
      });
      if (inputs["fx-charge"]) inputs["fx-charge"].value = state.fx[mode].charge;
      if (inputs["fx-fixed"])  inputs["fx-fixed"].value  = state.fx[mode].fixed;
      calc();
    }

    modeBtns.forEach(btn => {
      btn.addEventListener("click", () => setMode(btn.dataset.mode));
      btn.addEventListener("keydown", (e) => {
        if (e.key === "ArrowLeft" || e.key === "ArrowUp") {
          e.preventDefault();
          setMode("wire", true);
        } else if (e.key === "ArrowRight" || e.key === "ArrowDown") {
          e.preventDefault();
          setMode("fintech", true);
        }
      });
    });

    /* editable breakdown inputs */
    function applyField(field, raw) {
      const cur = (() => {
        if (field === "fx-charge")     return state.fx[state.fxMode].charge;
        if (field === "fx-fixed")      return state.fx[state.fxMode].fixed;
        if (field === "stable-spread") return state.stable.spread;
        if (field === "stable-fee")    return state.stable.fee;
        return 0;
      })();
      let v = parseFloat(raw);
      if (!Number.isFinite(v)) v = cur;
      switch (field) {
        case "fx-charge":     state.fx[state.fxMode].charge = clamp(v, 0, 10);  break;
        case "fx-fixed":      state.fx[state.fxMode].fixed  = clamp(v, 0, 200); break;
        case "stable-spread": state.stable.spread           = clamp(v, 0, 10);  break;
        case "stable-fee":    state.stable.fee              = clamp(v, 0, 50);  break;
      }
    }

    Object.entries(inputs).forEach(([field, el]) => {
      el.addEventListener("input", () => { applyField(field, el.value); calc(); });
      el.addEventListener("blur", () => {
        if (field === "fx-charge")     el.value = state.fx[state.fxMode].charge;
        if (field === "fx-fixed")      el.value = state.fx[state.fxMode].fixed;
        if (field === "stable-spread") el.value = state.stable.spread;
        if (field === "stable-fee")    el.value = state.stable.fee;
      });
    });

    /* restore defaults per card */
    root.querySelectorAll("[data-restore]").forEach(btn => {
      btn.addEventListener("click", () => {
        const scope = btn.dataset.restore;
        if (scope === "fx") {
          state.fx = clone(defaults.fx);
          if (inputs["fx-charge"]) inputs["fx-charge"].value = state.fx[state.fxMode].charge;
          if (inputs["fx-fixed"])  inputs["fx-fixed"].value  = state.fx[state.fxMode].fixed;
        } else if (scope === "stable") {
          state.stable = clone(defaults.stable);
          if (inputs["stable-spread"]) inputs["stable-spread"].value = state.stable.spread;
          if (inputs["stable-fee"])    inputs["stable-fee"].value    = state.stable.fee;
        }
        calc();
      });
    });

    /* IOF stable toggle */
    toggle.addEventListener("change", () => {
      state.iofStableOn = toggle.checked;
      calc();
    });

    /* calculation */
    function calc() {
      const usd = Math.max(0, num(input.value, 0));
      const m = state.fx[state.fxMode];

      const fxChargeUsd = usd * (m.charge / 100);
      const fxIofUsd    = usd * (state.iofCambio / 100);
      const fxFixedUsd  = m.fixed;
      const fxNetUsd    = Math.max(0, usd - fxChargeUsd - fxIofUsd - fxFixedUsd);

      const stSpreadUsd = usd * (state.stable.spread / 100);
      const stIofUsd    = state.iofStableOn ? usd * (state.iofStableProposed / 100) : 0;
      const stFeeUsd    = state.stable.fee;
      const stNetUsd    = Math.max(0, usd - stSpreadUsd - stIofUsd - stFeeUsd);

      const fxNetBrl  = fxNetUsd * state.ptax;
      const stNetBrl  = stNetUsd * state.ptax;
      const savingsBrl = stNetBrl - fxNetBrl;
      const usdBrl     = usd * state.ptax;
      const savingsPct = usdBrl > 0 ? (savingsBrl / usdBrl) * 100 : 0;

      if (outs["fx-charge"]) outs["fx-charge"].textContent = fmtBRLneg(fxChargeUsd * state.ptax);
      if (outs["fx-iof"])    outs["fx-iof"].textContent    = fmtBRLneg(fxIofUsd    * state.ptax);
      if (outs["fx-fixed"])  outs["fx-fixed"].textContent  = fmtBRLneg(fxFixedUsd  * state.ptax);
      if (outs["fx-net"])    outs["fx-net"].textContent    = fmtBRL(fxNetBrl);

      if (outs["stable-spread"]) outs["stable-spread"].textContent = fmtBRLneg(stSpreadUsd * state.ptax);
      if (outs["stable-iof"])    outs["stable-iof"].textContent    = state.iofStableOn ? fmtBRLneg(stIofUsd * state.ptax) : "-";
      if (outs["stable-fee"])    outs["stable-fee"].textContent    = fmtBRLneg(stFeeUsd * state.ptax);
      if (outs["stable-net"])    outs["stable-net"].textContent    = fmtBRL(stNetBrl);

      if (outs["savings"])     outs["savings"].textContent     = (savingsBrl >= 0 ? "+ " : "− ") + fmtBRL(Math.abs(savingsBrl));
      if (outs["savings-pct"]) outs["savings-pct"].textContent = fmtPct(savingsPct);

      if (iofRow) iofRow.style.opacity = state.iofStableOn ? "1" : "0.4";

      const savingsEl = outs["savings"];
      if (savingsEl) {
        savingsEl.classList.remove("rep-sim__savings-value--pulse");
        void savingsEl.offsetWidth;
        savingsEl.classList.add("rep-sim__savings-value--pulse");
      }
    }

    input.addEventListener("input", calc);
    presets.forEach(btn => btn.addEventListener("click", () => {
      input.value = btn.dataset.preset;
      presets.forEach(b => b.classList.remove("active"));
      btn.classList.add("active");
      calc();
    }));

    calc();
    fetchLivePtax();
  })();

  /* Fade-up on intersection */
  (function () {
    const els = document.querySelectorAll(".fade-up, [style*='--rep-stagger']");
    if (!("IntersectionObserver" in window) || !els.length) return;
    const io = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add("is-visible");
          io.unobserve(e.target);
        }
      });
    }, { rootMargin: "0px 0px -80px 0px", threshold: 0.1 });
    els.forEach(el => io.observe(el));
  })();

  /* FAQ nav highlight on scroll */
  (function () {
    const links = document.querySelectorAll(".rep-faq-nav__link");
    if (!links.length) return;
    const sections = Array.from(links).map(l => document.querySelector(l.getAttribute("href")));
    function update() {
      const threshold = 200;
      let idx = 0;
      sections.forEach((s, i) => {
        if (!s) return;
        const rect = s.getBoundingClientRect();
        if (rect.top <= threshold) idx = i;
      });
      links.forEach((l, i) => l.classList.toggle("active", i === idx));
    }
    window.addEventListener("scroll", update, { passive: true });
    update();
  })();
</script>
