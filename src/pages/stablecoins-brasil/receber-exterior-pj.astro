---
import Base from "@layouts/Base.astro";
import t    from "@i18n/en.json";
import "@styles/pages/receber-exterior-pj.css";

/*  Constantes editoriais  */
const locale        = "en-US";
const canonical     = "https://bitsark.com/stablecoins-brasil/receber-exterior-pj/";
const datePublished = "2026-05-16";
const dateModified  = "2026-05-16";

/* PTAX-venda hardcoded · atualizar editorialmente com dateModified */
const ptaxRef     = 5.10;
const ptaxRefDate = "2026-05-15";

/* IOF projetado · consulta pública (CP 99/2026), sem lei sancionada */
const iofProposed     = 0.035;   /* stablecoin Â· projetado */
const iofSwiftCurrent = 0.0038;  /* câmbio ingresso PJ atual */

/* Simulador · presets editoriais (em percentual; JS divide por 100) */
const fxPresets = {
  wire:    { charge: 2.5, fixed: 35 },
  fintech: { charge: 1.0, fixed: 0  },
};
const stablePresets = { spread: 0.1, fee: 1.0 };
const iofCambioPct       = 0.38;  /* IOF de câmbio (wire + fintech) */
const iofStableProposedPct = 3.5; /* IOF stablecoin (CP 99/2026) */

const rep = t.receber_exterior_pj;

const dateModifiedDisplay = new Date(dateModified + "T12:00:00Z")
  .toLocaleDateString(locale, { day: "numeric", month: "long", year: "numeric", timeZone: "UTC" });

const ptaxFormatted = new Intl.NumberFormat(locale, { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(ptaxRef);
const ptaxDateFormatted = new Date(ptaxRefDate + "T12:00:00Z").toLocaleDateString(locale, { timeZone: "UTC" });

const iofCambioFormatted = new Intl.NumberFormat(locale, { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(iofCambioPct) + "%";
const iofStableFormatted = new Intl.NumberFormat(locale, { minimumFractionDigits: 1, maximumFractionDigits: 1 }).format(iofStableProposedPct) + "%";

/*  Timeline regulatória com status dinâmico (build-time)  */
const now = new Date();
const timelineConfig = [
  { date: new Date("2022-12-21"), end: new Date("2023-12-11T23:59:59") },
  { date: new Date("2023-12-12"), end: new Date("2025-10-31T23:59:59") },
  { date: new Date("2025-11-01"), end: new Date("2025-12-31T23:59:59") },
  { date: new Date("2026-01-01"), end: new Date("2026-06-30T23:59:59") },
  { date: new Date("2026-07-01"), end: new Date("2026-12-31T23:59:59") },
  { date: new Date("2027-01-01"), end: new Date("2099-12-31T23:59:59") },
];
const processedTimeline = rep.regulacao.items.map((it, i) => {
  const cfg = timelineConfig[i];
  const status = now > cfg.end ? "past" : now >= cfg.date ? "active" : "future";
  return { ...it, status };
});

const alternates = [
  { hreflang: "en",        href: canonical },
  { hreflang: "pt-BR",     href: "https://bitsark.com/pt/stablecoins-brasil/receber-exterior-pj/" },
  { hreflang: "x-default", href: canonical }
];

/*  Schema.org @graph  */
const allFaqs = rep.faq.categories.flatMap(c => c.questions);

const schemaGraph = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": canonical,
      "url": canonical,
      "name": "Receive from Abroad as Brazil PJ",
      "description": rep.meta.description,
      "inLanguage": "en-US",
      "datePublished": datePublished,
      "dateModified": dateModified,
      "publisher": { "@id": "https://bitsark.com/#organization" },
      "about": [
        { "@type": "Legislation", "name": "Lei nº 14.478/2022",                 "alternateName": "Marco dos Ativos Virtuais", "legislationType": "Lei Ordinária Federal",   "jurisdiction": "Brasil", "dateEnacted": "2022-12-21" },
        { "@type": "Legislation", "name": "Lei nº 14.754/2023",                 "alternateName": "Lei das Offshores",         "legislationType": "Lei Ordinária Federal",   "jurisdiction": "Brasil", "dateEnacted": "2023-12-12" },
        { "@type": "Legislation", "name": "Instrução Normativa RFB nº 2.291/2025", "alternateName": "DeCripto",               "legislationType": "Instrução Normativa",     "jurisdiction": "Brasil", "dateEnacted": "2025-11-14" },
        { "@type": "Legislation", "name": "Resolução BCB nº 521/2025",          "legislationType": "Resolução BCB",                                                          "jurisdiction": "Brasil", "dateEnacted": "2025-11-01" },
        { "@type": "Legislation", "name": "Lei Complementar nº 116/2003",       "alternateName": "ISS sobre serviços",        "legislationType": "Lei Complementar",        "jurisdiction": "Brasil", "dateEnacted": "2003-07-31" },
      ],
      "audience": {
        "@type": "Audience",
        "audienceType": "Business owners in Brazil providing services abroad",
      },
      "breadcrumb": { "@id": `${canonical}#breadcrumb` },
      "mainEntity": [
        { "@id": `${canonical}#article` },
        { "@id": `${canonical}#howto` },
        { "@id": `${canonical}#faq` },
      ],
    },
    {
      "@type": "TechArticle",
      "@id": `${canonical}#article`,
      "headline": rep.meta.title,
      "description": rep.meta.description,
      "datePublished": datePublished,
      "dateModified": dateModified,
      "inLanguage": "en-US",
      "author":    { "@id": "https://bitsark.com/#organization" },
      "publisher": { "@id": "https://bitsark.com/#organization" },
      "image": "https://bitsark.com/og/receber-exterior-pj.png",
      "articleSection": "Crypto-PJ Taxation",
      "keywords": "receive USDT abroad Brazil, USDC service export, CNPJ stablecoin, Wise Business PJ, Husky fintech câmbio, Remessa Online PJ, international service provider Brazil, crypto export taxes, freelancer crypto Brazil, digital nomad CNPJ, DeCripto PJ",
      "mentions": [
        { "@type": "Organization", "name": "Wise Business",   "url": "https://wise.com/business" },
        { "@type": "Organization", "name": "Husky",           "url": "https://huskypay.com" },
        { "@type": "Organization", "name": "Remessa Online",  "url": "https://www.remessaonline.com.br" }
      ],
      "license": "https://bitsark.com/terms",
      "mainEntityOfPage": { "@id": canonical },
    },
    {
      "@type": "BreadcrumbList",
      "@id": `${canonical}#breadcrumb`,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home",                        "item": "https://bitsark.com/" },
        { "@type": "ListItem", "position": 2, "name": "Stablecoins in Brazil",       "item": "https://bitsark.com/stablecoins-brasil/" },
        { "@type": "ListItem", "position": 3, "name": "Receive from abroad as PJ",   "item": canonical },
      ],
    },
    {
      "@type": "HowTo",
      "@id": `${canonical}#howto`,
      "name": rep.comoReceber.title,
      "description": rep.comoReceber.howToDescription,
      "totalTime": rep.comoReceber.totalTime,
      "inLanguage": "en-US",
      "tool": rep.comoReceber.tools.map(toolName => ({ "@type": "HowToTool", "name": toolName })),
      "step": rep.comoReceber.steps.map((s, i) => ({
        "@type": "HowToStep",
        "position": i + 1,
        "name": s.title,
        "text": s.text,
        "url": `${canonical}#step-${i + 1}`,
      })),
    },
    {
      "@type": "FAQPage",
      "@id": `${canonical}#faq`,
      "mainEntity": allFaqs.map(q => ({
        "@type": "Question",
        "name": q.q,
        "acceptedAnswer": { "@type": "Answer", "text": q.a.replace(/<[^>]+>/g, "") },
      })),
    },
  ],
};

/*  Icons (inline SVG)  */
const icons = { // This object is already defined in the original file, no change needed here.
  shield:    '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>',
  building:  '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="4" y="2" width="16" height="20" rx="2"/><path d="M9 22v-4h6v4"/><path d="M8 6h.01M16 6h.01M8 10h.01M16 10h.01M8 14h.01M16 14h.01"/></svg>',
  receipt:   '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 2v20l3-2 3 2 3-2 3 2 3-2V2H4z"/><path d="M8 7h8M8 11h8M8 15h5"/></svg>',
  calendar:  '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>',
  info:      '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>',
  coins:     '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="8" cy="8" r="6"/><path d="M18.09 10.37A6 6 0 1 1 10.34 18.06"/><path d="M7 6h1v4"/><path d="M17 12h1v4"/></svg>',
  "file-text":'<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>',
  globe:     '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>',
  bolt:      '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>',
  coin:      '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M14.5 9a2.5 2.5 0 0 0-5 0c0 1.4 1 2.2 2.5 2.5s2.5 1.1 2.5 2.5a2.5 2.5 0 0 1-5 0"/><path d="M12 7v10"/></svg>',
  clock:     '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>',
  warning:   '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>',
  check:     '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>',
  arrow:     '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>',
};

/* helper para resolver ícone do TLDR */
const tldrIcon = (name) => icons[name] || icons.info;

/* Status labels para timeline */
const timelineStatusLabel = { past: "Completed", active: "In force", future: "Upcoming" };
---

<Base
  title={rep.meta.title}
  description={rep.meta.description}
  lang="en"
  canonical={canonical}
  ogType="article"
  alternates={alternates}
  ogImage="https://bitsark.com/og/receber-exterior-pj.png"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(schemaGraph)} />

  <!-- ═══════════════════════════════════════════════════════════
       HERO
  ══════════════════════════════════════════════════════════════ -->
  <section class="rep-hero" aria-labelledby="page-heading" id="top">
    <div class="rep-hero__atmos" aria-hidden="true">
      <div class="rep-hero__halo"></div>
      <div class="rep-hero__grid"></div>
      <div class="rep-hero__noise"></div>
    </div>

    <div class="container rep-hero__body">

      <nav class="rep-breadcrumb" aria-label="Breadcrumb">
        <a href="/">{rep.hero.breadcrumbHome}</a>
        <span aria-hidden="true">›</span>
        <a href="/stablecoins-brasil/">{rep.hero.breadcrumbHub}</a>
        <span aria-hidden="true">›</span>
        <span aria-current="page">{rep.hero.breadcrumbCurrent}</span>
      </nav>

      <div class="rep-hero__topbar fade-up">
        <div class="rep-urgency-pill" role="status">
          <span class="rep-urgency-pill__dot" aria-hidden="true"></span>
          <span>{rep.hero.urgencyPill}</span>
        </div>
        <p class="rep-hero__meta">
          <time datetime={dateModified}>
            {rep.meta.lastReviewedLabel}: {dateModifiedDisplay}
          </time>
          <span class="rep-hero__meta-sep" aria-hidden="true">·</span>
          <span class="rep-hero__meta-disc">{rep.meta.disclaimerNotLegal}</span>
        </p>
      </div>

      <h1 id="page-heading" class="rep-hero__title" set:html={rep.hero.title} />

      <p class="rep-hero__sub">{rep.hero.sub}</p>

      <div class="rep-hero__chips fade-up" style="animation-delay:.24s">
        {rep.hero.chips.map(chip => (
          <span class="rep-chip">{chip}</span>
        ))}
      </div>

      <div class="rep-hero__floats" aria-label="Key indicators">
        {rep.hero.kpis.map((k, i) => (
          <div class="rep-hfloat" style={`--rep-stagger:${i}`}>
            <span class="rep-hfloat__label">{k.label}</span>
            <span class="rep-hfloat__value">{k.value}</span>
            <span class="rep-hfloat__meta">{k.meta}</span>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       TL;DR
  ══════════════════════════════════════════════════════════════ -->
  <section class="rep-section rep-section--alt" id="tldr" aria-labelledby="tldr-heading">
    <div class="container">
      <header class="rep-section-head">
        <p class="eyebrow eyebrow--icon">{rep.tldr.eyebrow}</p>
        <h2 id="tldr-heading" class="rep-section-title">{rep.tldr.title}</h2>
        <p class="rep-section-sub">{rep.tldr.sub}</p>
      </header>

      <div class="rep-tldr-grid">
        {rep.tldr.items.map((item, i) => (
          <article class="rep-tldr-card" style={`--rep-stagger:${i}`}>
            <div class="rep-tldr-icon" aria-hidden="true" set:html={tldrIcon(item.icon)} />
            <h3 class="rep-tldr-q">{item.q}</h3>
            <p class="rep-tldr-a" set:html={item.a} />
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       POR QUE STABLECOIN
  ══════════════════════════════════════════════════════════════ -->
  <section class="rep-section" id="why-stablecoin" aria-labelledby="porque-heading">
    <div class="container">
      <header class="rep-section-head">
        <p class="eyebrow eyebrow--icon">{rep.porQue.eyebrow}</p>
        <h2 id="porque-heading" class="rep-section-title">{rep.porQue.title}</h2>
        <p class="rep-section-sub">{rep.porQue.sub}</p>
      </header>

      <div class="rep-porque-grid">
        {rep.porQue.cards.map((card, i) => (
          <article class="rep-porque-card" style={`--rep-stagger:${i}`}>
            <div class="rep-porque-icon" aria-hidden="true" set:html={i === 0 ? icons.bolt : i === 1 ? icons.coin : icons.clock} />
            <div class="rep-porque-stat">
              <span class="rep-porque-stat__value">{card.stat}</span>
              <span class="rep-porque-stat__label">{card.statLabel}</span>
            </div>
            <h3 class="rep-porque-title">{card.title}</h3>
            <p class="rep-porque-desc">{card.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       COMO RECEBER (HowTo)
  ══════════════════════════════════════════════════════════════ -->
  <section class="rep-section rep-section--alt" id="how-to" aria-labelledby="howto-heading">
    <div class="container">
      <header class="rep-section-head">
        <p class="eyebrow eyebrow--icon">{rep.comoReceber.eyebrow}</p>
        <h2 id="howto-heading" class="rep-section-title">{rep.comoReceber.title}</h2>
        <p class="rep-section-sub">{rep.comoReceber.sub}</p>
      </header>

      <ol class="rep-howto-list" aria-label="Steps to receive USDT/USDC as a Brazilian PJ">
        {rep.comoReceber.steps.map((step, i) => (
          <li class="rep-howto-step" id={`step-${i + 1}`} style={`--rep-stagger:${i}`}>
            <div class="rep-howto-step__num" aria-hidden="true">{String(i + 1).padStart(2, "0")}</div>
            <div class="rep-howto-step__body">
              <h3 class="rep-howto-step__title">{step.title}</h3>
              <p class="rep-howto-step__text">{step.text}</p>
              {step.note && (
                <p class="rep-howto-step__note">
                  <span class="rep-howto-step__note-icon" aria-hidden="true" set:html={icons.info} />
                  <span>{step.note}</span>
                </p>
              )}
              {step.link && (
                <a class="rep-howto-step__link" href={step.link.href}>
                  {step.link.label}
                </a>
              )}
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       COMPARATIVO SWIFT × STABLECOIN
  ══════════════════════════════════════════════════════════════ -->
  <section class="rep-section" id="comparison" aria-labelledby="comparison-heading">
    <div class="container">
      <header class="rep-section-head">
        <p class="eyebrow eyebrow--icon">{rep.comparativo.eyebrow}</p>
        <h2 id="comparativo-heading" class="rep-section-title">{rep.comparativo.title}</h2>
        <p class="rep-section-sub">{rep.comparativo.sub}</p>
      </header>

      <div class="rep-compare-wrap">
        <table class="rep-compare-table data-table premium-table">
          <caption class="sr-only">Comparison between receiving via bank SWIFT wire and via USDT/USDC stablecoin</caption>
          <thead>
            <tr>
              {rep.comparativo.headers.map((h, i) => (
                <th scope="col" class={i === 2 ? "rep-compare-table__highlight" : ""}>{h}</th>
              ))}
            </tr>
          </thead>
          <tbody>
            {rep.comparativo.rows.map(row => (
              <tr>
                <th scope="row">{row[0]}</th>
                <td>{row[1]}</td>
                <td class="rep-compare-table__highlight">{row[2]}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       SIMULADOR SWIFT × STABLECOIN
  ══════════════════════════════════════════════════════════════ -->
  <section class="rep-section rep-section--alt" id="simulator" aria-labelledby="sim-heading">
    <div class="container">
      <header class="rep-section-head">
        <p class="eyebrow eyebrow--icon">{rep.simulador.eyebrow}</p>
        <h2 id="sim-heading" class="rep-section-title">{rep.simulador.title}</h2>
        <p class="rep-section-sub">{rep.simulador.sub}</p>
      </header>

      <div
        class="rep-sim"
        id="rep-sim"
        data-locale={locale}
        data-ptax={ptaxRef}
        data-fx-mode="wire"
        data-wire-charge={fxPresets.wire.charge}
        data-wire-fixed={fxPresets.wire.fixed}
        data-fintech-charge={fxPresets.fintech.charge}
        data-fintech-fixed={fxPresets.fintech.fixed}
        data-stable-spread={stablePresets.spread}
        data-stable-fee={stablePresets.fee}
        data-iof-cambio={iofCambioPct}
        data-iof-stable-proposed={iofStableProposedPct}
      >
        <div class="rep-sim__top">
          <div class="rep-sim__input-wrap">
            <label for="rep-sim-input" class="rep-sim__input-label">{rep.simulador.inputLabel}</label>
            <div class="rep-sim__input-field">
              <span class="rep-sim__input-currency" aria-hidden="true">$</span>
              <input
                type="number"
                inputmode="decimal"
                id="rep-sim-input"
                class="rep-sim__input"
                value="5000"
                min="100"
                max="10000000"
                step="100"
              />
              <span class="rep-sim__input-unit" aria-hidden="true">{rep.simulador.inputUnit}</span>
            </div>

            <div class="rep-sim__presets" role="group" aria-label={rep.simulador.presetsLabel}>
              {rep.simulador.presets.map(p => (
                <button type="button" class="rep-sim__preset" data-preset={p}>
                  ${new Intl.NumberFormat(locale).format(p)}
                </button>
              ))}
            </div>
          </div>

          <div class="rep-sim__ptax-col">
            <div class="rep-sim__ptax-row">
              <label for="rep-sim-ptax-input" class="rep-sim__ptax-label">
                {rep.simulador.ptaxLabel}
              </label>
              <div class="rep-sim__ptax-field" id="rep-sim-ptax-field">
                <span class="rep-sim__ptax-prefix" aria-hidden="true">R$</span>
                <input
                  type="number"
                  id="rep-sim-ptax-input"
                  class="rep-sim__ptax-input"
                  value={ptaxRef}
