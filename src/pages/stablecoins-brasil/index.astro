---
import Base from "@layouts/Base.astro";
import t from "@i18n/en.json";
import "@styles/pages/stablecoins.css";

/* ─── Data loading ────────────────────────────────────────────────── */
let marketData = { latestMarketCapUsd: 0, yoyGrowthPct: 0, monthly: [], updatedAt: null };
let brazilData = { latestAccumulatedUsd: 0, latestMonth: null, monthly: [], isFallback: false };

try {
  const mRaw = await import("../../../public/data/stablecoin-market.json");
  const bRaw = await import("../../../public/data/stablecoin-brazil.json");
  marketData = mRaw.default ?? mRaw;
  brazilData = bRaw.default ?? bRaw;
} catch (e) {
  console.warn("[stablecoins-brasil] Could not load data JSONs:", e.message);
}

/* ─── Helpers ─────────────────────────────────────────────────────── */
function fmtBillion(n) {
  if (!n) return "-";
  if (n >= 1e12) return `$${(n / 1e12).toFixed(1)}T`;
  if (n >= 1e9)  return `$${(n / 1e9).toFixed(0)}B`;
  if (n >= 1e6)  return `$${(n / 1e6).toFixed(0)}M`;
  return `$${n.toLocaleString("en-US")}`;
}

const marketCap     = fmtBillion(marketData.latestMarketCapUsd);
const brazilAccum   = fmtBillion(brazilData.latestAccumulatedUsd);
const yoy           = marketData.yoyGrowthPct ? `+${marketData.yoyGrowthPct}%` : "-";

const locale = "en-US";
const dataUpdatedAt = marketData.updatedAt
  ? new Date(marketData.updatedAt).toLocaleDateString(locale, { month: "long", year: "numeric" })
  : "-";

/* Brazil flow-to-cap ratio: cumulative BR inflow ÷ current global market cap.
   This is a flow-vs-stock proxy of adoption intensity, NOT a share of holdings.
   Methodological caveats are spelled out in the insightNote copy. */
const brazilFlowToGlobalCapPct =
  marketData.latestMarketCapUsd && brazilData.latestAccumulatedUsd
    ? Math.round((brazilData.latestAccumulatedUsd / marketData.latestMarketCapUsd) * 100)
    : 19;

/* ── Static breakdown (USDT vs USDC vs other) - Brazil volume share ── */
const usdtShare  = 70;
const usdcShare  = 25;
const otherShare = 5;

/* ── Hero KPI deltas / small visual cues ────────────────────────────── */
const heroKpis = [
  { value: marketCap,                                label: t.stablecoins_page.hero.kpiGlobalCap,     meta: t.stablecoins_page.hero.kpiGlobalCapMeta,     accent: false, delta: yoy, deltaTone: "positive" },
  { value: yoy,                                      label: t.stablecoins_page.hero.kpiGrowth,        meta: t.stablecoins_page.hero.kpiGrowthMeta,        accent: false, deltaTone: "positive", noDelta: true },
  { value: brazilAccum,                              label: t.stablecoins_page.hero.kpiBrazilInflow,  meta: t.stablecoins_page.hero.kpiBrazilInflowMeta,  accent: true,  delta: `≈${brazilFlowToGlobalCapPct}% ${t.stablecoins_page.data.shareLabel}`, deltaTone: "accent" },
  { value: `≈${brazilFlowToGlobalCapPct}%`,          label: t.stablecoins_page.hero.kpiBrazilShare,   meta: t.stablecoins_page.hero.kpiBrazilShareMeta,   accent: false, noDelta: true },
];

/* Serialise chart data for the client script */
const chartMarket = JSON.stringify(marketData.monthly ?? []);
const chartBrazil = JSON.stringify(brazilData.monthly ?? []);

/* ─── Schema.org ──────────────────────────────────────────────────── */
const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "headline": t.stablecoins_page.meta.title,
  "description": t.stablecoins_page.meta.description,
  "publisher": { "@type": "Organization", "name": "bitsARK Labs", "url": "https://bitsark.com" },
  "author": { "@type": "Organization", "name": "bitsARK Labs" },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://www.bitsark.com/stablecoins-brasil",
  },
  "url": "https://www.bitsark.com/stablecoins-brasil",
  "dateModified": marketData.updatedAt ?? new Date().toISOString(),
  "about": [
    { "@type": "Thing", "name": "Stablecoins" },
    { "@type": "Thing", "name": "Criptomoedas no Brasil" },
    { "@type": "Thing", "name": "USDT" },
    { "@type": "Thing", "name": "USDC" },
    { "@type": "Thing", "name": "Regulação Banco Central Brasil" },
  ],
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": t.stablecoins_page.hero.breadcrumbHome,    "item": "https://bitsark.com/" },
    { "@type": "ListItem", "position": 2, "name": t.stablecoins_page.hero.breadcrumbCurrent, "item": "https://bitsark.com/stablecoins-brasil" },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": t.stablecoins_page.faq.items.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a.replace(/<[^>]+>/g, "") }
  }))
};

const alternates = [
  { hreflang: "en",        href: "https://bitsark.com/stablecoins-brasil/" },
  { hreflang: "pt-BR",     href: "https://bitsark.com/pt/stablecoins-brasil/" },
  { hreflang: "x-default", href: "https://bitsark.com/stablecoins-brasil/" }
];
---

<Base
  title={t.stablecoins_page.meta.title}
  description={t.stablecoins_page.meta.description}
  lang="en"
  canonical="https://bitsark.com/stablecoins-brasil/"
  alternates={alternates}
  ogType="website"
  ogImage="https://bitsark.com/og/stablecoins-brasil.png"
  schema={schema}
>

  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- ═══════════════════════════════════════════════════════════
       HERO - editorial brief
  ══════════════════════════════════════════════════════════════ -->
  <section class="sb-hero">
    <div class="sb-hero-glow" aria-hidden="true"></div>
    <div class="sb-hero-grid-bg" aria-hidden="true"></div>
    <div class="sb-container">

      <nav class="sb-breadcrumb" aria-label="Breadcrumb">
        <a href="/">{t.stablecoins_page.hero.breadcrumbHome}</a>
        <span aria-hidden="true">›</span>
        <span aria-current="page">{t.stablecoins_page.hero.breadcrumbCurrent}</span>
      </nav>

      <div class="sb-hero-tags">
        <div class="sb-live-badge">
          <span class="status-dot" aria-hidden="true"></span>
          {t.stablecoins_page.hero.liveBadge} {dataUpdatedAt}
        </div>
        <div class="sb-rank-pill">
          <span class="sb-rank-pill-hash" aria-hidden="true">#</span>
          {t.stablecoins_page.hero.rankTag}
        </div>
      </div>

      <h1 class="sb-hero-title" set:html={t.stablecoins_page.hero.title} />

      <p class="sb-hero-sub">
        {t.stablecoins_page.hero.subtitle}
      </p>

      <!-- KPI row -->
      <div class="sb-kpi-row" aria-label="Key market figures">
        {heroKpis.map((k, i) => (
          <div class:list={["sb-kpi", k.accent && "sb-kpi--accent"]} style={`--sb-kpi-i:${i}`}>
            <span class="sb-kpi-meta">{k.meta}</span>
            <span class="sb-kpi-value">{k.value}</span>
            <span class="sb-kpi-label">{k.label}</span>
            {!k.noDelta && k.delta && (
              <span class:list={["sb-kpi-delta", `sb-kpi-delta--${k.deltaTone || "muted"}`]}>
                {k.delta}
              </span>
            )}
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       TL;DR - quick answers (AI overview / featured snippet bait)
  ══════════════════════════════════════════════════════════════ -->
  <section class="sb-section sb-section--alt sb-section--tight" id="tldr">
    <div class="sb-container">
      <div class="sb-tldr-head">
        <p class="eyebrow">{t.stablecoins_page.tldr.eyebrow}</p>
        <h2 class="sb-section-title">{t.stablecoins_page.tldr.title}</h2>
        <p class="sb-section-sub">{t.stablecoins_page.tldr.sub}</p>
      </div>

      <div class="sb-tldr-grid">
        {t.stablecoins_page.tldr.items.map((item, i) => (
          <div class="sb-tldr-card" style={`--sb-stagger:${i}`}>
            <div class="sb-tldr-icon" aria-hidden="true">
              {item.icon === "shield" && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                  <path d="m9 12 2 2 4-4"/>
                </svg>
              )}
              {item.icon === "pix" && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12 12 5l7 7-7 7z"/>
                  <path d="m9 12 3-3 3 3-3 3z"/>
                </svg>
              )}
              {item.icon === "receipt" && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4 2v20l3-2 3 2 3-2 3 2 3-2V2H4z"/>
                  <path d="M8 7h8M8 11h8M8 15h5"/>
                </svg>
              )}
              {item.icon === "chart" && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M3 3v18h18"/>
                  <path d="m7 14 4-4 4 3 5-6"/>
                </svg>
              )}
            </div>
            <h3 class="sb-tldr-q">{item.q}</h3>
            <p class="sb-tldr-a" set:html={item.a} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       THE BASICS
  ══════════════════════════════════════════════════════════════ -->
  <section class="sb-section" id="basics">
    <div class="sb-container sb-narrow">
      <p class="eyebrow">{t.stablecoins_page.basics.eyebrow}</p>
      <h2 class="sb-section-title">{t.stablecoins_page.basics.title}</h2>
      <p>{t.stablecoins_page.basics.p1}</p>
      <p set:html={t.stablecoins_page.basics.p2} />

      <div class="sb-analogy-card">
        <div class="sb-analogy-icon" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2a7 7 0 0 1 5 11.95V17a1 1 0 0 1-1 1H8a1 1 0 0 1-1-1v-3.05A7 7 0 0 1 12 2Z"/>
            <path d="M9 21h6M10 17v1M14 17v1"/>
          </svg>
        </div>
        <p set:html={t.stablecoins_page.basics.analogy} />
      </div>

      <!-- Flow -->
      <div class="sb-flow" role="img" aria-label={t.stablecoins_page.basics.flow.aria}>
        <div class="sb-flow-node" style="--flow-step: 0;">
          <div class="sb-flow-circle">R$</div>
          <p set:html={t.stablecoins_page.basics.flow.step1} />
        </div>
        <div class="sb-flow-connector" style="--flow-step: 0;" aria-hidden="true"></div>
        <div class="sb-flow-node" style="--flow-step: 1;">
          <div class="sb-flow-circle">⇄</div>
          <p set:html={t.stablecoins_page.basics.flow.step2} />
        </div>
        <div class="sb-flow-connector" style="--flow-step: 1;" aria-hidden="true"></div>
        <div class="sb-flow-node sb-flow-node--accent" style="--flow-step: 2;">
          <div class="sb-flow-circle">$</div>
          <p set:html={t.stablecoins_page.basics.flow.step3} />
        </div>
        <div class="sb-flow-connector" style="--flow-step: 2;" aria-hidden="true"></div>
        <div class="sb-flow-node" style="--flow-step: 3;">
          <div class="sb-flow-circle">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/>
              <path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
            </svg>
          </div>
          <p set:html={t.stablecoins_page.basics.flow.step4} />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       MARKET DATA - CHARTS
  ══════════════════════════════════════════════════════════════ -->
  <section class="sb-section sb-section--alt" id="data">
    <div class="sb-container">
      <p class="eyebrow">{t.stablecoins_page.data.eyebrow}</p>
      <h2 class="sb-section-title">{t.stablecoins_page.data.title}</h2>
      <p class="sb-section-sub">{t.stablecoins_page.data.sub}</p>

      <div class="sb-charts-grid">

        <!-- Chart 1: Global market cap -->
        <div class="sb-chart-card">
          <div class="sb-chart-header">
            <div>
              <h3>{t.stablecoins_page.data.globalTitle}</h3>
              <span class="sb-chart-badge">{t.stablecoins_page.data.globalBadge}</span>
            </div>
            <div class="sb-chart-figure">
              <span class="sb-chart-figure-value">{marketCap}</span>
              <span class="sb-chart-figure-delta sb-chart-figure-delta--positive">{yoy} YoY</span>
            </div>
          </div>
          <div class="sb-chart-wrap" id="wrap-global">
            <canvas id="chart-global" aria-label={t.stablecoins_page.data.globalTitle} aria-describedby="table-global-data"></canvas>
            <table id="table-global-data" class="sr-only">
              <caption>{t.stablecoins_page.data.globalTitle}</caption>
              <thead>
                <tr>
                  <th>Month</th>
                  <th>Market Cap (USD)</th>
                </tr>
              </thead>
              <tbody>
                {marketData.monthly.map((d) => (
                  <tr>
                    <td>{d.month}</td>
                    <td>{d.marketCapUsd}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <p class="sb-chart-source">
            Source: <a href="https://defillama.com/stablecoins" target="_blank" rel="noopener noreferrer">DefiLlama</a>
            &mdash; updated {dataUpdatedAt}
          </p>
        </div>

        <!-- Chart 2: Brazil cumulative -->
        <div class="sb-chart-card sb-chart-card--accent">
          <div class="sb-chart-header">
            <div>
              <h3>{t.stablecoins_page.data.brazilTitle}</h3>
              <span class="sb-chart-badge" set:html={t.stablecoins_page.data.brazilBadge} />
            </div>
            <div class="sb-chart-figure">
              <span class="sb-chart-figure-value sb-chart-figure-value--accent">{brazilAccum}</span>
              <span class="sb-chart-figure-delta sb-chart-figure-delta--accent">≈{brazilFlowToGlobalCapPct}% {t.stablecoins_page.data.shareLabel}</span>
            </div>
          </div>
          <div class="sb-chart-wrap" id="wrap-brazil">
            <canvas id="chart-brazil" aria-label={t.stablecoins_page.data.brazilTitle} aria-describedby="table-brazil-data"></canvas>
            <table id="table-brazil-data" class="sr-only">
              <caption>{t.stablecoins_page.data.brazilTitle}</caption>
              <thead>
                <tr>
                  <th>Month</th>
                  <th>Accumulated Inflow (USD)</th>
                </tr>
              </thead>
              <tbody>
                {brazilData.monthly.map((d) => (
                  <tr>
                    <td>{d.month}</td>
                    <td>{d.accumulatedUsd}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <p class="sb-chart-source">
            Source: <a href="https://www.bcb.gov.br" target="_blank" rel="noopener noreferrer">Banco Central do Brasil</a>
            &mdash; {t.stablecoins_page.data.bcbSource}
            {brazilData.isFallback && <span class="sb-chart-fallback"> {t.stablecoins_page.data.fallbackNote}</span>}
          </p>
        </div>
      </div>

      <!-- Insight callout - data-driven -->
      <div class="sb-insight-callout">
        <div class="sb-insight-stat">~1 in {Math.round(100 / brazilFlowToGlobalCapPct)}</div>
        <div class="sb-insight-body">
          <p>{t.stablecoins_page.data.insightStat}</p>
          <p set:html={t.stablecoins_page.data.insightP1.replace("{accum}", brazilAccum).replace("{share}", brazilFlowToGlobalCapPct.toString())} />
          <p class="sb-insight-caveat" set:html={t.stablecoins_page.data.insightNote} />
          <a href="https://x.com/fernandoulrich" target="_blank" rel="noopener noreferrer" class="sb-link">
            {t.stablecoins_page.data.insightLink}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       BRAZIL IN THE WORLD - ranking league table
  ══════════════════════════════════════════════════════════════ -->
  <section class="sb-section" id="ranking">
    <div class="sb-container">
      <p class="eyebrow">{t.stablecoins_page.ranking.eyebrow}</p>
      <h2 class="sb-section-title">{t.stablecoins_page.ranking.title}</h2>
      <p class="sb-section-sub">{t.stablecoins_page.ranking.sub}</p>

      <div class="sb-rank-table" role="table" aria-label="Country adoption ranking">
        <div class="sb-rank-row sb-rank-row--head" role="row">
          <div class="sb-rank-cell sb-rank-cell--rank">{t.stablecoins_page.ranking.rank}</div>
          <div class="sb-rank-cell sb-rank-cell--country">{t.stablecoins_page.ranking.colCountry}</div>
          <div class="sb-rank-cell sb-rank-cell--note">{t.stablecoins_page.ranking.colNote}</div>
          <div class="sb-rank-cell sb-rank-cell--bar">{t.stablecoins_page.ranking.colVolume}</div>
          <div class="sb-rank-cell sb-rank-cell--loss">{t.stablecoins_page.ranking.colInflation}</div>
        </div>
        {t.stablecoins_page.ranking.countries.map((c, i) => (
          <div class:list={["sb-rank-row", c.code === "BRA" && "sb-rank-row--highlight"]} style={`--sb-stagger:${i}`} role="row">
            <div class="sb-rank-cell sb-rank-cell--rank">
              <span class="sb-rank-num">{String(i + 1).padStart(2, "0")}</span>
            </div>
            <div class="sb-rank-cell sb-rank-cell--country">
              <span class="sb-rank-code">{c.code}</span>
              <span class="sb-rank-name">{c.name}</span>
            </div>
            <div class="sb-rank-cell sb-rank-cell--note">{c.note}</div>
            <div class="sb-rank-cell sb-rank-cell--bar">
              <div class="sb-rank-bar-wrap" aria-hidden="true">
                <div class="sb-rank-bar-fill" style={`--sb-rank-w:${c.intensity}%`}></div>
              </div>
              <span class="sb-rank-bar-val">{c.intensity}</span>
            </div>
            <div class="sb-rank-cell sb-rank-cell--loss">{c.loss}</div>
          </div>
        ))}
      </div>

      <div class="sb-rank-meta">
        <p set:html={t.stablecoins_page.ranking.note} />
        <p class="sb-rank-source">{t.stablecoins_page.ranking.source}</p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       USDT vs USDC - breakdown
  ══════════════════════════════════════════════════════════════ -->
  <section class="sb-section sb-section--alt" id="breakdown">
    <div class="sb-container sb-narrow-md">
      <p class="eyebrow">{t.stablecoins_page.breakdown.eyebrow}</p>
      <h2 class="sb-section-title">{t.stablecoins_page.breakdown.title}</h2>
      <p class="sb-section-sub">{t.stablecoins_page.breakdown.sub}</p>

      <div class="sb-breakdown">
        <div class="sb-breakdown-bar" aria-hidden="true">
          <div class="sb-breakdown-seg sb-breakdown-seg--usdt" style={`--w:${usdtShare}%`}>
            <span>{usdtShare}%</span>
          </div>
          <div class="sb-breakdown-seg sb-breakdown-seg--usdc" style={`--w:${usdcShare}%`}>
            <span>{usdcShare}%</span>
          </div>
          <div class="sb-breakdown-seg sb-breakdown-seg--other" style={`--w:${otherShare}%`}>
            <span>{otherShare}%</span>
          </div>
        </div>

        <div class="sb-breakdown-legend">
          <div class="sb-breakdown-item">
            <span class="sb-breakdown-dot sb-breakdown-dot--usdt" aria-hidden="true"></span>
            <div>
              <strong>{t.stablecoins_page.breakdown.usdtLabel}</strong>
              <p>{t.stablecoins_page.breakdown.usdtNote}</p>
            </div>
          </div>
          <div class="sb-breakdown-item">
            <span class="sb-breakdown-dot sb-breakdown-dot--usdc" aria-hidden="true"></span>
            <div>
              <strong>{t.stablecoins_page.breakdown.usdcLabel}</strong>
              <p>{t.stablecoins_page.breakdown.usdcNote}</p>
            </div>
          </div>
          <div class="sb-breakdown-item">
            <span class="sb-breakdown-dot sb-breakdown-dot--other" aria-hidden="true"></span>
            <div>
              <strong>{t.stablecoins_page.breakdown.otherLabel}</strong>
              <p>{t.stablecoins_page.breakdown.otherNote}</p>
            </div>
          </div>
        </div>

        <p class="sb-breakdown-note">{t.stablecoins_page.breakdown.note}</p>
      </div>

      <!-- USDT vs USDC comparison table -->
      <div class="sb-compare">
        <h3 class="sb-compare-title">{t.stablecoins_page.breakdown.compareTitle}</h3>
        <div class="sb-compare-grid" role="table" aria-label="USDT vs USDC comparison">
          <div class="sb-compare-row sb-compare-row--head" role="row">
            <span></span>
            <span class="sb-compare-h sb-compare-h--usdt">USDT</span>
            <span class="sb-compare-h sb-compare-h--usdc">USDC</span>
          </div>
          {t.stablecoins_page.breakdown.compareRows.map((row, i) => (
            <div class="sb-compare-row" style={`--sb-stagger:${i}`} role="row">
              <span class="sb-compare-label">{row.label}</span>
              <span>{row.usdt}</span>
              <span>{row.usdc}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       WHY BRAZILIANS USE STABLECOINS - with stats
  ══════════════════════════════════════════════════════════════ -->
  <section class="sb-section" id="why">
    <div class="sb-container">
      <p class="eyebrow">{t.stablecoins_page.why.eyebrow}</p>
      <h2 class="sb-section-title">{t.stablecoins_page.why.title}</h2>

      <div class="sb-use-cases">
        {t.stablecoins_page.why.cards.map((card, i) => {
          const icons = [
            // 0 - protection (shield + dollar arrow up)
            `<polyline points="22 17 13.5 8.5 8.5 13.5 2 7"/><polyline points="16 17 22 17 22 11"/>`,
            // 1 - cross-border (globe)
            `<circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>`,
            // 2 - vault (lock)
            `<rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>`,
            // 3 - spread (zap)
            `<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>`,
          ];
          return (
            <div class="sb-use-card" style={`--sb-stagger:${i}`}>
              <div class="sb-use-card-head">
                <span class="sb-use-icon" aria-hidden="true">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
                       stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"
                       set:html={icons[i]} />
                </span>
                {card.stat && (
                  <div class="sb-use-stat">
                    <span class="sb-use-stat-val">{card.stat}</span>
                    <span class="sb-use-stat-label">{card.statLabel}</span>
                  </div>
                )}
              </div>
              <h3>{card.title}</h3>
              <p>{card.desc}</p>
              {card.link && <a href="/dolarmap" class="sb-use-link">{card.link}</a>}
            </div>
          );
        })}
      </div>
    </div>
  </section>

