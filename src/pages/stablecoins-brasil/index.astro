  <script>
    import Chart from "chart.js/auto";

    function initStablecoinCharts() {
      const chartMarket = document.getElementById("sb-chart-data-market")?.textContent ?? "[]";
      const chartBrazil = document.getElementById("sb-chart-data-brazil")?.textContent ?? "[]";
      const style = getComputedStyle(document.documentElement);

      const C = {
        primary:     style.getPropertyValue('--color-primary').trim(),
        primaryFill: style.getPropertyValue('--color-primary-highlight').trim(),
        success:     style.getPropertyValue('--color-success').trim(),
        successFill: style.getPropertyValue('--color-success-highlight').trim(),
        grid:        style.getPropertyValue('--color-border').trim(),
        ticks:       style.getPropertyValue('--color-text-faint').trim(),
        tooltipBg:   style.getPropertyValue('--color-surface').trim(),
        tooltipBdr:  style.getPropertyValue('--color-border').trim(),
        tooltipTitle:style.getPropertyValue('--color-text').trim(),
        tooltipBody: style.getPropertyValue('--color-text-muted').trim(),
      };

      const baseOptions = {
        responsive: true,
        maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false },
        plugins: {
          legend: { display: false },
          tooltip: {
            backgroundColor: C.tooltipBg,
            borderColor: C.tooltipBdr,
            borderWidth: 1,
            titleColor: C.tooltipTitle,
            bodyColor: C.tooltipBody,
            padding: 12,
            cornerRadius: 6,
            titleFont: { family: 'Geist Mono, monospace', size: 11, weight: '500' },
            bodyFont:  { family: 'Geist Mono, monospace', size: 12 },
          },
        },
        scales: {
          x: {
            grid: { color: C.grid, drawTicks: false },
            ticks: { color: C.ticks, maxRotation: 0, autoSkip: true, maxTicksLimit: 6, font: { family: 'Geist Mono, monospace', size: 10 }, padding: 8 },
            border: { color: C.grid },
          },
          y: {
            grid: { color: C.grid, drawTicks: false },
            ticks: { color: C.ticks, font: { family: 'Geist Mono, monospace', size: 10 }, padding: 8 },
            border: { color: C.grid },
          },
        },
        animation: { duration: 800, easing: "easeOutQuart" },
      };

      function markLoaded(canvasId) {
        const wrap = document.getElementById(canvasId)?.closest(".sb-chart-wrap");
        if (wrap) wrap.classList.add("is-loaded");
      }

      /* Global market cap */
      const mData   = JSON.parse(chartMarket);
      const mLabels = mData.map(d => d.month.slice(0, 7));
      const mValues = mData.map(d => +(d.marketCapUsd / 1e9).toFixed(1));

      new Chart(document.getElementById("chart-global"), {
        type: "line",
        data: {
          labels: mLabels,
          datasets: [{
            data: mValues,
            borderColor: C.primary,
            backgroundColor: ctx => {
              const chart = ctx.chart;
              const { ctx: cctx, chartArea } = chart;
              if (!chartArea) return C.primaryFill;
              const g = cctx.createLinearGradient(0, chartArea.top, 0, chartArea.bottom);
              g.addColorStop(0, 'rgba(79, 152, 163, 0.25)');
              g.addColorStop(1, 'rgba(79, 152, 163, 0.0)');
              return g;
            },
            fill: true,
            tension: 0.4,
            pointRadius: 0,
            pointHitRadius: 14,
            borderWidth: 2,
          }],
        },
        options: {
          ...baseOptions,
          plugins: {
            ...baseOptions.plugins,
            tooltip: {
              ...baseOptions.plugins.tooltip,
              callbacks: { label: ctx => ` $${ctx.parsed.y}B market cap` },
            },
          },
          scales: {
            ...baseOptions.scales,
            y: {
              ...baseOptions.scales.y,
              ticks: { ...baseOptions.scales.y.ticks, callback: v => `$${v}B` },
            },
          },
        },
      });
      markLoaded("chart-global");

      /* Brazil cumulative */
      const bData   = JSON.parse(chartBrazil);
      const bLabels = bData.map(d => d.month.slice(0, 7));
      const bValues = bData.map(d => +(d.accumulatedUsd / 1e9).toFixed(2));

      new Chart(document.getElementById("chart-brazil"), {
        type: "line",
        data: {
          labels: bLabels,
          datasets: [{
            data: bValues,
            borderColor: C.success,
            backgroundColor: ctx => {
              const chart = ctx.chart;
              const { ctx: cctx, chartArea } = chart;
              if (!chartArea) return C.successFill;
              const g = cctx.createLinearGradient(0, chartArea.top, 0, chartArea.bottom);
              g.addColorStop(0, 'rgba(109, 170, 69, 0.28)');
              g.addColorStop(1, 'rgba(109, 170, 69, 0.0)');
              return g;
            },
            fill: true,
            tension: 0.4,
            pointRadius: 0,
            pointHitRadius: 14,
            borderWidth: 2,
          }],
        },
        options: {
          ...baseOptions,
          plugins: {
            ...baseOptions.plugins,
            tooltip: {
              ...baseOptions.plugins.tooltip,
              callbacks: { label: ctx => ` $${ctx.parsed.y}B cumulative inflow` },
            },
          },
          scales: {
            ...baseOptions.scales,
            y: {
              ...baseOptions.scales.y,
              ticks: { ...baseOptions.scales.y.ticks, callback: v => `$${v}B` },
            },
          },
        },
      });
      markLoaded("chart-brazil");
    }

    initStablecoinCharts();
  </script>

</Base>
