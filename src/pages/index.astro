---
/**
 * src/pages/index.astro
 * Variante EN (English) da home page - a raiz do site.
 *
 * Padrão de i18n: JSON estático importado em build-time - zero runtime,
 * compatível 100% com Cloudflare Pages + Astro SSG.
 */
import Base            from '@layouts/Base.astro';
import { Picture }     from 'astro:assets';
import founderImg      from '@assets/founder.jpg';
import t               from '@i18n/en.json';
import ExchangeMarquee from '../components/ExchangeMarquee.astro';
import DolarMapLogo   from '../components/DolarMapLogo.astro';
import '@styles/pages/home.css';

/**
 * hreflang alternates - injetados por Base.astro no <head>.
 */
const alternates = [
  { hreflang: 'en',        href: t.canonical },
  { hreflang: 'pt-BR',     href: t.alternatePt },
  { hreflang: 'x-default', href: t.canonical },
];

/**
 * Schema da home: apenas WebSite.
 * A Organization é declarada UMA ÚNICA VEZ em Base.astro (fonte de verdade).
 * Aqui referenciamos via @id - duplicar a Organization causa "url duplicado"
 * no Rich Results Test quando o validador unifica os dois nós pelo mesmo @id.
 */
const schema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": "https://bitsark.com/#website",
  "url": "https://bitsark.com/",
  "name": "bitsARK Labs",
  "alternateName": "bitsARK",
  "description": t.meta.description,
  "inLanguage": "en",
  "publisher": { "@id": "https://bitsark.com/#organization" }
};

const lastModified = new Date().toISOString();

---

<Base
  title={t.meta.title}
  description={t.meta.description}
  lang={t.lang}
  canonical={t.canonical}
  alternates={alternates}
  schema={schema}
  ogImage="https://bitsark.com/og-default.png"
>
  <meta slot="head" property="article:modified_time" content={lastModified} />

  <!-- ── Hero ──────────────────────────────────────────────── -->
  <section class="hero" aria-labelledby="hero-heading">
    <div class="hero-glow"  aria-hidden="true"></div>
    <div class="hero-glow-2" aria-hidden="true"></div>
    <div class="hero-grid"  aria-hidden="true"></div>

    <div class="container">
      <div class="hero__inner">

        <p class="eyebrow eyebrow--centered fade-up" style="animation-delay: 0.1s">
          {t.hero.eyebrow}
        </p>

        <h1 id="hero-heading" class="hero__title fade-up" style="animation-delay: 0.2s">
          {t.hero.title}<br />
          <span class="hero__title-accent">{t.hero.titleAccent}</span>
        </h1>

        <p class="hero__subtitle fade-up" style="animation-delay: 0.3s">
          {t.hero.subtitle}
        </p>

        <div class="hero__actions fade-up" style="animation-delay: 0.4s">
          <a href="/dolarmap" class="btn btn-primary">
            {t.hero.ctaPrimary}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
                 aria-hidden="true" focusable="false">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
          <a href="/exchanges/api" class="btn btn-secondary">
            {t.hero.ctaSecondary}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
                 aria-hidden="true" focusable="false">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>

        <div class="hero__stats fade-up"
             style="animation-delay: 0.5s"
             role="list"
             aria-label={t.hero.statsAriaLabel}>

          {t.hero.stats.map((stat, i) => (
            <>
              <div class="hero__stat" role="listitem">
                <span class={`hero__stat-value${stat.accent ? ' hero__stat-value--accent' : ''}`}>
                  {stat.value}
                </span>
                <span class="hero__stat-label">{stat.label}</span>
                {stat.meta && <span class="hero__stat-meta">{stat.meta}</span>}
              </div>
              {i < t.hero.stats.length - 1 && (
                <div class="hero__stat-divider" aria-hidden="true"></div>
              )}
            </>
          ))}

        </div>

      </div>
    </div>
  </section>

  <!-- ── Founder Band ──────────────────────────────────────────
       Faixa âncora-de-credibilidade: ponte entre o produto (Hero)
       e o portfólio (Tools). Asymmetric photo-left layout.
       Status dot pulsa em --color-success; mono font na linha 2 carrega
       a estética dev/terminal do resto do site.
  -->
  <aside class="founder-band fade-up"
         aria-label={t.founder.ariaLabel}
         style="animation-delay: 0.6s">
    <div class="container">
      <div class="founder-band__inner">

        <a href="/about" class="founder-band__photo-link"
           aria-label={t.founder.aboutLabel}>
          <span class="founder-band__photo-glow" aria-hidden="true"></span>
          <Picture
            src={founderImg}
            alt={t.founder.photoAlt}
            widths={[64, 96, 128, 192]}
            sizes="64px"
            formats={['avif', 'webp']}
            quality={85}
            class="founder-band__photo"
            loading="lazy"
            decoding="async"
          />
        </a>

        <div class="founder-band__content">
          <p class="founder-band__line1">
            <span class="founder-band__name">{t.founder.name}</span>
            <span class="founder-band__dash" aria-hidden="true">-</span>
            <span class="founder-band__role">{t.founder.role}</span>
          </p>
          <p class="founder-band__line2">
            <span class="founder-band__status">
              <span class="founder-band__status-dot" aria-hidden="true"></span>
              {t.founder.statusLabel}
            </span>
            <span class="founder-band__sep" aria-hidden="true">·</span>
            <span class="founder-band__status-detail">{t.founder.statusDetail}</span>
          </p>
        </div>

        <div class="founder-band__actions">
          <a
            href="https://www.linkedin.com/in/ricardods/"
            class="founder-band__link"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn (opens in new tab)"
          >
            {t.founder.linkedinLabel}
            <svg width="10" height="10" viewBox="0 0 12 12" fill="none" aria-hidden="true">
              <path d="M2.5 9.5l7-7M9.5 9V2.5H3"
                    stroke="currentColor" stroke-width="1.5"
                    stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="/about" class="founder-band__link founder-band__link--primary">
            {t.founder.aboutLabel}
          </a>
        </div>

      </div>
    </div>
  </aside>

  <!-- ── Produtos ─────────────────────────────────────────── -->
  <section class="section" id="products" aria-labelledby="products-heading">
    <div class="container">
      <p class="eyebrow eyebrow--centered">{t.tools.eyebrow} · {t.intelligence.eyebrow}</p>
      <h2 id="products-heading" class="section__title">{t.tools.title}</h2>

      <div class="products-grid--four">

        <!-- DolarMap (hero - spans full row 1) -->
        <article class="card product-card product-card--dolarmap product-card--hero fade-up" data-spotlight style="animation-delay: 0.1s">
          <span class="product-card__aurora" aria-hidden="true"></span>
          <span class="product-card__grain"  aria-hidden="true"></span>
          <span class="product-card__spotlight" aria-hidden="true"></span>
          <div class="card-body">
            <div class="product-card__header">
              <svg class="product-card__icon" width="18" height="18" viewBox="0 0 24 24" fill="none"
                   stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                   aria-hidden="true" focusable="false">
                <rect x="5" y="2" width="14" height="20" rx="2" ry="2"/>
                <path d="M12 18h.01"/>
              </svg>
              <span class="product-card__type">Mobile App</span>
            </div>

            <h3 class="product-card__dm-logo-row">
              <a href="/dolarmap" class="product-card__dm-logo product-card__primary-link" aria-label={t.tools.dolarmap.ariaLabel}>
                <DolarMapLogo gradientId="dm-logo-gradient-home" aria-label="DolarMap" role="img" focusable="false" />
              </a>
            </h3>

            <p class="product-card__lede" set:html={t.tools.dolarmap.desc} />

            <dl class="product-card__kpis" aria-label="DolarMap key metrics">
              {t.tools.dolarmap.kpis.map((kpi, i) => (
                <>
                  {i > 0 && <span class="kpi__divider" aria-hidden="true"></span>}
                  <div class="kpi">
                    <dt class="kpi__num" data-count={kpi.count}>{kpi.num}</dt>
                    <dd class="kpi__label">{kpi.label}</dd>
                  </div>
                </>
              ))}
            </dl>

            <div class="product-card__tags">
              <span class="badge badge-success">
                <span class="status-dot" aria-hidden="true"></span>
                {t.tools.dolarmap.statusLabel}
              </span>
              <span class="badge badge-neutral">Android</span>
              <span class="badge badge-neutral">Node.js</span>
              <span class="badge badge-neutral">Flutter</span>
            </div>

            <div class="product-card__cta-group">
              <a href="/dolarmap" class="btn btn-secondary btn-sm product-card__secondary-link">{t.tools.dolarmap.cta}</a>
            </div>
          </div>
        </article>

        <!-- Stablecoins no Brasil -->
        <article class="card product-card product-card--stablecoins fade-up" data-spotlight style="animation-delay: 0.4s">
          <span class="product-card__aurora" aria-hidden="true"></span>
          <span class="product-card__grain"  aria-hidden="true"></span>
          <span class="product-card__spotlight" aria-hidden="true"></span>
          <div class="card-body">
            <div class="product-card__header">
              <svg class="product-card__icon" width="18" height="18" viewBox="0 0 24 24" fill="none"
                   stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                   aria-hidden="true" focusable="false">
                <line x1="12" y1="1" x2="12" y2="23"/>
                <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
              </svg>
              <span class="product-card__type">Market Data</span>
            </div>

            <h3 class="nav__product-block">
              <a href="/stablecoins-brasil" class="product-card__logo-wrap product-card__primary-link" aria-label={t.intelligence.stablecoins.ariaLabel}>
                <span class="nav__product-block__name nav__product-block__name--success">
                  {t.intelligence.stablecoins.productName}
                </span>
                <span class="nav__product-block__sub nav__product-block__sub--faint">
                  {t.intelligence.stablecoins.productSub}
                </span>
              </a>
            </h3>

            <dl class="product-card__kpis" aria-label="Stablecoins Brazil key metrics">
              {t.intelligence.stablecoins.kpis.map((kpi, i) => (
                <>
                  {i > 0 && <span class="kpi__divider" aria-hidden="true"></span>}
                  <div class="kpi">
                    <dt class="kpi__num" data-count={kpi.count}>{kpi.num}</dt>
                    <dd class="kpi__label">{kpi.label}</dd>
                  </div>
                </>
              ))}
            </dl>

            <div class="product-card__tags">
              <span class="badge badge-success">
                <span class="status-dot" aria-hidden="true"></span>
                {t.intelligence.stablecoins.statusLabel}
              </span>
              <span class="badge badge-neutral">{t.intelligence.stablecoins.badge1}</span>
            </div>

            <div class="product-card__cta-group">
              <a href="/stablecoins-brasil" class="btn btn-secondary btn-sm product-card__secondary-link">{t.intelligence.stablecoins.cta}</a>
            </div>
          </div>
        </article>

        <!-- Exchanges API -->
        <article class="card product-card product-card--api fade-up" data-spotlight style="animation-delay: 0.2s">
          <span class="product-card__aurora" aria-hidden="true"></span>
          <span class="product-card__grain"  aria-hidden="true"></span>
          <span class="product-card__spotlight" aria-hidden="true"></span>
          <div class="card-body">
            <div class="product-card__header">
              <svg class="product-card__icon" width="18" height="18" viewBox="0 0 24 24" fill="none"
                   stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                   aria-hidden="true" focusable="false">
                <polyline points="16 18 22 12 16 6"/>
                <polyline points="8 6 2 12 8 18"/>
              </svg>
              <span class="product-card__type">REST API</span>
            </div>

            <h3 class="nav__product-block">
              <a href="/exchanges/api" class="product-card__logo-wrap product-card__primary-link" aria-label={t.tools.api.ariaLabel}>
                <span class="nav__product-block__name nav__product-block__name--api">
                  {t.tools.api.productName}
                </span>
                <span class="nav__product-block__sub nav__product-block__sub--faint">
                  {t.tools.api.productSub}
                </span>
              </a>
            </h3>

            <dl class="product-card__kpis" aria-label="Exchanges API key metrics">
              {t.tools.api.kpis.map((kpi, i) => (
                <>
                  {i > 0 && <span class="kpi__divider" aria-hidden="true"></span>}
                  <div class="kpi">
                    <dt class="kpi__num" data-count={kpi.count}>{kpi.num}</dt>
                    <dd class="kpi__label">{kpi.label}</dd>
                  </div>
                </>
              ))}
            </dl>

            <div class="product-card__tags">
              <span class="badge badge-success">
                <span class="status-dot" aria-hidden="true"></span>
                {t.tools.api.statusLabel}
              </span>
              <span class="badge badge-neutral">REST · JSON</span>
              <span class="badge badge-neutral">Cloudflare</span>
            </div>

            <div class="product-card__cta-group">
              <a href="/exchanges/api" class="btn btn-secondary btn-sm product-card__secondary-link">{t.tools.api.ctaDocs}</a>
              <a href="/exchanges/"   class="btn btn-secondary btn-sm product-card__secondary-link">{t.tools.api.ctaExchanges}</a>
            </div>
          </div>
        </article>

        <!-- Exchanges no Brasil -->
        <article class="card product-card product-card--exchanges fade-up" data-spotlight style="animation-delay: 0.3s">
          <span class="product-card__aurora" aria-hidden="true"></span>
          <span class="product-card__grain"  aria-hidden="true"></span>
          <span class="product-card__spotlight" aria-hidden="true"></span>
          <div class="card-body">
            <div class="product-card__header">
              <svg class="product-card__icon" width="18" height="18" viewBox="0 0 24 24" fill="none"
                   stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                   aria-hidden="true" focusable="false">
                <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
                <line x1="8" y1="21" x2="16" y2="21"/>
                <line x1="12" y1="17" x2="12" y2="21"/>
              </svg>
              <span class="product-card__type">Exchange Intelligence</span>
            </div>

            <h3 class="nav__product-block">
              <a href="/exchanges" class="product-card__logo-wrap product-card__primary-link" aria-label={t.intelligence.exchanges.ariaLabel}>
                <span class="nav__product-block__name nav__product-block__name--primary">
                  {t.intelligence.exchanges.productName}
                </span>
                <span class="nav__product-block__sub nav__product-block__sub--faint">
                  {t.intelligence.exchanges.productSub}
                </span>
              </a>
            </h3>

            <dl class="product-card__kpis" aria-label="Exchanges Brazil key metrics">
              {t.intelligence.exchanges.kpis.map((kpi, i) => (
                <>
                  {i > 0 && <span class="kpi__divider" aria-hidden="true"></span>}
                  <div class="kpi">
                    <dt class="kpi__num" data-count={kpi.count}>{kpi.num}</dt>
                    <dd class="kpi__label">{kpi.label}</dd>
                  </div>
                </>
              ))}
            </dl>

            <div class="product-card__tags">
              <span class="badge badge-success">
                <span class="status-dot" aria-hidden="true"></span>
                {t.intelligence.exchanges.statusLabel}
              </span>
              <span class="badge badge-neutral">{t.intelligence.exchanges.badge2}</span>
            </div>

            <div class="product-card__cta-group">
              <a href="/exchanges" class="btn btn-secondary btn-sm product-card__secondary-link">{t.intelligence.exchanges.cta}</a>
            </div>

            <aside class="product-card__marquee-strip" aria-label="Brazilian exchanges">
              <ExchangeMarquee />
            </aside>
          </div>
        </article>

      </div>
    </div>
  </section>

  <!-- ── Princípios ─────────────────────────────────────────── -->
  <section class="section" id="principles" aria-labelledby="principles-heading">
    <div class="container">
      <p class="eyebrow eyebrow--centered">{t.principles.eyebrow}</p>
      <h2 id="principles-heading" class="section__title">{t.principles.title}</h2>

      <div class="reasons-grid">

        <!-- Gap-first -->
        <div class="reason-card fade-up" style="animation-delay: 0.1s">
          <div class="reason-card__icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round" focusable="false">
              <circle cx="11" cy="11" r="8"/>
              <path d="M21 21l-4.35-4.35"/>
            </svg>
          </div>
          <h3 class="reason-card__title">{t.principles.items[0].title}</h3>
          <p>{t.principles.items[0].desc}</p>
          <p class="reason-card__proof">{t.principles.items[0].proof}</p>
        </div>

        <!-- Zero fricção -->
        <div class="reason-card fade-up" style="animation-delay: 0.2s">
          <div class="reason-card__icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round" focusable="false">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
              <path d="M7 11V7a5 5 0 0 1 9.9-1"/>
            </svg>
          </div>
          <h3 class="reason-card__title">{t.principles.items[1].title}</h3>
          <p>{t.principles.items[1].desc}</p>
          <p class="reason-card__proof">{t.principles.items[1].proof}</p>
        </div>

        <!-- Profundidade regulatória BR -->
        <div class="reason-card fade-up" style="animation-delay: 0.3s">
          <div class="reason-card__icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round" focusable="false">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
          </div>
          <h3 class="reason-card__title">{t.principles.items[2].title}</h3>
          <p>{t.principles.items[2].desc}</p>
          <p class="reason-card__proof">{t.principles.items[2].proof}</p>
        </div>

      </div>
    </div>
  </section>

  <!-- ── CTA Strip ──────────────────────────────────────────── -->
  <section class="cta-strip" id="cta" aria-labelledby="cta-heading">
    <div class="container">
      <p class="cta-strip__terminal" aria-hidden="true">{t.cta.terminal}</p>
      <h2 id="cta-heading" class="cta-strip__title">{t.cta.title}</h2>
      <p class="cta-strip__sub">{t.cta.subtitle}</p>
      <div class="cta-strip__actions">
        <a href="/exchanges" class="btn btn-primary">{t.cta.ctaExchanges}</a>
        <a
          href="https://github.com/bitsARK-Labs"
          class="btn btn-secondary"
          target="_blank"
          rel="noopener noreferrer"
        >
          {t.cta.ctaGithub}
        </a>
      </div>
      <!-- Hiring callout: recruiter-facing anchor with strong visual hook -->
      <div class="cta-strip__hiring" role="complementary" aria-label={t.cta.hiringTag}>
        <span class="cta-strip__hiring-tag">{t.cta.hiringTag}</span>
        <p class="cta-strip__hiring-body">{t.cta.hiringBody}</p>
        <a href="/about" class="cta-strip__hiring-link">{t.cta.hiringLink}</a>
      </div>

      <p class="cta-strip__about">
        {t.cta.aboutPrefix} <a href="/about">{t.cta.aboutLink}</a>
      </p>
    </div>
  </section>

  {/*
    Product-card interactivity: spotlight cursor-follow + KPI count-up.
    Inline so it runs after DOM parse with zero bundling overhead - the
    snippet has no imports and is tiny (~1 KB).
  */}
  <script>
    function initHome() {
      // Spotlight: update --mx/--my on each product card as the pointer moves
      document.querySelectorAll<HTMLElement>('[data-spotlight]').forEach((card) => {
        card.addEventListener('pointermove', (e: PointerEvent) => {
          const r = card.getBoundingClientRect();
          card.style.setProperty('--mx', `${e.clientX - r.left}px`);
          card.style.setProperty('--my', `${e.clientY - r.top}px`);
        });
      });

      // KPI count-up on scroll into view (skipped under reduced-motion)
      const reduceMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (!reduceMotion && 'IntersectionObserver' in window) {
        const animateCount = (el: HTMLElement, target: number) => {
          const duration = 1200;
          const start = performance.now();
          const tpl = el.dataset.template || '{n}';
          const tick = (now: number) => {
            const t = Math.min(1, (now - start) / duration);
            const eased = 1 - Math.pow(1 - t, 3);
            el.textContent = tpl.replace('{n}', String(Math.round(target * eased)));
            if (t < 1) requestAnimationFrame(tick);
          };
          requestAnimationFrame(tick);
        };

        const io = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            const el = entry.target as HTMLElement;
            const target = parseFloat(el.dataset.count ?? '');
            if (!Number.isNaN(target)) animateCount(el, target);
            io.unobserve(el);
          });
        }, { threshold: 0.4 });

        document.querySelectorAll<HTMLElement>('.kpi__num[data-count]').forEach((el) => {
          const m = el.textContent?.match(/(\d[\d.,]*)/);
          if (m) {
            el.dataset.template = el.textContent!.replace(m[1], '{n}');
            el.textContent = el.dataset.template.replace('{n}', '0');
          }
          io.observe(el);
        });
      }
    }

    document.addEventListener('astro:page-load', initHome);
  </script>

</Base>
