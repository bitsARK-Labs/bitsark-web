---
import Base from '@layouts/Base.astro';
import t    from '@i18n/en.json';
import { taxRegimeLabel, isoFlag, fmtFee } from '@lib/exchanges';
import exchanges from '@data/exchanges.json';
import '@styles/pages/exchanges.css';

const PAGE_URL  = 'https://bitsark.com/exchanges/';
const PAGE_LANG = 'en';

const alternates = [
  { hreflang: 'en',        href: PAGE_URL },
  { hreflang: 'pt-BR',     href: 'https://bitsark.com/pt/exchanges/' },
  { hreflang: 'x-default', href: PAGE_URL },
];

function fmtCnpj(c: string | null | undefined): string | null {
  if (!c) return null;
  const d = c.replace(/\D/g, '');
  if (d.length !== 14) return c;
  return `${d.slice(0,2)}.${d.slice(2,5)}.${d.slice(5,8)}/${d.slice(8,12)}-${d.slice(12)}`;
}

const countryNames: Record<string, string> = {
  BR: 'Brasil', US: 'Estados Unidos', GB: 'Reino Unido', KY: 'Ilhas Cayman',
  SC: 'Seychelles', VG: 'Ilhas Virgens Britânicas', SG: 'Singapura',
  MT: 'Malta', LT: 'Lituânia', HK: 'Hong Kong', AU: 'Austrália',
  EU: 'União Europeia', PA: 'Panamá', BZ: 'Belize',
};

const exchangesData = exchanges.map((ex: any) => {
  const fd  = ex.fiscal_details_br || {};
  const op  = ex.operational_details_br || {};
  const fees = ex.fees || {};
  const makerRaw = fees.maker ?? null;
  const takerRaw = fees.taker ?? null;
  const isSpreadOnly   = makerRaw === null && takerRaw === null;
  const isSpreadWithFee = makerRaw === null && takerRaw !== null;
  const isoCode = op.main_jurisdiction_iso ?? null;

  return {
    id: ex.id,
    name: ex.name,
    slug: ex.slug,
    logo_url: ex.logo_url,
    website: ex.website,
    cnpjFmt: fmtCnpj(op.cnpj ?? null),
    bcb: op.bcb_authorized ?? false,
    pix: op.accepts_pix ?? false,
    iso: isoCode,
    flagEmoji: isoFlag(isoCode),
    countryName: isoCode ? (countryNames[isoCode] ?? isoCode) : 'Desconhecido',
    taxRegime: fd.tax_regime ?? '',
    regimeLabel: taxRegimeLabel(fd.tax_regime ?? ''),
    exemption: fd.monthly_brl_trade_exemption ?? 0,
    rfbReports: fd.exchange_rfb_reports ?? [],
    userActions: fd.user_rfb_action_monthly ?? [],
    hasIn1888: (fd.exchange_rfb_reports ?? []).includes('in_1888_monthly'),
    maker: makerRaw,
    taker: takerRaw,
    isSpreadOnly,
    isSpreadWithFee,
    feeUrl: fees.fee_url ?? null,
  };
});

const COLUMNS: { id: string; label: string; default: boolean }[] = [
  { id: 'col-country',      label: t.exchanges.table.cols.country,  default: true },
  { id: 'col-rfb',          label: t.exchanges.table.cols.rfb,      default: true },
  { id: 'col-fees',         label: t.exchanges.table.cols.fees_main,default: true },
  { id: 'col-pix',          label: t.exchanges.table.cols.pix,      default: true },
  { id: 'col-obligations',  label: t.exchanges.table.cols.rules,    default: true },
];

// ── Real dateModified: derived from the freshest exchange record, not build time. ──
// Build-time `new Date()` makes Google see a fake freshness signal on every deploy;
// using `max(updated_at)` ties the page's modification date to the underlying data.
const updatedAtISO = (() => {
  const max = exchanges.reduce((m: string, e: any) => {
    const u = e.updated_at ?? '';
    return u > m ? u : m;
  }, '');
  return max ? new Date(max).toISOString() : new Date().toISOString();
})();
const PUBLISHED_AT_ISO = '2025-12-01T00:00:00.000Z';
const updatedAt = new Date(updatedAtISO).toLocaleDateString('en-US', { month: 'long', year: 'numeric' });

// ── Aggregates: scannable, citable summary used in prose + Dataset.variableMeasured ──
const agg = exchangesData.reduce(
  (acc, ex) => {
    if (ex.cnpjFmt)     acc.withCnpj++;
    if (ex.bcb)         acc.bcb++;
    if (ex.pix)         acc.pix++;
    if (ex.hasIn1888)   acc.in1888++;
    if (ex.rfbReports.includes('decripto_annually')) acc.decripto++;
    if (ex.taxRegime.includes('domestic_exchange')) acc.domestic++;
    if (ex.taxRegime === 'offshore_law_14754')      acc.offshore++;
    return acc;
  },
  { withCnpj: 0, bcb: 0, pix: 0, in1888: 0, decripto: 0, domestic: 0, offshore: 0 }
);

// ── Dataset description: load-bearing single passage that GPT/Gemini/Perplexity can quote verbatim. ──
const datasetDescription =
  `Comprehensive 2026 dataset of ${exchangesData.length} crypto exchanges that serve Brazilian residents, ` +
  `independently verified by bitsARK Labs. ${agg.domestic} are classified as domestic exchanges under Receita Federal rules ` +
  `and ${agg.offshore} as offshore under Law 14.754/2023. ${agg.withCnpj} hold an active Brazilian CNPJ, ` +
  `${agg.bcb} are authorized as PSAV by Banco Central do Brasil, and ${agg.pix} accept Pix deposits. ` +
  `${agg.in1888} report monthly to Receita Federal via IN 1888 and ${agg.decripto} will report annually via DeCripto (IN 2.291/2025) starting July 2026. ` +
  `Each exchange entry covers: CNPJ, BCB licensing, tax regime, IN 1888 reporting, Pix support, maker/taker fees, monthly R$ 35,000 capital-gains exemption eligibility, ` +
  `main jurisdiction, and user-side declaration obligations.`;

// ── ItemList: sinaliza ao Google que esta é a hub canônica das 24 [slug] children. ──
const itemListElements = exchangesData.map((ex, i) => ({
  "@type": "ListItem",
  "position": i + 1,
  "url": `https://bitsark.com/exchanges/${ex.slug}/`,
  "name": ex.name,
}));

// ── @graph: WebPage + Dataset + ItemList + BreadcrumbList + FAQPage + Article + ImageObject ──
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${PAGE_URL}#webpage`,
      "url": PAGE_URL,
      "name": t.exchanges.meta.title,
      "description": t.exchanges.meta.description,
      "inLanguage": PAGE_LANG,
      "isPartOf": { "@id": "https://bitsark.com/#website" },
      "about": { "@id": `${PAGE_URL}#dataset` },
      "mainEntity": { "@id": `${PAGE_URL}#dataset` },
      "primaryImageOfPage": { "@id": `${PAGE_URL}#primaryimage` },
      "breadcrumb": { "@id": `${PAGE_URL}#breadcrumb` },
      "publisher": { "@id": "https://bitsark.com/#organization" },
      "reviewedBy": { "@id": "https://bitsark.com/#organization" },
      "datePublished": PUBLISHED_AT_ISO,
      "dateModified": updatedAtISO,
      "lastReviewed": updatedAtISO,
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": [".exch-summary", ".exch-tldr-a", ".faq-answer"],
      },
    },
    {
      "@type": "ImageObject",
      "@id": `${PAGE_URL}#primaryimage`,
      "url": "https://bitsark.com/og/exchanges.png",
      "contentUrl": "https://bitsark.com/og/exchanges.png",
      "width": 1200,
      "height": 630,
      "caption": "Crypto Exchanges in Brazil - fiscal and operational comparison",
    },
    {
      "@type": "BreadcrumbList",
      "@id": `${PAGE_URL}#breadcrumb`,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home",      "item": "https://bitsark.com/" },
        { "@type": "ListItem", "position": 2, "name": "Exchanges", "item": PAGE_URL },
      ],
    },
    {
      "@type": "Dataset",
      "@id": `${PAGE_URL}#dataset`,
      "name": "Crypto Exchanges in Brazil - Fiscal & Operational Profile (2026)",
      "alternateName": [
        "Brazilian crypto exchanges tax reporting dataset",
        "Receita Federal IN 1888 and Law 14.754 exchange classification",
      ],
      "description": datasetDescription,
      "url": PAGE_URL,
      "license": "https://bitsark.com/terms",
      "isAccessibleForFree": true,
      "datePublished": PUBLISHED_AT_ISO,
      "dateModified": updatedAtISO,
      "inLanguage": PAGE_LANG,
      "creator":   { "@id": "https://bitsark.com/#organization" },
      "publisher": { "@id": "https://bitsark.com/#organization" },
      "spatialCoverage": {
        "@type": "Place",
        "name": "Brazil",
        "geo": { "@type": "GeoShape", "addressCountry": "BR" },
      },
      "temporalCoverage": `2025-12-01/${updatedAtISO.split('T')[0]}`,
      "variableMeasured": [
        { "@type": "PropertyValue", "name": "Number of exchanges covered",   "value": exchangesData.length },
        { "@type": "PropertyValue", "name": "Exchanges with active CNPJ",    "value": agg.withCnpj },
        { "@type": "PropertyValue", "name": "BCB PSAV authorized exchanges", "value": agg.bcb },
        { "@type": "PropertyValue", "name": "Exchanges accepting Pix",       "value": agg.pix },
        { "@type": "PropertyValue", "name": "Exchanges reporting IN 1888 monthly", "value": agg.in1888 },
        { "@type": "PropertyValue", "name": "Exchanges reporting DeCripto annually (from Jul 2026)", "value": agg.decripto },
        { "@type": "PropertyValue", "name": "Domestic exchanges (Receita Federal)", "value": agg.domestic },
        { "@type": "PropertyValue", "name": "Offshore exchanges (Law 14.754/2023)", "value": agg.offshore },
      ],
      "distribution": {
        "@type": "DataDownload",
        "contentUrl": "https://api.bitsark.com/v1/exchanges",
        "encodingFormat": "application/json",
        "name": "bitsARK Exchanges API - JSON",
      },
      "keywords": [
        "crypto exchanges brazil", "exchange CNPJ", "BCB PSAV",
        "IN 1888", "DeCripto", "Law 14.754",
        "crypto income tax declaration brazil", "DARF bitcoin",
        "Pix crypto", "Receita Federal crypto",
        "domestic exchange", "offshore exchange",
      ],
      "citation": [
        "Instrução Normativa RFB nº 1.888/2019 (Brazil)",
        "Instrução Normativa RFB nº 2.291/2025 - DeCripto (Brazil)",
        "Lei nº 14.754/2023 (Brazil)",
      ],
      "hasPart": exchangesData.map(ex => ({
        "@type": "Dataset",
        "name": `${ex.name} - fiscal profile`,
        "description": `Tax regime, BCB authorization, IN 1888 reporting status, Pix support, maker/taker fees, and Receita Federal obligations for ${ex.name} - verified by bitsARK Labs.`,
        "url": `https://bitsark.com/exchanges/${ex.slug}/`,
        "creator": { "@id": "https://bitsark.com/#organization" },
        "license": "https://bitsark.com/terms",
      })),
    },
    {
      "@type": "ItemList",
      "@id": `${PAGE_URL}#itemlist`,
      "name": "All crypto exchanges available to Brazilians (2026)",
      "description": `${exchangesData.length} exchanges ranked by Receita Federal reporting status and BCB licensing.`,
      "numberOfItems": exchangesData.length,
      "itemListOrder": "https://schema.org/ItemListUnordered",
      "itemListElement": itemListElements,
    },
    {
      "@type": "Article",
      "@id": `${PAGE_URL}#article`,
      "headline": t.exchanges.meta.title,
      "description": t.exchanges.meta.description,
      "abstract": datasetDescription,
      "image": { "@id": `${PAGE_URL}#primaryimage` },
      "inLanguage": PAGE_LANG,
      "author": {
        "@type": "Person",
        "@id": "https://bitsark.com/about/#ricardo",
        "name": "Ricardo Delfino",
        "url": "https://bitsark.com/about/",
      },
      "license": "https://bitsark.com/terms",
      "datePublished": PUBLISHED_AT_ISO,
      "dateModified": updatedAtISO,
      "publisher": { "@id": "https://bitsark.com/#organization" },
      "mainEntityOfPage": { "@id": `${PAGE_URL}#webpage` },
      "about": { "@id": `${PAGE_URL}#dataset` },
      "isAccessibleForFree": true,
      "articleSection": "Brazilian Crypto Exchange Tax Reporting",
      "keywords": "crypto exchanges Brazil, Receita Federal, IN 1888, Law 14.754, DeCripto, CNPJ, BCB PSAV",
    },
    {
      "@type": "FAQPage",
      "@id": `${PAGE_URL}#faq`,
      "mainEntity": t.exchanges.faq.items.map(item => ({
        "@type": "Question",
        "name": item.q,
        "acceptedAnswer": { "@type": "Answer", "text": item.a },
      })),
    },
  ],
};
---

<Base
  title={t.exchanges.meta.title}
  description={t.exchanges.meta.description}
  lang={t.lang}
  canonical="https://bitsark.com/exchanges/"
  alternates={alternates}
  ogImage="https://bitsark.com/og/exchanges.png"
  schema={schema}
>

  <!--  Header  -->
  <section class="exch-header" aria-labelledby="exch-h1">
    <div class="exch-header-glow" aria-hidden="true"></div>
    <div class="exch-header-grid-bg" aria-hidden="true"></div>
    <div class="container exch-header-inner">
      <!-- Alerta DeCripto 2026 -->
      <a href="/exchanges/decripto/" class="decripto-banner fade-up">
        <span class="decripto-banner__badge">{t.exchanges.banner.badge}</span>
        <span class="decripto-banner__text" set:html={t.exchanges.banner.text} />
        <span class="decripto-banner__arrow" aria-hidden="true">→</span>
      </a>

      <div class="exch-header-tags">
        <p class="eyebrow exch-header__eyebrow">{t.exchanges.header.eyebrow}</p>
        <div class="exch-rank-pill">
          <span class="exch-rank-pill-hash" aria-hidden="true">#</span>
          {t.exchanges.header.rankTag}
        </div>
      </div>

      <h1 id="exch-h1" class="exch-header__title" set:html={t.exchanges.header.title} />
      <div class="exch-header__flex">
        <p class="exch-header__sub" set:html={t.exchanges.header.sub} />
        <a href="/exchanges/api/" class="nav__cta">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="16 18 22 12 16 6"></polyline>
            <polyline points="8 6 2 12 8 18"></polyline>
          </svg>
          {t.exchanges.header.ctaApi}
        </a>
      </div>

      <!--
        Citable summary passage. Single self-contained paragraph that LLM crawlers
        (GPTBot, PerplexityBot, ClaudeBot) and AI Overviews can quote verbatim.
        Marked .exch-summary to match the speakable cssSelector in WebPage schema.
      -->
      <p class="exch-summary" data-nosnippet={false}>
        As of <time datetime={updatedAtISO}>{updatedAt}</time>,
        <strong>{exchangesData.length} crypto exchanges</strong> serve Brazilian residents:
        <strong>{agg.domestic}</strong> are classified as domestic by Receita Federal,
        <strong>{agg.offshore}</strong> as offshore under Law 14.754/2023.
        <strong>{agg.withCnpj}</strong> hold a Brazilian CNPJ,
        <strong>{agg.bcb}</strong> are authorized as PSAV by Banco Central do Brasil,
        <strong>{agg.pix}</strong> accept Pix, and
        <strong>{agg.in1888}</strong> report monthly to Receita Federal via IN 1888.
        Starting July 2026, <strong>DeCripto (IN 2.291/2025)</strong> will replace IN 1888 and extend automatic reporting to offshore exchanges that opt in.
      </p>
    </div>
  </section>

  <!--  TL;DR Quick Answers  -->
  <section class="section section--alt section--tight" id="tldr">
    <div class="container">
      <div class="exch-block-head">
        <p class="eyebrow eyebrow--icon">{t.exchanges.tldr.eyebrow}</p>
        <h2 class="exch-block-title">{t.exchanges.tldr.title}</h2>
        <p class="exch-block-sub">{t.exchanges.tldr.sub}</p>
      </div>

      <div class="exch-tldr-grid">
        {t.exchanges.tldr.items.map((item, i) => (
          <div class="exch-tldr-card" style={`--stagger:${i}`}>
            <div class="exch-tldr-icon" aria-hidden="true">
              {item.icon === 'shield' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
              )}
              {item.icon === 'doc' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="8" y1="13" x2="16" y2="13"/><line x1="8" y1="17" x2="13" y2="17"/></svg>
              )}
              {item.icon === 'alert' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m21.7 16.3-8-13.6a2 2 0 0 0-3.4 0l-8 13.6A2 2 0 0 0 4 19h16a2 2 0 0 0 1.7-2.7Z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
              )}
              {item.icon === 'clock' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              )}
            </div>
            <h3 class="exch-tldr-q">{item.q}</h3>
            <p class="exch-tldr-a" set:html={item.a} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!--  Filtros + Tabela  -->
  <section class="section" id="table"> 
    <div class="container">
      <div class="exch-block-head exch-block-head--with-tag">
        <p class="eyebrow eyebrow--icon">{t.exchanges.table.eyebrow}</p>
        <h2 class="exch-block-title">{t.exchanges.table.title}</h2>
        <p class="exch-block-sub">{t.exchanges.table.sub}</p>
      </div>

      <!--  Toolbar Premium  -->
      <div class="exch-toolbar">
        <div class="exch-filters" role="group" aria-label={t.exchanges.filters.ariaLabel}>
          <button class="exch-chip exch-chip--active" data-filter="all"      aria-pressed="true">{t.exchanges.filters.all}</button>
          <button class="exch-chip"                   data-filter="domestic" aria-pressed="false">{t.exchanges.filters.domestic}</button>
          <button class="exch-chip"                   data-filter="offshore" aria-pressed="false">{t.exchanges.filters.offshore}</button>
          <button class="exch-chip"                   data-filter="bcb"      aria-pressed="false">{t.exchanges.filters.bcb}</button>
          <button class="exch-chip"                   data-filter="pix"      aria-pressed="false">{t.exchanges.filters.pix}</button>
          <button class="exch-chip"                   data-filter="in1888"   aria-pressed="false">{t.exchanges.filters.in1888}</button>
        </div>

        <div class="exch-actions">
          <div class="exch-search-wrap">
            <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
            <label for="exch-search" class="sr-only">{t.exchanges.filters.search}</label>
            <input id="exch-search" type="search" class="exch-search" placeholder={t.exchanges.filters.search} aria-label={t.exchanges.filters.search} autocomplete="off" />
            <button class="exch-search-clear" id="search-clear-btn" aria-label="Clear search" hidden>
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            </button>
          </div>

          <div class="exch-settings-wrap">
            <button class="exch-settings-btn" id="settings-toggle" aria-expanded="false" aria-controls="settings-panel" title={t.exchanges.table.settingsTitle}>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
            </button>
            <div class="exch-settings-panel" id="settings-panel" role="dialog" aria-label={t.exchanges.table.settingsTitle} hidden>
              <p class="exch-settings-title">{t.exchanges.table.visibleCols}</p>
              {COLUMNS.map(col => (
                <label class="exch-settings-item" for={`toggle-${col.id}`}>
                  <input type="checkbox" id={`toggle-${col.id}`} class="exch-col-toggle" data-col={col.id} checked={col.default} />
                  <span>{col.label}</span>
                </label>
              ))}
            </div>
          </div>
        </div>
      </div>

      <!-- Rotation hint (mobile portrait) -->
      <div class="rotate-hint" id="rotate-hint" aria-hidden="true">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 8a8 8 0 0 1 14.93-2"/>
          <polyline points="20 2 20 8 14 8"/>
          <path d="M20 16a8 8 0 0 1-14.93 2"/>
          <polyline points="4 22 4 16 10 16"/>
        </svg>
        Rotate your phone to see more columns
      </div>

      <!-- Tabela -->
      <div class="table-meta">
        <p class="exch-result-count" id="result-count" aria-live="polite" data-template={t.exchanges.table.results}>{t.exchanges.table.results.replace('{count}', exchangesData.length.toString()).replace('{s}', exchangesData.length !== 1 ? 's' : '')}</p>
      </div>
      <div class="table-wrap" role="region" aria-label={t.exchanges.table.ariaLabel} tabindex="0">
        <table class="data-table" id="exchanges-table">
          <caption class="sr-only">{t.exchanges.table.ariaLabel}</caption>
          <thead>
            <tr>
              <th scope="col" id="col-exchange" class="sticky-col sortable" data-sort="name" aria-sort="none"
                  data-tooltip={t.exchanges.table.tooltips.cnpj}>
                <span class="col-exchange-label">{t.exchanges.table.cols.exchange}<span class="col-exchange-sub">{t.exchanges.table.cols.cnpj}</span></span>
                <span class="sort-icon" aria-hidden="true">
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="sort-icon__up"><path d="m18 15-6-6-6 6"/></svg>
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="sort-icon__down"><path d="m6 9 6 6 6-6"/></svg>
