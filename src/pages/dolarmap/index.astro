<!-- ═══════════════════════════════════════════════════════════════════════════
     SCRIPTS - scroll reveal + video resilience
═══════════════════════════════════════════════════════════════════════════ -->
<script>
  // ── Fade-up via IntersectionObserver ─────────────────────────────────
  const els = document.querySelectorAll<HTMLElement>('.fade-up');
  if ('IntersectionObserver' in window && els.length) {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            io.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
    );
    els.forEach((el) => io.observe(el));
  } else {
    els.forEach((el) => el.classList.add('is-visible'));
  }

  // ── Hero video: hide gracefully if source 404s ──────────────────────
  // If both <source> elements fail (e.g. file not uploaded yet) the browser
  // shows nothing and falls back to the poster image - which is exactly
  // what we want. No JS needed unless we want to remove the element.
  const heroVideo = document.querySelector<HTMLVideoElement>('.dm-device__video');
  if (heroVideo) {
    heroVideo.addEventListener('error', () => {
      // When all sources fail, swap to a static poster image to avoid the
      // broken-video icon on certain Android browsers.
      const poster = heroVideo.getAttribute('poster');
      if (poster) {
        const img = document.createElement('img');
        img.src = poster;
        img.alt = '';
        img.className = 'dm-device__video';
        heroVideo.replaceWith(img);
      }
    }, true);
  }
</script>
