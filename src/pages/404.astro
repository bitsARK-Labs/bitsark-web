---
import Base from '@layouts/Base.astro';
import en from '../i18n/en.json';
import pt from '../i18n/pt.json';

// SSG renders in EN - client script swaps to PT if preferred-lang is pt-BR.
// Reason: CDN/server always serves /404.html regardless of the original URL,
// so getLangFromUrl(Astro.url) would always return 'en' in production.
const t404en = en.page_404;
const t404pt = pt.page_404;
---

<Base
  title={t404en.meta.title}
  description={t404en.meta.description}
  noindex={true}
  lang="en"
>
  <!-- Data rain canvas -->
  <canvas id="rain" aria-hidden="true"></canvas>

  <div class="nf">

    <!-- ── Terminal log ── -->
    <div class="term" role="log" aria-label="Request log">
      <div class="term-bar">
        <span class="dot dot--red"></span>
        <span class="dot dot--yellow"></span>
        <span class="dot dot--green"></span>
        <span class="term-name">bitsark://edge/request.log</span>
      </div>
      <div class="term-body">
        <div class="log-row" style="animation-delay:0.05s">
          <span class="ts">14:32:07.891</span>
          <span class="badge info">INFO</span>
          <span data-i18n="terminal.log_info">{t404en.terminal.log_info}</span>
        </div>
        <div class="log-row" style="animation-delay:0.28s">
          <span class="ts">14:32:07.912</span>
          <span class="badge warn">WARN</span>
          <span data-i18n="terminal.log_warn">{t404en.terminal.log_warn}</span>
          &nbsp;<code class="req-path" id="req-path">/&hellip;</code>
        </div>
        <div class="log-row" style="animation-delay:0.51s">
          <span class="ts">14:32:07.913</span>
          <span class="badge err">ERROR</span>
          <span data-i18n="terminal.log_err">{t404en.terminal.log_err}</span>
        </div>
        <div class="log-row" style="animation-delay:0.74s">
          <span class="ts">14:32:07.914</span>
          <span class="badge info">INFO</span>
          <span>
            Exchange API <span class="ok" data-i18n="terminal.status_online">{t404en.terminal.status_online}</span>
            &nbsp;&middot;&nbsp;
            DolarMap <span class="ok" data-i18n="terminal.status_online">{t404en.terminal.status_online}</span>
            &nbsp;&middot;&nbsp;
            Feeds <span class="ok" data-i18n="terminal.status_live">{t404en.terminal.status_live}</span>
          </span>
        </div>
        <div class="log-row cursor-row" style="animation-delay:0.97s">
          <span class="prompt">$</span>&nbsp;<span class="cursor">█</span>
        </div>
      </div>
    </div>

    <!-- ── 404 hero ── -->
    <div class="hero">
      <h1 class="code404" data-text="404" aria-label="404 error">404</h1>
      <div class="route-tag" data-i18n="hero.tag">{t404en.hero.tag}</div>
    </div>

    <!-- ── Description ── -->
    <p class="desc">
      <span data-i18n="desc">{t404en.desc}</span><br>
      <span class="muted" data-i18n="muted">{t404en.muted}</span>
    </p>

    <!-- ── CTAs ── -->
    <div class="actions">
      <a href="/" class="btn btn-primary" id="btn-home">&larr; <span data-i18n="btn_home">{t404en.btn_home}</span></a>
      <a href="/exchanges" class="btn btn-secondary" id="btn-exchanges"><span data-i18n="btn_exchanges">{t404en.btn_exchanges}</span></a>
    </div>

    <!-- ── Status strip ── -->
    <div class="status-strip">
      <span class="status-item"><span class="led led--green"></span><span data-i18n="status_uptime">{t404en.status_uptime}</span></span>
      <span class="status-sep">/</span>
      <span class="status-item"><span class="led led--green"></span><span data-i18n="status_feeds">{t404en.status_feeds}</span></span>
      <span class="status-sep">/</span>
      <span class="status-item"><span class="led led--cyan"></span><span data-i18n="status_store">{t404en.status_store}</span></span>
    </div>

  </div><!-- /.nf -->


  <style>
    /* ───────────────────────────────────────────────────
       Canvas rain
    ─────────────────────────────────────────────────── */
    #rain {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      opacity: 0.14;
    }

    /* ───────────────────────────────────────────────────
       Page wrapper
    ─────────────────────────────────────────────────── */
    .nf {
      position: relative;
      z-index: 1;
      min-height: calc(100vh - 160px);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 2rem;
      padding: 4rem 1.5rem 5rem;
      text-align: center;
    }

    /* ───────────────────────────────────────────────────
       Terminal window
    ─────────────────────────────────────────────────── */
    .term {
      width: 100%;
      max-width: 600px;
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-lg);
      box-shadow:
        var(--glow-primary),
        0 0 0 1px rgba(6, 182, 212, 0.06);
      overflow: hidden;
      animation: fadeUp 0.5s cubic-bezier(0.16, 1, 0.3, 1) both;
    }

    .term-bar {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 0.55rem 1rem;
      background: var(--color-surface-2);
      border-bottom: 1px solid var(--color-border);
    }

    .dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      flex-shrink: 0;
    }
    .dot--red    { background: var(--color-error);   }
    .dot--yellow { background: var(--color-warning); }
    .dot--green  { background: var(--color-success); }

    .term-name {
      font-family: var(--font-mono);
      font-size: 0.67rem;
      color: var(--color-text-faint);
      margin-left: 0.35rem;
      letter-spacing: 0.03em;
    }

    .term-body {
      padding: 0.9rem 1.1rem 1.15rem;
      display: flex;
      flex-direction: column;
      gap: 0.32rem;
    }

    .log-row {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      color: var(--color-text-muted);
      display: flex;
      align-items: baseline;
      gap: 0.45rem;
      flex-wrap: wrap;
      text-align: left;
      opacity: 0;
      animation: fadeUp 0.4s cubic-bezier(0.16, 1, 0.3, 1) both;
    }

    .ts {
      color: var(--color-text-faint);
      font-size: 0.63rem;
      flex-shrink: 0;
    }

    .badge {
      display: inline-block;
      font-family: var(--font-mono);
      font-size: 0.57rem;
      font-weight: 700;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      padding: 0.1em 0.42em;
      border-radius: 0.2em;
      flex-shrink: 0;
    }
    .badge.info { background: rgba(6, 182, 212, 0.12);  color: var(--color-primary); }
    .badge.warn { background: rgba(245, 158, 11, 0.12); color: var(--color-warning); }
    .badge.err  { background: rgba(244, 63, 94, 0.12);  color: var(--color-error);   }

    .req-path {
      font-family: var(--font-mono);
      font-size: 0.67rem;
      color: var(--color-primary);
      background: var(--color-primary-highlight);
      border: 1px solid var(--color-primary-border);
      padding: 0.1em 0.38em;
      border-radius: 0.2em;
    }

    .ok {
      color: var(--color-success);
      font-weight: 600;
    }

    .cursor-row { align-items: center; }
    .prompt { color: var(--color-primary); font-weight: 700; }
    .cursor {
      color: var(--color-primary);
      animation: blink 1.1s step-end infinite;
    }

    /* ───────────────────────────────────────────────────
       404 hero
    ─────────────────────────────────────────────────── */
    .hero {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.85rem;
      animation: fadeUp 0.5s cubic-bezier(0.16, 1, 0.3, 1) 0.15s both;
    }

    .code404 {
      font-family: var(--font-mono);
      font-size: clamp(5.5rem, 20vw, 10.5rem);
      line-height: 1;
      font-weight: 700;
      letter-spacing: -0.04em;
      color: transparent;
      -webkit-text-stroke: 1.5px var(--color-primary);
      text-stroke: 1.5px var(--color-primary);
      position: relative;
      user-select: none;
      margin: 0;
    }

    /* Glitch - top slice */
    .code404::before {
      content: attr(data-text);
      position: absolute;
      inset: 0;
      font-family: var(--font-mono);
      font-size: inherit;
      font-weight: inherit;
      letter-spacing: inherit;
      line-height: inherit;
      color: var(--color-primary);
      clip-path: polygon(0 0, 100% 0, 100% 32%, 0 32%);
      animation: glitch-a 4.2s steps(1) infinite;
    }

    /* Glitch - bottom slice */
    .code404::after {
      content: attr(data-text);
      position: absolute;
      inset: 0;
      font-family: var(--font-mono);
      font-size: inherit;
      font-weight: inherit;
      letter-spacing: inherit;
      line-height: inherit;
      color: var(--color-error);
      opacity: 0.6;
      clip-path: polygon(0 68%, 100% 68%, 100% 100%, 0 100%);
      animation: glitch-b 4.2s steps(1) infinite;
    }

    .route-tag {
      font-family: var(--font-mono);
      font-size: 0.63rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--color-text-faint);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-sm);
      padding: 0.3em 0.85em;
    }

    /* ───────────────────────────────────────────────────
       Description
    ─────────────────────────────────────────────────── */
    .desc {
      color: var(--color-text);
      font-size: 1rem;
      line-height: 1.7;
      animation: fadeUp 0.5s cubic-bezier(0.16, 1, 0.3, 1) 0.25s both;
      margin: 0;
    }
    .muted {
      color: var(--color-text-muted);
      font-size: 0.9em;
    }

    /* ───────────────────────────────────────────────────
       CTAs
    ─────────────────────────────────────────────────── */
    .actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      justify-content: center;
      animation: fadeUp 0.5s cubic-bezier(0.16, 1, 0.3, 1) 0.35s both;
    }

    /* ───────────────────────────────────────────────────
       Status strip
    ─────────────────────────────────────────────────── */
    .status-strip {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      align-items: center;
      gap: 0.6rem 1.2rem;
      font-family: var(--font-mono);
      font-size: 0.64rem;
      color: var(--color-text-faint);
      animation: fadeUp 0.5s cubic-bezier(0.16, 1, 0.3, 1) 0.45s both;
    }
    .status-item {
      display: flex;
      align-items: center;
      gap: 0.38rem;
    }
    .status-sep {
      color: var(--color-divider);
    }

    .led {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      flex-shrink: 0;
    }
    .led--green { background: var(--color-success); box-shadow: 0 0 5px var(--color-success); }
    .led--cyan  { background: var(--color-primary); box-shadow: 0 0 5px var(--color-primary); }

    /* ───────────────────────────────────────────────────
       Keyframes
       (fadeUp is defined globally in global.css)
    ─────────────────────────────────────────────────── */
    @keyframes blink {
      0%, 100% { opacity: 1; }
      50%       { opacity: 0; }
    }

    @keyframes glitch-a {
      0%,  86% { transform: translate(0, 0); }
      87%       { transform: translate(-3px, -1px); }
      88%       { transform: translate(3px, 1px);  }
      89%       { transform: translate(-2px, 0);   }
      90%       { transform: translate(2px, -1px); }
      91%, 100% { transform: translate(0, 0); }
    }

    @keyframes glitch-b {
      0%,  88% { transform: translate(0, 0); }
      89%       { transform: translate(3px, 1px);   }
      90%       { transform: translate(-3px, -1px); }
      91%       { transform: translate(2px, 0);     }
      92%       { transform: translate(-1px, 1px);  }
      93%, 100% { transform: translate(0, 0); }
    }

    /* ───────────────────────────────────────────────────
       Reduced motion
    ─────────────────────────────────────────────────── */
    @media (prefers-reduced-motion: reduce) {
      .code404::before,
      .code404::after,
      .cursor {
        animation: none;
      }
      .code404::before { color: var(--color-primary); }
      .code404::after  { display: none; }
      .cursor { opacity: 1; }
    }
  </style>

  <!-- Translations injected at build time; read by the processed script below -->
  <script is:inline type="application/json" id="i18n-404">
    {JSON.stringify({ en: t404en, pt: t404pt })}
  </script>

  <script>
    (() => {
      /* ── Load translations injected at build time ── */
      const i18nEl = document.getElementById('i18n-404');
      const i18n = i18nEl ? JSON.parse(i18nEl.textContent ?? '{}') : { en: {}, pt: {} };

      /* ── Detect language from localStorage (set by Base.astro on every page visit) ── */
      const isPt = localStorage.getItem('preferred-lang') === 'pt-BR'
        || window.location.pathname.startsWith('/pt/');

      const strings = isPt ? i18n.pt : i18n.en;

      /* ── Swap all translatable text nodes ── */
      document.querySelectorAll('[data-i18n]').forEach((el) => {
        const key = el.getAttribute('data-i18n');
        const keys = key.split('.');
        let val = strings;
        for (const k of keys) val = val?.[k];
        if (typeof val === 'string') el.textContent = val;
      });

      /* ── Update <html lang> and <title> for accessibility ── */
      if (isPt) {
        document.documentElement.lang = 'pt-BR';
        document.title = strings.meta.title;
        document.querySelector('meta[name="description"]')
          ?.setAttribute('content', strings.meta.description);
      }

      /* ── Fix CTA hrefs to use /pt/ prefix when PT ── */
      if (isPt) {
        const btnHome = document.getElementById('btn-home');
        const btnExchanges = document.getElementById('btn-exchanges');
        if (btnHome) btnHome.href = '/pt/';
        if (btnExchanges) btnExchanges.href = '/pt/exchanges/';
      }

      /* ── Fill the actual path in the terminal log ── */
      const pathEl = document.getElementById('req-path');
      if (pathEl) {
        const p = window.location.pathname;
        pathEl.textContent = p.length > 42 ? p.slice(0, 40) + '…' : p;
      }

      /* ── Data-rain canvas ── */
      const canvas = document.getElementById('rain');
      if (!canvas) return;
      const ctx = canvas.getContext('2d');
      if (!ctx) return;

      const SYMS = [
        'BRL','BTC','ETH','USDC','ARK','BCB','PIX','USD','API','FEE',
        '5.23','0.25%','99.9%','0x404','1.00','98.4k','0.012',
        '▲','▼','$','#','0','1','≈','→','·',
      ];

      const FS = 13;
      let drops = [];
      let animationFrameId;
      const mediaQuery = window.matchMedia('(prefers-reduced-motion: reduce)');

      function resize() {
        canvas.width  = window.innerWidth;
        canvas.height = window.innerHeight;
        const cols = Math.floor(canvas.width / FS);
        while (drops.length < cols) drops.push(-(Math.random() * 60 | 0));
        if (drops.length > cols) drops.length = cols;
      }

      resize();
      window.addEventListener('resize', resize, { passive: true });

      function draw() {
        ctx.fillStyle = 'rgba(8, 13, 18, 0.055)';
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        ctx.font = `${FS}px "Geist Mono","Fira Code",monospace`;

        for (let i = 0; i < drops.length; i++) {
          const y = drops[i] * FS;
          if (y < 0) { drops[i] += 0.8; continue; }

          const sym    = SYMS[Math.random() * SYMS.length | 0];
          const bright = y < 80;

          ctx.globalAlpha = bright ? 0.92 : 0.5 + Math.random() * 0.25;
          ctx.fillStyle   = bright ? '#e2eaf4' : '#06b6d4';
          ctx.fillText(sym, i * FS, y);
          ctx.globalAlpha = 1;

          if (y > canvas.height && Math.random() > 0.974) drops[i] = 0;
          drops[i] += 0.75;
        }
      }

      function startAnimation() {
        if (animationFrameId || mediaQuery.matches) return;
        function loop() {
          draw();
          animationFrameId = requestAnimationFrame(loop);
        }
        animationFrameId = requestAnimationFrame(loop);
      }

      function stopAnimation() {
        if (animationFrameId) {
          cancelAnimationFrame(animationFrameId);
          animationFrameId = null;
        }
      }

      startAnimation();
      mediaQuery.addEventListener('change', () => {
        if (mediaQuery.matches) { stopAnimation(); } else { startAnimation(); }
      });
      document.addEventListener('visibilitychange', () => {
        if (document.hidden) { stopAnimation(); } else { startAnimation(); }
      });
    })();
  </script>
</Base>
