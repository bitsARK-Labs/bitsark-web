---
import Base from '@layouts/Base.astro';
import { useTranslations } from '@i18n/index';
import type { Lang } from '@i18n/index';
import EmailObfuscated from '@components/EmailObfuscated.astro';

const lang: Lang = 'pt-BR';
const t = useTranslations(lang);
const title       = t('privacy.title');
const description = t('privacy.description');
const lastUpdated = t('privacy.lastUpdated');

const ensureArray = (val: any) => Array.isArray(val) ? val : [];

const alternates = [
  { hreflang: 'en',        href: 'https://bitsark.com/dolarmap/privacy/' },
  { hreflang: 'pt-BR',     href: 'https://bitsark.com/pt/dolarmap/privacy/' },
  { hreflang: 'x-default', href: 'https://bitsark.com/dolarmap/privacy/' },
];
---

<Base
  title={title}
  description={description}
  lang={lang}
  canonical="https://bitsark.com/pt/dolarmap/privacy/"
  alternates={alternates}
  noindex={true}
>
  <main class="section legal-page">
    <div class="legal-container">
      <header class="legal-header">
        <p class="eyebrow">DolarMap</p>
        <h1>{t('privacy.header')}</h1>
        <p class="legal-meta">
          <strong>DolarMap</strong> · {t('privacy.meta')}: {lastUpdated}
        </p>
      </header>

      <section class="legal-section">
        <h2 set:html={t('privacy.sections.intro.title')} />
        <p set:html={t('privacy.sections.intro.p1')} />
        <p set:html={t('privacy.sections.intro.p2')} />
      </section>

      <section class="legal-section">
        <h2 set:html={t('privacy.sections.controller.title')} />
        <p><span set:html={t('privacy.sections.controller.p1')} /> <EmailObfuscated email="support@bitsark.com" /></p>
      </section>

      <section class="legal-section">
        <h2 set:html={t('privacy.sections.dataCollection.title')} />
        <p set:html={t('privacy.sections.dataCollection.p1')} />

        <h3 set:html={t('privacy.sections.dataCollection.uuid.title')} />
        <p set:html={t('privacy.sections.dataCollection.uuid.p1')} />
        <ul>
          {ensureArray(t('privacy.sections.dataCollection.uuid.items')).map((item: string) => (
            <li set:html={item} />
          ))}
        </ul>

        <h3 set:html={t('privacy.sections.dataCollection.firebase.title')} />
        <p set:html={t('privacy.sections.dataCollection.firebase.p1')} />

        <h3 set:html={t('privacy.sections.dataCollection.fcm.title')} />
        <p set:html={t('privacy.sections.dataCollection.fcm.p1')} />
        <ul>
          {ensureArray(t('privacy.sections.dataCollection.fcm.items')).map((item: string) => (
            <li set:html={item} />
          ))}
        </ul>

        <h3 set:html={t('privacy.sections.dataCollection.alerts.title')} />
        <p set:html={t('privacy.sections.dataCollection.alerts.p1')} />
        <ul>
          {ensureArray(t('privacy.sections.dataCollection.alerts.items')).map((item: string) => (
            <li set:html={item} />
          ))}
        </ul>
        <p set:html={t('privacy.sections.dataCollection.alerts.p2')} />

        <h3 set:html={t('privacy.sections.dataCollection.google.title')} />
        <p set:html={t('privacy.sections.dataCollection.google.p1')} />

        <h3 set:html={t('privacy.sections.dataCollection.sdks.title')} />
        <p set:html={t('privacy.sections.dataCollection.sdks.p1')} />
        <ul>
          {ensureArray(t('privacy.sections.dataCollection.sdks.items')).map((item: string) => (
            <li set:html={item} />
          ))}
        </ul>
        <p set:html={t('privacy.sections.dataCollection.sdks.p2')} />

        <h3 set:html={t('privacy.sections.dataCollection.notCollected.title')} />
        <p set:html={t('privacy.sections.dataCollection.notCollected.p1')} />
        <ul>
          {ensureArray(t('privacy.sections.dataCollection.notCollected.items')).map((item: string) => (
            <li set:html={item} />
          ))}
        </ul>

        <h3 set:html={t('privacy.sections.dataCollection.preferences.title')} />
        <p set:html={t('privacy.sections.dataCollection.preferences.p1')} />
      </section>

      <section class="legal-section">
        <h2 set:html={t('privacy.sections.dataUsage.title')} />
        <p set:html={t('privacy.sections.dataUsage.p1')} />
        <ul>
          {ensureArray(t('privacy.sections.dataUsage.items')).map((item: string) => (
            <li set:html={item} />
          ))}
        </ul>
        <p set:html={t('privacy.sections.dataUsage.p2')} />
      </section>

      <section class="legal-section">
        <h2 set:html={t('privacy.sections.legalBasis.title')} />
        <p set:html={t('privacy.sections.legalBasis.p1')} />
        <ul>
          {ensureArray(t('privacy.sections.legalBasis.items')).map((item: string) => (
            <li set:html={item} />
          ))}
        </ul>
      </section>

      <section class="legal-section">
        <h2 set:html={t('privacy.sections.sharing.title')} />
        <p set:html={t('privacy.sections.sharing.p1')} />

        <h3 set:html={t('privacy.sections.sharing.firebase.title')} />
        <p set:html={t('privacy.sections.sharing.firebase.p1')} />

        <h3 set:html={t('privacy.sections.sharing.server.title')} />
        <p set:html={t('privacy.sections.sharing.server.p1')} />

        <h3 set:html={t('privacy.sections.sharing.legal.title')} />
        <p set:html={t('privacy.sections.sharing.legal.p1')} />
      </section>

      <section class="legal-section">
        <h2 set:html={t('privacy.sections.retention.title')} />
        <p set:html={t('privacy.sections.retention.p1')} />
        <ul>
          {ensureArray(t('privacy.sections.retention.items')).map((item: string) => (
            <li set:html={item} />
          ))}
        </ul>
      </section>

      <section class="legal-section">
        <h2 set:html={t('privacy.sections.security.title')} />
        <p set:html={t('privacy.sections.security.p1')} />
        <ul>
          {ensureArray(t('privacy.sections.security.items')).map((item: string) => (
            <li set:html={item} />
          ))}
        </ul>
        <p set:html={t('privacy.sections.security.p2')} />
      </section>

      <section class="legal-section">
        <h2 set:html={t('privacy.sections.rights.title')} />
        <p set:html={t('privacy.sections.rights.p1')} />
        <ul>
          {ensureArray(t('privacy.sections.rights.items')).map((item: string) => (
            <li set:html={item} />
          ))}
        </ul>
        <p set:html={t('privacy.sections.rights.p2')} />
      </section>

      <section class="legal-section">
        <h2 set:html={t('privacy.sections.cookies.title')} />
        <p set:html={t('privacy.sections.cookies.p1')} />
      </section>

      <section class="legal-section">
        <h2 set:html={t('privacy.sections.internationalTransfer.title')} />
        <p set:html={t('privacy.sections.internationalTransfer.p1')} />
      </section>

      <section class="legal-section">
        <h2 set:html={t('privacy.sections.minors.title')} />
        <p set:html={t('privacy.sections.minors.p1')} />
      </section>

      <section class="legal-section">
        <h2 set:html={t('privacy.sections.changes.title')} />
        <p set:html={t('privacy.sections.changes.p1')} />
      </section>

      <section class="legal-section">
        <h2 set:html={t('privacy.sections.contactDPO.title')} />
        <p set:html={t('privacy.sections.contactDPO.p1')} />
        <p set:html={t('privacy.sections.contactDPO.p2')} />
      </section>

      <section class="legal-section">
        <h2 set:html={t('privacy.sections.summary.title')} />
        <p set:html={t('privacy.sections.summary.p1')} />

        <h3 set:html={t('privacy.sections.summary.notLinked.title')} />
        <p set:html={t('privacy.sections.summary.notLinked.p1')} />
        <ul>
          {ensureArray(t('privacy.sections.summary.notLinked.items')).map((item: string) => (
            <li set:html={item} />
          ))}
        </ul>

        <h3 set:html={t('privacy.sections.summary.linked.title')} />
        <p set:html={t('privacy.sections.summary.linked.p1')} />
        <ul>
          {ensureArray(t('privacy.sections.summary.linked.items')).map((item: string) => (
            <li set:html={item} />
          ))}
        </ul>

        <h3 set:html={t('privacy.sections.summary.notCollectedSummary.title')} />
        <p set:html={t('privacy.sections.summary.notCollectedSummary.p1')} />

        <p set:html={t('privacy.sections.summary.deletion')} />
      </section>
    </div>
  </main>
</Base>

<style>
  .legal-page {
    padding: 3rem var(--space-4) 5rem;
    min-height: 100vh;
  }

  .legal-container {
    max-width: 780px;
    margin-inline: auto;
  }

  .legal-header {
    margin-bottom: var(--space-10);
    padding-bottom: var(--space-6);
    border-bottom: 1px solid var(--color-border);
  }

  .legal-header h1 {
    font-size: var(--text-2xl);
    font-weight: 700;
    margin-top: var(--space-2);
    margin-bottom: var(--space-2);
    color: var(--color-primary);
    letter-spacing: -0.02em;
  }

  .legal-meta {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    color: var(--color-text-faint);
  }

  .legal-section {
    margin-bottom: var(--space-10);
  }

  .legal-section h2 {
    font-size: var(--text-lg);
    font-weight: 700;
    margin-bottom: var(--space-4);
    color: var(--color-primary);
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .legal-section h3 {
    font-size: 1rem;
    font-weight: 600;
    margin: 1.25rem 0 0.5rem;
    color: var(--color-text);
  }

  .legal-section p {
    font-size: var(--text-base);
    line-height: 1.8;
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
  }

  .legal-section ul {
    padding-left: var(--space-6);
    margin: 0.5rem 0 var(--space-6);
    list-style: disc;
  }

  .legal-section ul li {
    font-size: var(--text-base);
    line-height: 1.75;
    color: var(--color-text-muted);
    margin-bottom: var(--space-2);
  }

  .legal-section a {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 4px;
    transition: color var(--transition);
  }

  .legal-section a:hover {
    color: var(--color-primary-hover);
  }
</style>
