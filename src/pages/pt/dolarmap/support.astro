---
import Base from '@layouts/Base.astro';
import { useTranslations } from '@i18n/ui';

const lang = 'pt-BR';
const t = useTranslations(lang);

const title = t.support.meta.title;
const description = t.support.meta.description;

const alternates = [
  { hreflang: 'en',        href: 'https://bitsark.com/dolarmap/support/' },
  { hreflang: 'pt-BR',     href: 'https://bitsark.com/pt/dolarmap/support/' },
  { hreflang: 'x-default', href: 'https://bitsark.com/dolarmap/support/' },
];
---

<Base
  title={title}
  description={description}
  lang={lang}
  canonical="https://bitsark.com/pt/dolarmap/support/"
  alternates={alternates}
  noindex={true}
>
  <main class="support-page">
    <!-- ── Hero Section ── -->
    <section class="sb-hero">
      <div class="sb-hero-glow" aria-hidden="true"></div>
      <div class="sb-container">
        <p class="eyebrow fade-up">{t.support.hero.eyebrow}</p>
        <h1 class="sb-hero-title fade-up">
          {t.support.hero.title}<br />
          <span class="sb-accent">{t.support.hero.titleAccent}</span>
        </h1>
        <p class="sb-hero-sub fade-up">{t.support.hero.sub}</p>

        <div class="support-contact-card fade-up">
          <div class="contact-info">
            <span class="badge badge-primary">{t.support.contact.badge}</span>
            <p>{t.support.contact.text}</p>
            <a href="mailto:support@bitsark.com" class="contact-button">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
              {t.support.contact.email}
            </a>
            <p class="response-note" set:html={t.support.contact.response}></p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── FAQ Section ── -->
    <section class="sb-section">
      <div class="sb-container sb-narrow">
        <p class="eyebrow fade-up">{t.support.faq.eyebrow}</p>
        <h2 class="sb-section-title fade-up">{t.support.faq.title}</h2>
        
        <div class="faq-list fade-up">
          <details class="faq-item">
            <summary>{t.support.faq.q1.q}</summary>
            <div class="faq-answer">
              <p>{t.support.faq.q1.a}</p>
            </div>
          </details>

          <details class="faq-item">
            <summary>{t.support.faq.q2.q}</summary>
            <div class="faq-answer">
              <p>{t.support.faq.q2.a}</p>
            </div>
          </details>

          <details class="faq-item">
            <summary>{t.support.faq.q3.q}</summary>
            <div class="faq-answer">
              <p>{t.support.faq.q3.a}</p>
            </div>
          </details>

          <details class="faq-item">
            <summary>{t.support.faq.q4.q}</summary>
            <div class="faq-answer">
              <p>{t.support.faq.q4.a}</p>
            </div>
          </details>
        </div>
      </div>
    </section>

    <!-- ── Data Management Section ── -->
    <section class="sb-section sb-section--alt">
      <div class="sb-container sb-narrow">
        <p class="eyebrow fade-up">{t.support.privacy.eyebrow}</p>
        <h2 class="sb-section-title fade-up">{t.support.privacy.title}</h2>

        <div class="faq-list fade-up">
          <details class="faq-item">
            <summary>{t.support.privacy.q1.q}</summary>
            <div class="faq-answer">
              <p set:html={t.support.privacy.q1.a}></p>
            </div>
          </details>

          <details class="faq-item">
            <summary>{t.support.privacy.q2.q}</summary>
            <div class="faq-answer">
              <p set:html={t.support.privacy.q2.a}></p>
            </div>
          </details>

          <details class="faq-item">
            <summary>{t.support.privacy.q3.q}</summary>
            <div class="faq-answer">
              <p set:html={t.support.privacy.q3.a}></p>
            </div>
          </details>
        </div>
      </div>
    </section>

    <!-- ── Account Deletion Section ── -->
    <section id="account-deletion" class="sb-section">
      <div class="sb-container sb-narrow">
        <p class="eyebrow fade-up">{t.support.deletion.eyebrow}</p>
        <h2 class="sb-section-title fade-up">{t.support.deletion.title}</h2>
        <p class="sb-section-desc fade-up" set:html={t.support.deletion.desc}></p>

        <div class="deletion-card fade-up">
          <div class="deletion-card-header">
            <span class="badge badge-warning">{t.support.deletion.card.badge}</span>
            <h3>{t.support.deletion.card.title}</h3>
            <p>{t.support.deletion.card.sub}</p>
          </div>

          <div class="deletion-steps">
            <div class="deletion-step">
              <span class="step-number">1</span>
              <div class="step-content">
                <strong>{t.support.deletion.card.step1.title}</strong>
                <p set:html={t.support.deletion.card.step1.text}></p>
              </div>
            </div>
            <div class="deletion-step">
              <span class="step-number">2</span>
              <div class="step-content">
                <strong>{t.support.deletion.card.step2.title}</strong>
                <div class="code-block">{t.support.deletion.card.step2.code}</div>
              </div>
            </div>
            <div class="deletion-step">
              <span class="step-number">3</span>
              <div class="step-content">
                <strong>{t.support.deletion.card.step3.title}</strong>
                <p>{t.support.deletion.card.step3.text}</p>
              </div>
            </div>
          </div>

          <div class="deletion-card-footer">
            <a
              href={`mailto:support@bitsark.com?subject=${encodeURIComponent(t.support.deletion.card.step2.code)}&body=${encodeURIComponent(t.support.deletion.card.body)}`}
              class="contact-button deletion-button"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
              {t.support.deletion.card.button}
            </a>
            <p class="deletion-notice" set:html={t.support.deletion.card.notice}></p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Footer Links ── -->
    <footer class="support-footer fade-up">
      <div class="sb-container">
        <p class="legal-links">
          <a href={lang === 'pt-BR' ? '/pt/dolarmap/privacy' : '/dolarmap/privacy'}>{t.support.footer.privacy}</a>
          <span aria-hidden="true">·</span>
          <a href={lang === 'pt-BR' ? '/pt/dolarmap/terms' : '/dolarmap/terms'}>{t.support.footer.terms}</a>
        </p>
        <p class="legal-meta">{t.support.footer.meta}</p>
      </div>
    </footer>
  </main>
</Base>

<style>
  /* ── Layout & Containers ── */
  .sb-container { max-width: var(--content-wide); margin-inline: auto; padding-inline: var(--space-6); }
  .sb-narrow    { max-width: 720px; }
  .support-page { background: var(--color-bg); color: var(--color-text); }

  /* ── Hero Pattern (Sync with dolarmap/index) ── */
  .sb-hero {
    position: relative;
    overflow: hidden;
    padding-block: clamp(4rem, 8vw, 6rem);
    border-bottom: 1px solid var(--color-border);
  }
  .sb-hero-glow {
    position: absolute;
    top: -20%;
    left: 50%;
    transform: translateX(-50%);
    width: 800px;
    height: 600px;
    background: radial-gradient(ellipse at center, rgba(var(--color-primary-rgb), 0.08) 0%, transparent 70%);
    pointer-events: none;
  }
  .sb-hero-title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    line-height: 1.1;
    margin-bottom: var(--space-6);
  }
  .sb-accent { color: var(--color-primary); }
  .sb-hero-sub {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    max-width: 50ch;
    line-height: 1.6;
    margin-bottom: var(--space-8);
  }

  /* ── Contact Card ── */
  .support-contact-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-8);
    max-width: 500px;
    box-shadow: var(--shadow-lg);
  }
  .contact-info p { margin-block: var(--space-2) var(--space-4); color: var(--color-text-muted); }
  .contact-button {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    background: var(--color-primary);
    color: var(--color-text-inverse);
    padding: 0.8rem 1.5rem;
    border-radius: var(--radius-md);
    font-weight: 700;
    text-decoration: none;
    transition: filter 0.2s;
  }
  .contact-button:hover { filter: brightness(1.1); }
  .response-note { font-size: 0.75rem; color: var(--color-text-faint) !important; margin-top: 1rem; }

  /* ── Section Standard ── */
  .sb-section { padding-block: clamp(3rem, 6vw, 5rem); }
  .sb-section--alt { background: var(--color-surface); border-block: 1px solid var(--color-border); }
  .sb-section-title { font-family: var(--font-display); font-size: var(--text-xl); margin-bottom: var(--space-8); }

  /* ── Section description ── */
  .sb-section-desc { color: var(--color-text-muted); font-size: var(--text-base); line-height: 1.7; margin-bottom: var(--space-8); max-width: 60ch; }

  /* ── Deletion Card ── */
  .deletion-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
  }
  .deletion-card-header {
    padding: var(--space-8);
    border-bottom: 1px solid var(--color-border);
  }
  .deletion-card-header h3 {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    margin-block: var(--space-3) var(--space-2);
  }
  .deletion-card-header p { color: var(--color-text-muted); font-size: var(--text-sm); margin: 0; }
  .badge-warning { background: color-mix(in srgb, var(--color-warning, #f59e0b) 15%, transparent); color: var(--color-warning, #f59e0b); border: 1px solid color-mix(in srgb, var(--color-warning, #f59e0b) 30%, transparent); }

  .deletion-steps { padding: var(--space-8); display: flex; flex-direction: column; gap: var(--space-6); }
  .deletion-step { display: flex; gap: var(--space-4); align-items: flex-start; }
  .step-number {
    flex-shrink: 0;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: var(--color-primary);
    color: var(--color-text-inverse);
    font-weight: 700;
    font-size: var(--text-sm);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .step-content { flex: 1; }
  .step-content strong { display: block; color: var(--color-text); margin-bottom: var(--space-1); font-size: var(--text-sm); }
  .step-content p { color: var(--color-text-muted); font-size: var(--text-sm); margin: 0; line-height: 1.5; }
  .step-content a { color: var(--color-primary); }
  .code-block {
    margin-top: var(--space-2);
    padding: var(--space-3) var(--space-4);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text);
    user-select: all;
  }

  .deletion-card-footer {
    padding: var(--space-8);
    border-top: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-surface) 50%, var(--color-bg));
  }
  .deletion-button { background: var(--color-text); color: var(--color-bg); margin-bottom: var(--space-4); }
  .deletion-button:hover { filter: brightness(1.15); }
  .deletion-notice { font-size: var(--text-xs); color: var(--color-text-faint); margin: 0; line-height: 1.6; }

  /* ── Footer ── */
  .support-footer { padding-block: 4rem; text-align: center; border-top: 1px solid var(--color-border); }
  .legal-links { display: flex; justify-content: center; gap: 1rem; margin-bottom: 1rem; font-size: var(--text-sm); }
  .legal-links a { color: var(--color-text-muted); }
  .legal-meta { font-size: var(--text-xs); color: var(--color-text-faint); }

  /* ── Animations ── */
  .fade-up { opacity: 0; transform: translateY(20px); transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1); }
  .fade-up.visible { opacity: 1; transform: translateY(0); }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) entry.target.classList.add('visible');
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));
</script>