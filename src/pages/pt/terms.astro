---
import Base from '@layouts/Base.astro';
import { useTranslations } from '@i18n/ui';

const lang = 'pt-BR';
const t = useTranslations(lang);
const strings = t.site_terms;

const alternates = [
  { hreflang: 'en', href: 'https://bitsark.com/terms/' },
  { hreflang: 'pt-BR', href: 'https://bitsark.com/pt/terms/' },
  { hreflang: 'x-default', href: 'https://bitsark.com/terms/' }
];
---

<Base 
  title={strings.meta.title} 
  description={strings.meta.description}
  lang={lang}
  canonical="https://bitsark.com/pt/terms/"
  alternates={alternates}
  noindex={true}
>
  <main class="section legal-page">
    <div class="legal-container">
      <header class="legal-header">
        <p class="eyebrow">{strings.header.eyebrow}</p>
        <h1>{strings.header.title}</h1>
        <p class="legal-meta" set:html={strings.header.meta} />
      </header>

      <section id="identification" class="legal-section">
        <h2>{strings.s1.h2}</h2>
        <p set:html={strings.s1.p} />
      </section>

      <section id="disclaimer" class="legal-section">
        <h2>{strings.s2.h2}</h2>
        <p set:html={strings.s2.p} />
      </section>

      <section id="accuracy" class="legal-section">
        <h2>{strings.s3.h2}</h2>
        <p set:html={strings.s3.p} />
        <div class="legal-callout">
          <p set:html={strings.s3.callout} />
        </div>
      </section>

      <section id="api" class="legal-section">
        <h2>{strings.s4.h2}</h2>
        <p set:html={strings.s4.p} />
        <ul>
          {strings.s4.li.map(item => <li set:html={item} />)}
        </ul>
      </section>

      <section id="third-party" class="legal-section">
        <h2>{strings.s5.h2}</h2>
        <p set:html={strings.s5.p} />
      </section>

      <section id="ecosystem" class="legal-section">
        <h2>{strings.s6.h2}</h2>
        <p set:html={strings.s6.p} />
      </section>

      <section id="intellectual-property" class="legal-section">
        <h2>{strings.s7.h2}</h2>
        <p set:html={strings.s7.p} />
      </section>

      <section id="liability" class="legal-section">
        <h2>{strings.s8.h2}</h2>
        <p set:html={strings.s8.p} />
      </section>

      <section id="jurisdiction" class="legal-section">
        <h2>{strings.s9.h2}</h2>
        <p set:html={strings.s9.p} />
      </section>
    </div>
  </main>
</Base>

<style>
  .legal-page {
    min-height: 100vh;
  }

  .legal-container {
    max-width: 780px;
    margin-inline: auto;
    /* Garante que o texto não cole nas bordas em mobile */
    padding-inline: var(--space-4);
  }

  .legal-header h1 {
    font-size: var(--text-2xl);
    margin-top: var(--space-2);
    margin-bottom: var(--space-2);
    color: var(--color-primary);
    letter-spacing: -0.02em;
  }

  .legal-header {
    margin-bottom: var(--space-10);
    padding-bottom: var(--space-6);
    border-bottom: 1px solid var(--color-border);
  }

  .legal-meta {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    color: var(--color-text-faint);
  }

  .legal-section {
    margin-bottom: var(--space-10);
  }

  .legal-section h2 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-4);
    color: var(--color-primary);
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .legal-section p {
    font-size: var(--text-base);
    line-height: 1.8;
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
  }

  .legal-section ul {
    padding-left: var(--space-6);
    margin-bottom: var(--space-6);
    list-style: disc;
  }

  .legal-section ul li {
    font-size: var(--text-base);
    margin-bottom: var(--space-2);
    color: var(--color-text-muted);
  }

  .legal-section a {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 4px;
    transition: color var(--transition);
  }

  .legal-section a:hover {
    color: var(--color-primary-hover);
  }
  
  .legal-callout {
    background: var(--color-error-highlight);
    border-left: 4px solid var(--color-error);
    padding: var(--space-5);
    margin-block: var(--space-8);
    border-radius: var(--radius-md);
  }
  
  .legal-callout p { 
    color: var(--color-text); 
    margin: 0; 
    font-size: var(--text-sm);
    line-height: 1.6;
  }
</style>