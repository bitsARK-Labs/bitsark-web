---
import Base from '@layouts/Base.astro';
import { Picture } from 'astro:assets';
import founderImg from '@assets/founder.jpg';
import t    from '@i18n/pt.json';
import '@styles/pages/about.css';

const emailRicardo = 'ricardo@bitsark.com';
const emailRicardoRev = emailRicardo.split('').reverse().join('');

const alternates = [
  { hreflang: 'en',        href: 'https://bitsark.com/about/' },
  { hreflang: 'pt-BR',     href: 'https://bitsark.com/pt/about/' },
  { hreflang: 'x-default', href: 'https://bitsark.com/about/' },
];

/**
 * dateModified em formato ISO 8601 com timezone (Schema.org DateTime).
 * Usar apenas YYYY-MM-DD provoca "datetime inválido" no Rich Results Test.
 * O <time datetime> no HTML aceita YYYY-MM-DD; por isso derivamos a versão
 * "date-only" abaixo.
 */
const dateModifiedISO = '2026-05-26T12:00:00+00:00';
const dateModifiedDateOnly = dateModifiedISO.slice(0, 10);

const founderImageUrl = new URL(founderImg.src, Astro.site).href;

const schema = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  "@id": "https://bitsark.com/pt/about/#profilepage",
  "url": "https://bitsark.com/pt/about/",
  "name": "Sobre Ricardo Delfino - Fundador da bitsARK Labs",
  "inLanguage": "pt-BR",
  "dateModified": dateModifiedISO,
  "isPartOf": { "@id": "https://bitsark.com/#website" },
  "about": { "@id": "https://bitsark.com/about/#ricardo" },
  "mainEntity": {
    "@type": "Person",
    "@id": "https://bitsark.com/about/#ricardo",
    "name": "Ricardo Delfino",
    "givenName": "Ricardo",
    "familyName": "Delfino",
    "url": "https://bitsark.com/pt/about/",
    "image": {
      "@type": "ImageObject",
      "url": founderImageUrl,
      "width": founderImg.width,
      "height": founderImg.height
    },
    "jobTitle": "Founder",
    "email": "ricardo@bitsark.com",
    "description": "Fundador da bitsARK Labs. Especialista em pagamentos e fintech focado em ativos digitais, rails cripto-fiat e localização de produto no LATAM.",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "São Paulo",
      "addressCountry": "BR"
    },
    "worksFor": { "@id": "https://bitsark.com/#organization" },
    "knowsAbout": [
      "Pagamentos",
      "Pix",
      "Maquininhas",
      "PSPs",
      "Crypto on-ramps",
      "Fiat on-ramps",
      "Stablecoins",
      "Bitcoin",
      "Regulação cripto Brasil",
      "Receita Federal IN RFB 1888",
      "Receita Federal IN RFB 2.291 (DeCripto)",
      "Lei 14.754/2023",
      "Autorização BCB (PSAV)",
      "CVM",
      "BCRA",
      "Arbitragem cambial",
      "Modelagem financeira",
      "M&A",
      "Localização de produto",
      "Go-to-Market LATAM"
    ],
    "knowsLanguage": ["pt-BR", "en", "es"],
    "nationality": { "@type": "Country", "name": "Brazil" },
    "sameAs": [
      "https://www.linkedin.com/in/ricardods/",
      "https://play.google.com/store/apps/dev?id=7793792104800726717"
    ]
  }
};

const lastUpdatedLabel = new Date(dateModifiedISO).toLocaleDateString('pt-BR', { day: 'numeric', month: 'long', year: 'numeric', timeZone: 'UTC' });
---

<Base
  title={t.about.meta.title}
  description={t.about.meta.description}
  lang={t.lang}
  canonical="https://bitsark.com/pt/about/"
  alternates={alternates}
  schema={schema}
>

  <!-- ── Hero ─────────────────────────────────────────────── -->
  <section class="about-hero">
    <div class="container">
      <div class="about-hero__byline">
        <Picture
          src={founderImg}
          alt="Ricardo Delfino - Fundador da bitsARK Labs"
          widths={[96, 144, 192, 288]}
          sizes="96px"
          formats={['avif', 'webp']}
          quality={88}
          class="about-hero__photo"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
        <div class="about-hero__byline-text">
          <p class="eyebrow">{t.about.hero.eyebrow}</p>
          <p class="about-hero__name">Ricardo Delfino</p>
          <p class="about-hero__role">{t.about.hero.role}</p>
        </div>
      </div>

      <h1>{t.about.hero.title}</h1>
      <p class="about-hero__sub">{t.about.hero.sub}</p>

      <p class="about-hero__updated">
        <span>{t.about.hero.location}</span>
      </p>

      <div class="social-links">
        <a href="https://www.linkedin.com/in/ricardods/" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          LinkedIn
        </a>
        <a href={`mailto:${emailRicardo}`} class="social-link" aria-label={`Email: ${emailRicardo}`}>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,12 2,6"/></svg>
          <span style="unicode-bidi: bidi-override; direction: rtl;" aria-hidden="true">{emailRicardoRev}</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ── Summary ──────────────────────────────────────────── -->
  <section class="section" aria-labelledby="summary-heading">
    <div class="container about-layout">
      <h2 id="summary-heading" class="about-section-title">{t.about.summary.title}</h2>
      <div class="about-summary">
        {t.about.summary.body.map((para: string) => (
          <p>{para}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- ── What I'm building ────────────────────────────────── -->
  <section class="section section--alt" aria-labelledby="projects-heading">
    <div class="container">
      <h2 id="projects-heading" class="section__title">{t.about.projects.title}</h2>

      <div class="exec-strip">
        {t.about.projects.items.map((item, i) => {
          const isExternal = item.url.startsWith('http');
          return (
            <a class:list={['exec-item', 'exec-item--link', { 'exec-item--bordered': i > 0 }]}
               href={item.url}
               target={isExternal ? '_blank' : undefined}
               rel={isExternal ? 'noopener noreferrer' : undefined}>
              <span class="exec-item__label">{item.label}</span>
              <span class="exec-item__meta">{item.meta}</span>
              <span class="exec-item__proof">{item.desc}</span>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ── Expertise ────────────────────────────────────────── -->
  <section class="section" aria-labelledby="expertise-heading">
    <div class="container about-layout">
      <h2 id="expertise-heading" class="section__title">{t.about.expertise.title}</h2>

      <dl class="expertise-list">
        {t.about.expertise.groups.map(group => (
          <div class="expertise-group">
            <dt class="expertise-group__label">{group.label}</dt>
            <dd class="expertise-group__items">{group.items.join(' · ')}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- ── Languages ────────────────────────────────────────── -->
  <section class="section section--alt" aria-labelledby="languages-heading">
    <div class="container about-layout">
      <h2 id="languages-heading" class="section__title">{t.about.languages.title}</h2>
      <p class="languages-line">
        {t.about.languages.items.map(lang => `${lang.name} (${lang.level})`).join(' · ')}
      </p>
    </div>
  </section>

  <!-- ── Contact + Disclaimer ─────────────────────────────── -->
  <section class="section" id="contact" aria-labelledby="contact-heading">
    <div class="container">
      <div class="contact-card">
        <p class="eyebrow">{t.about.contact.eyebrow}</p>
        <h2 id="contact-heading" class="contact-card__title">{t.about.contact.title}</h2>
        <p class="contact-card__body">{t.about.contact.body}</p>
        <div class="contact-card__actions">
          <a href={`mailto:${emailRicardo}`} class="btn btn-primary" aria-label={`Email: ${emailRicardo}`}>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,12 2,6"/></svg>
            <span style="unicode-bidi: bidi-override; direction: rtl;" aria-hidden="true">{emailRicardoRev}</span>
          </a>
          <a href="https://www.linkedin.com/in/ricardods/" class="btn btn-secondary" target="_blank" rel="noopener noreferrer">{t.about.contact.ctaLinkedin}</a>
        </div>
      </div>

    </div>
  </section>

</Base>
