---
import Base from '@layouts/Base.astro';
import { codeToHtml } from 'shiki';
import { getLangFromUrl, useTranslations, defaultLang, useLocalizedPath } from '@i18n/index';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const l = useLocalizedPath(lang);
const BASE_URL = 'https://api.bitsark.com/v1';

const _hl = (code: string, lang: string) =>
  codeToHtml(code, { lang, theme: 'github-dark' });

const exampleSingle = `{
  "success": true,
  "notice": "Data is provided for informational purposes only and may be outdated. BitsARK does not guarantee accuracy. Always verify with the official exchange. Full terms: https://bitsark.com/terms",
  "data": {
    "id": "mercado-bitcoin",
    "name": "Mercado Bitcoin",
    "slug": "mercado-bitcoin",
    "website": "https://www.mercadobitcoin.com.br",
    "logo_url": "https://assets.bitsark.com/logos/mercado-bitcoin.svg",
    "updated_at": "2026-04-22T21:56:00Z",
    "fiscal_status_br": "Nacional",
    "operational_details_br": {
      "cnpj": "18.213.434/0001-35",
      "bcb_authorized": true,
      "accepts_pix": true,
      "main_jurisdiction_iso": "BR"
    },
    "fiscal_details_br": {
      "tax_regime": "domestic_exchange",
      "monthly_brl_trade_exemption": 35000,
      "exchange_rfb_reports": ["in_1888_monthly"],
      "user_rfb_action_monthly": []
    },
    "fees": {
      "maker": 0.003,
      "taker": 0.007,
      "fee_url": "https://www.mercadobitcoin.com.br/taxas-contas-limites",
      "note": "Largest Brazilian exchange by volume. Pix fully supported. Volume-based tiers."
    }
  }
}`;

const hlSingle = await _hl(exampleSingle, 'json');
const hlQuickstart = await _hl(
  `curl "${BASE_URL}/exchanges?accepts_pix=true&brazil_registered=true"`,
  'bash'
);
const hlFetch = await _hl(
  `const res = await fetch('${BASE_URL}/exchanges/mercado-bitcoin');
if (!res.ok) throw new Error('BitsARK API ' + res.status);

const body = await res.json();
console.log(body.data.fiscal_details_br.tax_regime);`,
  'javascript'
);
const hlPython = await _hl(
  `import json
from urllib.request import urlopen

with urlopen("${BASE_URL}/exchanges/mercado-bitcoin") as res:
    body = json.load(res)

print(body["data"]["fiscal_details_br"]["tax_regime"])`,
  'python'
);
const hlLlmGuide = await _hl(
  `Use the BitsARK Exchanges API for Brazilian crypto exchange metadata, Pix support, BCB authorization, fiscal classification, RFB reporting obligations, and fee comparisons.
Base URL: ${BASE_URL}
No API key is required. CORS is enabled. Use data as informational, not as tax, legal, investment, or financial advice.`,
  'text'
);
const hlRateLimit = await _hl(
`{
  "success": false,
  "error": "Rate limit exceeded. Maximum 60 requests per minute.",
  "retry_after": 1746000420
}`,
  'json'
);
const hlCurl = await _hl(
  `curl "${BASE_URL}/exchanges?brazil_registered=true&bcb_licensed=true&accepts_pix=true"`,
  'bash'
);
const hlToFlag = await _hl(
  `const toFlag = (iso) => String.fromCodePoint(...[...iso].map(c => 0x1F1E6 - 65 + c.charCodeAt(0)));`,
  'javascript'
);
const hlMakerNull = await _hl(
  `"maker": null, "taker": 0.006 // spread/flat-rate model`,
  'jsonc'
);

const alternates = [
  { hreflang: 'en',        href: 'https://bitsark.com/exchanges/api' },
  { hreflang: 'pt-BR',     href: 'https://bitsark.com/pt/exchanges/api' },
  { hreflang: 'x-default', href: 'https://bitsark.com/exchanges/api' },
];
---

<Base
  title={t('exchanges_api.meta.title')}
  description={t('exchanges_api.meta.description')}
  lang={lang}
  alternates={alternates}
  ogImage="https://bitsark.com/og/exchanges-api.png"
>
  <meta
    slot="head"
    name="robots"
    content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1"
  />
  <link
    slot="head"
    rel="alternate"
    type="text/plain"
    href="https://bitsark.com/llms.txt"
    title="BitsARK LLM-readable summary"
  />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify([
    {
      "@context": "https://schema.org",
      "@type": "WebAPI",
      "name": "BitsARK Exchanges API",
      "description": "Free JSON API providing fiscal, regulatory, and fee data on cryptocurrency exchanges operating in Brazil.",
      "url": "https://bitsark.com/pt/exchanges/api",
      "documentation": "https://bitsark.com/pt/exchanges/api",
      "termsOfService": "https://bitsark.com/terms",
      "isAccessibleForFree": true,
      "encodingFormat": "application/json",
      "entryPoint": {
        "@type": "EntryPoint",
        "urlTemplate": "https://api.bitsark.com/v1/exchanges",
        "httpMethod": "GET",
        "contentType": "application/json"
      },
      "provider": {
        "@type": "Organization",
        "name": "BitsARK Labs",
        "legalName": "Tecnologia Atual Serviços LTDA",
        "url": "https://bitsark.com",
        "contactPoint": { "@type": "ContactPoint", "email": "support@bitsark.com" }
      },
      "license": "https://opensource.org/licenses/MIT"
    },
    {
      "@context": "https://schema.org",
      "@type": "TechArticle",
      "headline": "BitsARK Exchanges API Documentation",
      "description": "Free REST API with fiscal, regulatory, and fee data on 24+ crypto exchanges in Brazil.",
      "url": "https://bitsark.com/pt/exchanges/api",
      "proficiencyLevel": "Beginner",
      "inLanguage": "pt-BR"
    }
  ])} />

  <div class="api-layout">

    <!-- ── Sidebar ─────────────────────────────────────────── -->
    <aside class="api-sidebar" aria-label="API navigation">
      <nav>
        <p class="api-sidebar__group">{t('exchanges_api.sidebar.getting_started')}</p>
        <a href="#overview" class="api-sidebar__link">{t('exchanges_api.sidebar.overview')}</a>
        <a href="#quickstart" class="api-sidebar__link">{t('exchanges_api.sidebar.quickstart')}</a>
        <a href="#base-url" class="api-sidebar__link">{t('exchanges_api.sidebar.base_url')}</a>
        <a href="#rate-limits" class="api-sidebar__link">{t('exchanges_api.sidebar.rate_limits')}</a>

        <p class="api-sidebar__group">{t('exchanges_api.sidebar.endpoints')}</p>
        <a href="#ep-list" class="api-sidebar__link">GET /exchanges</a>
        <a href="#ep-fees" class="api-sidebar__link">GET /exchanges/fees</a>
        <a href="#ep-brazil" class="api-sidebar__link">GET /exchanges/brazil-registered</a>
        <a href="#ep-single" class="api-sidebar__link">GET /exchanges/:id</a>

        <p class="api-sidebar__group">{t('exchanges_api.sidebar.reference')}</p>
        <a href="#example" class="api-sidebar__link">{t('exchanges_api.sidebar.example')}</a>
        <a href="#schema" class="api-sidebar__link">{t('exchanges_api.sidebar.schema')}</a>
        <a href="#filters" class="api-sidebar__link">{t('exchanges_api.sidebar.filters')}</a>

        <p class="api-sidebar__group">{t('exchanges_api.sidebar.fiscal')}</p>
        <a href="#tax-regime" class="api-sidebar__link">{t('exchanges_api.sidebar.tax_regime')}</a>
        <a href="#rfb-reports" class="api-sidebar__link">{t('exchanges_api.sidebar.rfb_reports')}</a>
        <a href="#user-actions" class="api-sidebar__link">{t('exchanges_api.sidebar.user_actions')}</a>

        <p class="api-sidebar__group">{t('exchanges_api.sidebar.operational')}</p>
        <a href="#jurisdiction" class="api-sidebar__link">{t('exchanges_api.sidebar.jurisdiction')}</a>
        <a href="#fees-spread" class="api-sidebar__link">{t('exchanges_api.sidebar.fees_spread')}</a>

      <p class="api-sidebar__group">{t('exchanges_api.sidebar.support')}</p>
      <button type="button" id="open-feedback-btn-sidebar" class="api-sidebar__link api-sidebar__link--support">
        {t('exchanges_api.sidebar.report_issue')}
      </button>

      <!-- Uptime badge - Exchanges API -->
      <a
        href="https://status.bitsark.com"
        class="api-sidebar__uptime"
        target="_blank"
        rel="noopener noreferrer" 
        aria-label={t('exchanges_api.aria_labels.api_status_page')}
      >
        <img
          src="https://uptime.betterstack.com/status-badges/v1/monitor/2m06z.svg"
          alt={t('exchanges_api.aria_labels.api_uptime_alt')}
          width="104"
          height="20"
          loading="lazy"
          decoding="async"
        />
      </a>
      </nav>
    </aside>

    <!-- ── Main content ───────────────────────────────────── -->
    <div class="api-content" id="api-content">

      <!-- Overview -->
      <section id="overview" class="api-section">
        <p class="eyebrow">{t('exchanges_api.hero.eyebrow')}</p>
        <h1 class="api-hero__title">{t('exchanges_api.hero.title')}</h1>
        <p class="api-hero__sub">
          {t('exchanges_api.hero.sub1')}
        </p>
        <p class="api-hero__sub">
          {t('exchanges_api.hero.sub2')}
        </p>
        <p class="api-hero__sub" style="font-size: var(--text-xs); border-left: 2px solid var(--color-warning); padding-left: 1rem;">
          <strong>{t('exchanges_api.hero.disclaimer_strong')}</strong> {t('exchanges_api.hero.disclaimer')} 
          {t('exchanges_api.hero.terms_prefix')} <a href={l('/terms')} style="color: var(--color-primary); text-decoration: underline;">{t('exchanges_api.hero.terms_of_service')}</a>.
        </p>
        <div class="api-badges">
          <span class="badge badge-success">{t('exchanges_api.hero.badges.live')}</span>
          <span class="badge badge-neutral">{t('exchanges_api.hero.badges.rest_json')}</span>
          <span class="badge badge-neutral">{t('exchanges_api.hero.badges.cors_enabled')}</span>
          <span class="badge badge-neutral">{t('exchanges_api.hero.badges.no_auth')}</span>
          <span class="badge badge-neutral">{t('exchanges_api.hero.badges.open_source')}</span>
        </div>
      </section>

      <hr class="api-divider" />

      <!-- Quickstart -->
      <section id="quickstart" class="api-section">
        <h2>{t('exchanges_api.quickstart.title')}</h2>
        <p>
          {t('exchanges_api.quickstart.desc')}
        </p>

        <div class="quickstart-grid">
          <article class="quickstart-card">
            <div class="quickstart-card__head">
              <span class="quickstart-card__step">1</span>
              <h3>{t('exchanges_api.quickstart.step1_title')}</h3>
            </div>
            <p>{t('exchanges_api.quickstart.step1_desc')}</p>
            <div class="code-block code-block--compact" aria-label="Quickstart curl example" set:html={hlQuickstart}></div>
          </article>

          <article class="quickstart-card">
            <div class="quickstart-card__head">
              <span class="quickstart-card__step">2</span>
              <h3>{t('exchanges_api.quickstart.step2_title')}</h3>
            </div>
            <p>{t('exchanges_api.quickstart.step2_desc')}</p>
            <div class="code-block code-block--compact" aria-label="JavaScript fetch example" set:html={hlFetch}></div>
          </article>

          <article class="quickstart-card">
            <div class="quickstart-card__head">
              <span class="quickstart-card__step">3</span>
              <h3>{t('exchanges_api.quickstart.step3_title')}</h3>
            </div>
            <p>{t('exchanges_api.quickstart.step3_desc')}</p>
            <div class="code-block code-block--compact" aria-label="Python request example" set:html={hlPython}></div>
          </article>
        </div>

        <div class="llm-usage">
          <div>
            <h3>{t('exchanges_api.quickstart.ai_title')}</h3>
            <p>
              {t('exchanges_api.quickstart.ai_desc')} {t('exchanges_api.quickstart.ai_summary_prefix')}
              <a href="/llms.txt">/llms.txt</a>.
            </p>
          </div>
          <div class="code-block code-block--compact" aria-label="LLM usage guidance" set:html={hlLlmGuide}></div>
        </div>
      </section>

      <hr class="api-divider" />

      <!-- Base URL -->
      <section id="base-url" class="api-section">
        <h2>{t('exchanges_api.base_url.title')}</h2>
        <p>{t('exchanges_api.base_url.desc1')}</p>
        <div class="base-url-box"><span class="base-url-label">BASE URL</span><code class="base-url-value">https://api.bitsark.com/v1</code></div>
        <p style="margin-top:1rem">
          {t('exchanges_api.base_url.content_type_note')}
        </p>
      </section>

      <hr class="api-divider" />

      <!-- Rate limits -->
      <section id="rate-limits" class="api-section">
        <h2>{t('exchanges_api.rate_limits.title')}</h2>
        <p>
          {t('exchanges_api.rate_limits.desc1')}
        </p>
        <p>{t('exchanges_api.rate_limits.headers_included')}</p>
        <div class="table-wrap">
          <table class="data-table">
            <thead>
              <tr><th>{t('exchanges_api.rate_limits.header_col')}</th><th>{t('exchanges_api.rate_limits.desc_col')}</th></tr>
            </thead>
            <tbody>
              <tr><td><code>X-RateLimit-Limit</code></td><td>{t('exchanges_api.rate_limits.limit_desc')}</td></tr>
              <tr><td><code>X-RateLimit-Remaining</code></td><td>{t('exchanges_api.rate_limits.rem_desc')}</td></tr>
            </tbody>
          </table>
        </div>
        <p style="margin-top:1rem">{t('exchanges_api.rate_limits.error_desc')}</p>
        <div class="code-block" aria-label="Rate limit error response" set:html={hlRateLimit}></div>
      </section>

      <hr class="api-divider" />

      <!-- ── Endpoints ──────────────────────────────────────── -->
      <section id="endpoints" class="api-section">
        <h2>{t('exchanges_api.endpoints.title')}</h2>
      </section>

      <!-- GET /exchanges -->
      <section id="ep-list" class="api-section" style="padding-top:0">
        <div class="endpoint-card">
          <div class="endpoint-card__header">
            <span class="endpoint-card__method">GET</span>
            <code class="endpoint-card__url">/exchanges</code>
          </div>
          <p class="endpoint-card__desc">
            {t('exchanges_api.endpoints.list_desc')}
          </p>
          <p class="endpoint-card__desc">
            {t('exchanges_api.endpoints.pagination_note')}
          </p>
          <div class="endpoint-card__curl">
            <span class="curl-label">{t('exchanges_api.endpoints.example_label')}</span>
            <code>curl https://api.bitsark.com/v1/exchanges?accepts_pix=true&amp;brazil_registered=true</code>
          </div>
        </div>

        <!-- GET /exchanges/fees -->
        <div class="endpoint-card" id="ep-fees">
          <div class="endpoint-card__header">
            <span class="endpoint-card__method">GET</span>
            <code class="endpoint-card__url">/exchanges/fees</code>
          </div>
          <p class="endpoint-card__desc">
            {t('exchanges_api.endpoints.fees_desc')}
          </p>
          <div class="endpoint-card__curl">
            <span class="curl-label">{t('exchanges_api.endpoints.example_label')}</span>
            <code>curl https://api.bitsark.com/v1/exchanges/fees?brazil_registered=true</code>
          </div>
        </div>

        <!-- GET /exchanges/brazil-registered -->
        <div class="endpoint-card" id="ep-brazil">
          <div class="endpoint-card__header">
            <span class="endpoint-card__method">GET</span>
            <code class="endpoint-card__url">/exchanges/brazil-registered</code>
          </div>
          <p class="endpoint-card__desc">
            {t('exchanges_api.endpoints.brazil_desc')}
          </p>
          <div class="endpoint-card__curl">
            <span class="curl-label">{t('exchanges_api.endpoints.example_label')}</span>
            <code>curl https://api.bitsark.com/v1/exchanges/brazil-registered</code>
          </div>
        </div>

        <!-- GET /exchanges/:id -->
        <div class="endpoint-card" id="ep-single">
          <div class="endpoint-card__header">
            <span class="endpoint-card__method">GET</span>
            <code class="endpoint-card__url">/exchanges/<span class="endpoint-card__param">{'{id}'}</span></code>
          </div>
          <p class="endpoint-card__desc">
            {t('exchanges_api.endpoints.single_desc')}
          </p>
          <div class="endpoint-card__examples">
            <code>mercado-bitcoin</code>
            <code>binance</code>
            <code>foxbit</code>
            <code>nubank</code>
          </div>
          <div class="endpoint-card__curl" style="margin-top:0.75rem">
            <span class="curl-label">{t('exchanges_api.endpoints.example_label')}</span>
            <code>curl https://api.bitsark.com/v1/exchanges/mercado-bitcoin</code>
          </div>
        </div>
      </section>

      <hr class="api-divider" />

      <!-- Example response -->
      <section id="example" class="api-section">
        <h2>{t('exchanges_api.example_response.title')}</h2>
        <p>
          {t('exchanges_api.example_response.description')}
        </p>
        <div class="code-block" role="region" aria-label="JSON example response" set:html={hlSingle}></div>
      </section>

      <hr class="api-divider" />

      <!-- Schema reference -->
      <section id="schema" class="api-section"><h2>{t('exchanges_api.schema_reference.title')}</h2>
        <p>
          {t('exchanges_api.schema_reference.description')}
        </p>

        <div class="table-wrap">
          <table class="data-table">
            <thead>
              <tr>
                <th>{t('exchanges_api.schema_reference.table_headers.field')}</th>
                <th>{t('exchanges_api.schema_reference.table_headers.type')}</th>
                <th>{t('exchanges_api.schema_reference.table_headers.description')}</th>
              </tr>
            </thead>
            <tbody>
              <tr><td><code>id</code></td><td>string</td><td>{t('exchanges_api.schema_reference.fields.id_desc')}</td></tr>
              <tr><td><code>name</code></td><td>string</td><td>{t('exchanges_api.schema_reference.fields.name_desc')}</td></tr>
              <tr><td><code>slug</code></td><td>string</td><td>{t('exchanges_api.schema_reference.fields.slug_desc')}</td></tr>
              <tr><td><code>website</code></td><td>string</td><td>{t('exchanges_api.schema_reference.fields.website_desc')}</td></tr>
              <tr><td><code>logo_url</code></td><td>string</td><td>{t('exchanges_api.schema_reference.fields.logo_url_desc')}</td></tr>
              <tr><td><code>updated_at</code></td><td>ISO 8601</td><td>{t('exchanges_api.schema_reference.fields.updated_at_desc')}</td></tr>
              <tr><td><code>fiscal_status_br</code></td><td>string</td><td>{t('exchanges_api.schema_reference.fields.fiscal_status_br_desc')}</td></tr>
              <tr>
                <td colspan="3" class="data-table__group-header">{t('exchanges_api.schema_reference.fields.operational_details_br_group')}</td>
              </tr>
              <tr><td><code>cnpj</code></td><td>string | null</td><td>{t('exchanges_api.schema_reference.fields.cnpj_desc')}</td></tr>
              <tr><td><code>bcb_authorized</code></td><td>boolean</td><td>{t('exchanges_api.schema_reference.fields.bcb_authorized_desc')}</td></tr>
              <tr><td><code>accepts_pix</code></td><td>boolean</td><td>{t('exchanges_api.schema_reference.fields.accepts_pix_desc')}</td></tr>
              <tr><td><code>main_jurisdiction_iso</code></td><td>string</td><td>{t('exchanges_api.schema_reference.fields.main_jurisdiction_iso_desc')}</td></tr>
              <tr>
                <td colspan="3" class="data-table__group-header">{t('exchanges_api.schema_reference.fields.fiscal_details_br_group')}</td>
              </tr>
              <tr><td><code>tax_regime</code></td><td>string</td><td>{t('exchanges_api.schema_reference.fields.tax_regime_desc')}</td></tr>
              <tr><td><code>monthly_brl_trade_exemption</code></td><td>number</td><td>{t('exchanges_api.schema_reference.fields.monthly_brl_trade_exemption_desc')}</td></tr>
              <tr><td><code>exchange_rfb_reports</code></td><td>string[]</td><td>{t('exchanges_api.schema_reference.fields.exchange_rfb_reports_desc')}</td></tr>
              <tr><td><code>user_rfb_action_monthly</code></td><td>string[]</td><td>{t('exchanges_api.schema_reference.fields.user_rfb_action_monthly_desc')}</td></tr>
              <tr>
                <td colspan="3" class="data-table__group-header">{t('exchanges_api.schema_reference.fields.fees_group')}</td>
              </tr>
              <tr><td><code>maker</code></td><td>number | null</td><td>{t('exchanges_api.schema_reference.fields.maker_desc')}</td></tr>
              <tr><td><code>taker</code></td><td>number | null</td><td>{t('exchanges_api.schema_reference.fields.taker_desc')}</td></tr>
              <tr><td><code>fee_url</code></td><td>string</td><td>{t('exchanges_api.schema_reference.fields.fee_url_desc')}</td></tr>
              <tr><td><code>note</code></td><td>string</td><td>{t('exchanges_api.schema_reference.fields.note_desc')}</td></tr>
            </tbody>
          </table>
        </div>
      </section>

      <hr class="api-divider" />

      <!-- Query filters -->
      <section id="filters" class="api-section"><h2>{t('exchanges_api.query_filters.title')}</h2>
        <p>
          {t('exchanges_api.query_filters.description')}
        </p>
        <div class="table-wrap">
          <table class="data-table">
            <thead>
              <tr><th>{t('exchanges_api.query_filters.table_headers.parameter')}</th><th>{t('exchanges_api.query_filters.table_headers.type')}</th><th>{t('exchanges_api.query_filters.table_headers.description')}</th><th>{t('exchanges_api.query_filters.table_headers.example')}</th></tr>
            </thead>
            <tbody>
              <tr>
                <td><code>brazil_registered</code></td>
                <td>boolean</td>
                <td>{t('exchanges_api.query_filters.fields.brazil_registered_desc')}</td>
                <td><code>?brazil_registered=true</code></td>
              </tr>
              <tr>
                <td><code>bcb_licensed</code></td>
                <td>boolean</td>
                <td>{t('exchanges_api.query_filters.fields.bcb_licensed_desc')}</td>
                <td><code>?bcb_licensed=true</code></td>
              </tr>
              <tr>
                <td><code>accepts_pix</code></td>
                <td>boolean</td>
                <td>{t('exchanges_api.query_filters.fields.accepts_pix_desc')}</td>
                <td><code>?accepts_pix=true</code></td>
              </tr>
              <tr>
                <td><code>tax_regime</code></td>
                <td>string</td>
                <td>{t('exchanges_api.query_filters.fields.tax_regime_desc')}</td>
                <td><code>?tax_regime=domestic_exchange</code></td>
              </tr>
              <tr>
                <td><code>fiscal_status_br</code></td>
                <td>string</td>
                <td>{t('exchanges_api.query_filters.fields.fiscal_status_br_desc')}</td>
                <td><code>?fiscal_status_br=Nacional</code></td>
