  /* ── Feedback Modal ── */
  .feedback-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.6);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    z-index: 100;
  }
  .feedback-modal {
    position: fixed;
    inset: 0;
    z-index: 101;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    pointer-events: none;
  }
  .feedback-modal:not([hidden]) { pointer-events: auto; }
  .feedback-modal-box {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: 2rem;
    width: 100%;
    max-width: 480px;
    position: relative;
    box-shadow: 0 24px 64px rgba(0,0,0,0.35);
  }
  .feedback-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: var(--color-surface-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-text-faint);
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    font-size: 0.85rem;
    transition: color var(--transition), background var(--transition);
  }
  .feedback-close:hover { color: var(--color-text); background: var(--color-surface); }
  .feedback-close:focus-visible { outline: 2px solid var(--color-primary); outline-offset: 2px; }
  .feedback-title {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 0.2rem;
    padding-right: 2rem;
  }
  .feedback-subtitle {
    font-size: var(--text-xs);
    color: var(--color-text-faint);
    margin-bottom: 1.25rem;
  }
  .feedback-types {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1rem;
  }
  .feedback-type-btn {
    font-size: var(--text-xs);
    font-weight: 600;
    padding: 0.35em 0.85em;
    border-radius: 100px;
    border: 1px solid var(--color-border);
    background: var(--color-surface-2);
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all var(--transition);
    font-family: inherit;
  }
  .feedback-type-btn:hover,
  .feedback-type-btn.active {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: #fff;
  }
  .feedback-type-btn:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }
  .feedback-textarea {
    width: 100%;
    resize: vertical;
    min-height: 80px;
    padding: 0.65rem 0.85rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    background: var(--color-surface-2);
    color: var(--color-text);
    font-size: var(--text-sm);
    font-family: inherit;
    line-height: 1.5;
    transition: border-color var(--transition);
    box-sizing: border-box;
    display: block;
    margin-bottom: 0.75rem;
  }
  .feedback-textarea:focus {
    outline: none;
    border-color: var(--color-primary);
  }
  .feedback-email {
    width: 100%;
    padding: 0.6rem 0.85rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    background: var(--color-surface-2);
    color: var(--color-text);
    font-size: var(--text-sm);
    font-family: inherit;
    transition: border-color var(--transition);
    box-sizing: border-box;
    display: block;
    margin-bottom: 1rem;
  }
  .feedback-email:focus { outline: none; border-color: var(--color-primary); }
  .feedback-status {
    font-size: var(--text-sm);
    padding: 0.65rem 0.85rem;
    border-radius: var(--radius-md);
    margin-bottom: 0.75rem;
    line-height: 1.5;
  }
  .feedback-status--ok {
    background: rgba(16,185,129,0.1);
    color: var(--color-success);
    border: 1px solid rgba(16,185,129,0.2);
  }
  .feedback-status--err {
    background: rgba(239,68,68,0.1);
    color: #f87171;
    border: 1px solid rgba(239,68,68,0.2);
  }
  .feedback-submit {
    width: 100%;
    padding: 0.7rem;
    border-radius: var(--radius-md);
    border: none;
    background: var(--color-primary);
    color: #fff;
    font-size: var(--text-sm);
    font-weight: 600;
    cursor: pointer;
    font-family: inherit;
    transition: opacity var(--transition);
  }
  .feedback-submit:disabled { opacity: 0.4; cursor: not-allowed; }
  .feedback-submit:not(:disabled):hover { opacity: 0.85; }
  .feedback-submit:focus-visible { outline: 2px solid var(--color-primary); outline-offset: 2px; }
</style>

<script>
  // ── Feedback Modal ────────────────────────────────────────────────
  (function () {
    const modal     = document.getElementById('feedback-modal');
    const backdrop  = document.getElementById('feedback-backdrop');
    const statusEl  = document.getElementById('feedback-status');
    const submitBtn = document.getElementById('feedback-submit-btn') as HTMLButtonElement | null;
    const msgEl     = document.getElementById('feedback-message')   as HTMLTextAreaElement | null;
    const emailEl   = document.getElementById('feedback-email')     as HTMLInputElement | null;
    const hpEl      = document.getElementById('feedback-hp')        as HTMLInputElement | null;

    if (!modal || !backdrop) return;

    let selectedType: string | null = null;

    // Botão único que abre o modal (Hero)
    const openers = document.querySelectorAll('#open-feedback-btn');

    function openModal() {
      modal!.hidden    = false;
      backdrop!.hidden = false;
      document.body.style.overflow = 'hidden';
      // Foco no primeiro botão de tipo para acessibilidade
      const firstType = modal!.querySelector<HTMLButtonElement>('.feedback-type-btn');
      if (firstType) firstType.focus();
    }

    function closeModal() {
      modal!.hidden    = true;
      backdrop!.hidden = true;
      document.body.style.overflow = '';
      // Reset
      selectedType = null;
      if (msgEl)   msgEl.value = '';
      if (emailEl) emailEl.value = '';
      if (statusEl) { statusEl.hidden = true; statusEl.className = 'feedback-status'; statusEl.textContent = ''; }
      if (submitBtn) submitBtn.disabled = true;
      modal!.querySelectorAll('.feedback-type-btn').forEach(b => b.classList.remove('active'));
    }

    openers.forEach(btn => btn?.addEventListener('click', openModal));
    document.getElementById('close-feedback-btn')?.addEventListener('click', closeModal);
    backdrop.addEventListener('click', closeModal);

    // Fechar com Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal!.hidden) closeModal();
    });

    // Trap focus no modal
    modal.addEventListener('keydown', (e) => {
      if ((e as KeyboardEvent).key !== 'Tab') return;
      const focusable = Array.from(
        modal!.querySelectorAll<HTMLElement>('button:not([disabled]), textarea, input, [tabindex]:not([tabindex="-1"])')
      ).filter(el => !el.closest('[aria-hidden="true"]'));
      if (!focusable.length) return;
      const first = focusable[0];
      const last  = focusable[focusable.length - 1];
      if ((e as KeyboardEvent).shiftKey && document.activeElement === first) {
        e.preventDefault(); last.focus();
      } else if (!(e as KeyboardEvent).shiftKey && document.activeElement === last) {
        e.preventDefault(); first.focus();
      }
    });

    // Seleção de tipo
    modal.querySelectorAll<HTMLButtonElement>('.feedback-type-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        modal!.querySelectorAll('.feedback-type-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        selectedType = btn.dataset.type ?? null;
        if (submitBtn) submitBtn.disabled = false;
      });
    });

    // Submit
    submitBtn?.addEventListener('click', async () => {
      // Honeypot check
      if (hpEl?.value) return;
      if (!selectedType) return;

      submitBtn.disabled = true;
      const originalText = submitBtn.textContent;
      submitBtn.textContent = 'Enviando…';

      const controller = new AbortController();
      const timeoutId = setTimeout(() => controller.abort(), 8000);

      try {
        const payload = {
          page: location.pathname,
          type: selectedType,
          message: msgEl?.value?.trim() ?? '',
          email: emailEl?.value?.trim() ?? '',
          hp: hpEl?.value ?? '',
          exchange_slug: location.pathname.split('/').filter(Boolean).pop(),
        };

        const res = await fetch('/feedback', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
          signal: controller.signal
        });

        clearTimeout(timeoutId);

        if (!res.ok) throw new Error(`HTTP ${res.status}`);

        if (statusEl) {
          statusEl.textContent = '✓ Obrigado! Vamos verificar e corrigir em breve.';
          statusEl.className   = 'feedback-status feedback-status--ok';
          statusEl.hidden      = false;
        }
        submitBtn.textContent = 'Enviado ✓';
        setTimeout(closeModal, 2200);

      } catch (err) {
        clearTimeout(timeoutId);
        console.error('[Feedback] erro:', err);

        let errorMsg = 'Erro ao enviar. Tente novamente.';
        if ((err as any).name === 'AbortError') errorMsg = 'Tempo limite excedido. Tente novamente.';

        if (statusEl) {
          statusEl.textContent = errorMsg;
          statusEl.className   = 'feedback-status feedback-status--err';
          statusEl.hidden      = false;
        }
        submitBtn.disabled     = false;
        submitBtn.textContent  = originalText;
      }
    });

    // ── Page Nav: active link com IntersectionObserver ──────────────
    const sections = document.querySelectorAll('section[id]');
    const navLinks = document.querySelectorAll('.page-nav__link');
    if (sections.length && navLinks.length) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach(entry => {
            if (!entry.isIntersecting) return;
            navLinks.forEach(link => {
              link.classList.toggle(
                'page-nav__link--active',
                link.getAttribute('href') === `#${entry.target.id}`
              );
            });
          });
        },
        { rootMargin: '-30% 0px -65% 0px' }
      );
      sections.forEach(s => observer.observe(s));
    }
  })();
</script>

