{
  "ci": {
    "collect": {
      "staticDistDir": "./dist",
      "url": [
        "http://localhost/index.html",
        "http://localhost/dolarmap/index.html",
        "http://localhost/exchanges/index.html",
        "http://localhost/stablecoins-brasil/index.html",
        "http://localhost/about/index.html",
        "http://localhost/pt/index.html",
        "http://localhost/pt/dolarmap/index.html",
        "http://localhost/pt/exchanges/index.html"
      ],
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop",
        "throttlingMethod": "simulate",
        "onlyCategories": ["performance", "accessibility", "best-practices", "seo"]
      }
    },
    "assert": {
      "assertions": {
        "categories:performance":     ["error", { "minScore": 0.90 }],
        "categories:accessibility":   ["error", { "minScore": 0.95 }],
        "categories:best-practices":  ["error", { "minScore": 0.95 }],
        "categories:seo":             ["error", { "minScore": 1.00 }],
        "largest-contentful-paint":   ["warn",  { "maxNumericValue": 2500 }],
        "cumulative-layout-shift":    ["warn",  { "maxNumericValue": 0.10 }],
        "total-blocking-time":        ["warn",  { "maxNumericValue": 200 }],
        "color-contrast":             "error",
        "image-alt":                  "error",
        "label":                      "error",
        "html-has-lang":              "error",
        "meta-description":           "error",
        "document-title":             "error",
        "uses-https":                 "off",
        "is-on-https":                "off",
        "redirects-http":             "off"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
